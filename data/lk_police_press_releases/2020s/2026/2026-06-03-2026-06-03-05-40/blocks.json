    "text": "\u0b9a\u0ba8\u0bcd\u0ba4\u0ba4\u0b95\u0ba8\u0baa\u0bca\u0bbf\u0b9f\u0bae\u0bcd \u0ba4\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0b9f\u0ba3\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0ba4\u0baa\u0bca\u0ba4\u0bc1 \u0b95\u0bbf\u0b9f\u0b9f\u0ba4\u0bcd\u0ba4 \u0ba4\u0b95\u0bb5\u0bb2\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0b9f\u0baf\u0bbf\u0bb2\u0bcd, 2026.06.02 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0ba4\u0bbf\u0baf\u0bae\u0bcd \u0bae\u0bca\u0ba4\u0bae\u0bcd\u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf\u0baf \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 \u0b92\u0bb0\u0bc1 \u0bae\u0baf\u0bca\u0ba9\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bae\u0b9f\u0bb1\u0ba4\u0bcd\u0ba4\u0bc1 \u0b9f\u0bb5\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0baa\u0bb5\u0bb3\u0bbf\u0ba8\u0bca\u0b9f\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd \u0ba4\u0baf\u0bca\u0bca\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b92\u0bb0\u0bc1 \u0b9f\u0b95\u0ba4\u0bcd\u0ba4\u0bc1\u0baa\u0bcd\u0baa\u0bca\u0b95\u0bcd\u0b95\u0bbf, \u0b85\u0ba4\u0bb1\u0bcd\u0b95\u0bca\u0ba9 \u0b92\u0bb0\u0bc1 \u0baa\u0bae\u0b95\u0b9a\u0bbf\u0ba9\u0bcd, 9 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0bae\u0bc0\u0b9f\u0bcd\u0b9f\u0bca\u0bcd \u0bb5\u0b9f\u0b95 \u0ba4\u0ba4\u0bca\u0b9f\u0bcd\u0b9f\u0bca\u0b95\u0bcd\u0b95\u0bb3\u0bcd 4, \u0b89\u0bb3\u0bcd\u0ba8\u0bca\u0b9f\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd \u0ba4\u0baf\u0bca\u0bca\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f 9 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0bae\u0bc0\u0b9f\u0bcd\u0b9f\u0bca\u0bcd \u0ba4\u0ba4\u0bca\u0b9f\u0bcd\u0b9f\u0bca\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0baf\u0ba9\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0b95\u0bcd\u0b95\u0bc2\u0b9f\u0bbf\u0baf \u0b92\u0bb0\u0bc1 \u0ba4\u0bc1\u0baa\u0bcd\u0baa\u0bca\u0b95\u0bcd\u0b95\u0bbf, \u0b92\u0bb0\u0bc1 9 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0