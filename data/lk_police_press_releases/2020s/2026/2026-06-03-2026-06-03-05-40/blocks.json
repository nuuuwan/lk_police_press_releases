    "text": "\u0ba4\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0b9f\u0ba3\u0b95\u0b9f\u0bb3 \u0bae\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0ba9\u0bca\u0baf\u0bcd\u0bb5\u0bc1 \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0ba9\u0bca\u0baf\u0bcd\u0bb5\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0bc1\u0ba3\u0bcd\u0ba3\u0bb1\u0bbf\u0bb5\u0bc1 \u0baa\u0b95\u0bc1\u0baa\u0bcd\u0baa\u0bca\u0baf\u0bcd\u0bb5\u0bc1 \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1 \u0ba4\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba4\u0bc1. 02. \u0d9c\u0d82\u0da2\u0ddc \u0dc3\u0db8\u0d9f \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dd9\u0da7 - \u0db4\u0dda\u0dbb\u0ddc\u0db4\u0daf\u0dab\u0dd2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0dba. 2026.06.02 \u0daf\u0db1 \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0dba\u0dda\u0dbb\u0dcf\u0dba\u0daf\u0dab\u0dd2\u0dd9 \u0dba\u0db4\u0dcf\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0dba\u0dda \u0dba\u0dd9\u0dcf\u0dbb\u0d9a\u0dcf\u0dba\u0daf\u0db1\u0dd2\u0dd9 \u0db4\u0dca\u200d\u0dbb\u0dba\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0dba\u0dda\u0dbb\u0dcf\u0dba\u0daf\u0dab\u0dd2\u0dd9 \u0dba\u0db4\u0dcf\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dd9 \u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da7\u0dbd\u0dd3 \u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb \u0d9c\u0d82\u0da2\u0ddc \u0d9a\u0dd2\u0db4 \u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 06 \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 100 \u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dba\u0dc0\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0dd2\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0dba\u0dd9\u0db