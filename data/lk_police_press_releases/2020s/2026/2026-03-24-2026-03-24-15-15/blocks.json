    "text": "\u2022 \u0db8\u0dc4\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dc0\u0dbd\u0daf\u0dd3 \u0db4\u0dc4\u0ddd \u0db4 \u0dcf\u0daf\u0dd4 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd\u0daf\u0dd3 \u0db1\u0dcf\u0db3\u0dd4\u0db1\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0db0\u0d9c\u0dbd\u0dba\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0db4\u0daf\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1",
