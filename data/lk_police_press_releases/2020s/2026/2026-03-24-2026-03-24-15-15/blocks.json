    "text": "\u0db4\u0dc3\u0dca\u0dc0\u0dcf\u0dc0\u0dbd\u0daf\u0dd3 \u0d89\u0dad\u0dcf \u0dc3\u0dd4\u0dc4\u0daf\u0dc1\u0dd3\u0dbd\u0dd3 \u0db4\u0dbd\u0dc3 \u0db4\u0dd4\u0daf\u0dca\u0db0\u0d9c\u0dbd\u0dba\u0db1\u0dca\u0da7 \u0dc3\u0db8\u0dd3 \u0dc0\u0dd3\u0db8. \u2022 \u0dc3\u0db8\u0dd3 \u0db8\u0dd2\u0dad\u0dd4\u0dbb\u0db1\u0dca \u0db4\u0db8\u0db1\u0dca \u0dbb\u0d9f \u0dcf\u0db8\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dca\u0dc0\u0dcf\u0dc3\u0dba \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8. \u2022 \u0db8\u0dad\u0dca \u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0dba\u0dcf\u0daf\u0dcf\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba\u0dba\u0db1\u0dca \u0db8\u0dd2\u0dc1\u0dca\u200d\u0dbb \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0db4\u0da7\u0dcf\u0dc6\u0dd2, \u0db4 \u0dcf\u0d9a\u0dbd\u0da7\u0dca, \u0db4\u0dc0\u0db1\u0dad\u0dca \u0d86\u0dc4\u0dcf\u0dbb \u0dc4\u0dcf",
