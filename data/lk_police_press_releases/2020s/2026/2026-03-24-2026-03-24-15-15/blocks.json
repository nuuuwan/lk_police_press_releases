    "text": "\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db4\u0db8\u0dca\u0daf\u0dd3 \u0dc3\u0dd0\u0dc5\u0d9a\u0dd2\u0dbd\u0dd2\u0db8\u0dad\u0dca \u0dc0\u0dd3\u0db8. \u2022 \u0db1\u0dcf\u0db3\u0dd4\u0db1\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0db0\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0db4\u0daf\u0db1 \u0d9a\u0dd2\u0dc3\u0dd2\u0daf\u0dd4 \u0d86\u0dc4\u0dcf\u0dbb\u0dba\u0d9a\u0dca \u0db4\u0dc4\u0ddd \u0dcf\u0db1\u0dba\u0d9a\u0dca \u0d85\u0db1\u0dd4\u0db7\u0dc0\u0dba \u0db4\u0dc4\u0ddd \u0dcf\u0db1\u0dba",
