    "text": "\u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d9a\u0dd2\u0dc3\u0dd2\u0db8 \u0db4\u0dc4\u0dca\u0dad\u0dd4\u0dc0\u0d9a\u0dca \u0db8\u0dad \u0db4\u0db1\u0dcf\u0d9a\u0dbd \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0. \u2022 \u0dba\u0db8\u0dca \u0db4\u0dd4\u0daf\u0dca\u0db0\u0d9c\u0dbd\u0db4\u0dba\u0d9a\u0dd4 \u0db4\u0dc4\u0ddd \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0dad\u0db8\u0db1\u0dca \u0db4\u0dc0\u0dad \u0d85\u0db1\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db4\u0dbd\u0dc3 \u0dc3\u0db8\u0dd3 \u0dc0\u0dd3\u0db8\u0da7 \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4",
