    ],
    "text": "\u0d85 \u0dbb\u0dcf\u0db0\u0dba\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0db1 \u0db6\u0dc0\u0da7 \u0dc4\u0dd0\u0db4\u0d9f\u0db1\u0dca\u0db4\u0db1\u0dca \u0db1\u0db8\u0dca \u0dc0\u0dc4\u0dcf\u0db8 119, 118 \u0db4\u0dc4\u0ddd \u0dc5\u0d9f\u0db8 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0db4\u0dba\u0d9a\u0dd4\u0da7 \u0db4\u0dc4\u0ddd \u0db4\u0dd4\u0dbb\u0dc0\u0dd0\u0dc3\u0dd2\u0db4\u0dba\u0d9a\u0dd4\u0da7 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd3\u0db8. \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4 \u0db1\u0dca\u0dc0\u0dcf \u0db4\u0daf\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0d89\u0dc4\u0dad \u0d8b \u0db4\u0daf\u0dc3\u0dca \u0dc4\u0dcf \u0db8\u0d9f \u0db4 \u0db1\u0dca\u0dc0\u0dd3\u0db8\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dc0 \u0db1\u0dd2\u0dc3\u0dd2 \u0d85\u0dc0\u0db4\u0db6\u0ddd\u0db0\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dd4\u0dc0 \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2\u0db8\u0dad\u0dca\u0dc0 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d89\u0dad\u0dcf \u0d85\u0dad\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dca\u0dad\u0d9a\u0dca \u0db6\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4 \u0db1\u0dca\u0dc0\u0dcf \u0db4\u0daf\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0d85\u0dad\u0dbb \u0db4\u0db8\u0dc0\u0dd0\u0db1\u0dd2 \u0d85 \u0dbb\u0dcf\u0db0 \u0dc0\u0dc5\u0d9a\u0dca\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dc4\u0da2\u0db1\u0dba\u0dcf \u0dc3\u0dad\u0dd4 \u0d85\u0dc0\u0db4\u0db6\u0ddd\u0db0\u0dba \u0dc0\u0da9\u0dcf\u0dad\u0dca \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7\u0dad\u0dca \u0d94\u0db6 \u0dc3\u0db8\u0dd3 \u0dad\u0db8\u0dba\u0db1\u0dca\u0daf \u0db4\u0db8\u0dc0\u0dd0\u0db1\u0dd2 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0d9a\u0da7 \u0dad\u0dca \u0db4\u0db1\u0dcf\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0db8\u0db8 \u0dab\u0dd2\u0dc0\u0dd2\u0da9\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0dad\u0dc0\u0db4\u0d9a\u0d9a\u0dd4 \u0daf\u0dd0\u0db1\u0dd4\u0dc0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db1 \u0db4\u0dbd\u0dc3\u0dad\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0db4\u0d9c\u0db1\u0dca \u0d89\u0dda\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1\u0dd4 \u0dbd\u0dd0\u0db4\u0dda. \u0db4\u0db8\u0dba \u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0db4\u0dda \u0daf\u0dd0\u0db1\u0dd4\u0dc0\u0dad\u0dca \u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d94\u0db6 \u0db8\u0dcf\u0db0\u0dba \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb \u0dcf\u0dbb\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0db4\u0daf\u0db1 \u0db4\u0dbd\u0dc3 \u0d9a\u0dcf\u0dbb\u0dd4\u0dab\u0dd2\u0d9a\u0dc0 \u0d89\u0dda\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db8\u0dd2. \u0daf\u0db4\u0dcf\u0dbd\u0dd2 \u0dca \u0db8\u0dcf\u0db0\u0dba \u0daf\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf . \u0baa\u0ba3\u0bae\u0bcd, \u0ba4\u0b99\u0bcd\u0b95 \u0ba8\u0b95\u0b95\u0b95\u0bb3\u0bcd \u0b89\u0bb3\u0bcd\u0bb3\u0bbf\u0b9f\u0bcd\u0b9f \u0b9a \u0bca\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0b95\u0bb3 \u0ba4\u0bbf\u0bb0\u0bc1\u0b9f\u0bc1\u0ba4\u0bb2\u0bcd, \u0b9a\u0b95\u0bca\u0bb3\u0bcd\u0b95\u0bb3\u0baf\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0baa\u0bb2\u0bb5\u0ba8\u0bcd\u0ba4\u0bae\u0bca\u0b95 \u0baa\u0bb1\u0bbf\u0b95\u0bcd\u0b95 \u0b8e\u0ba4\u0bcd\u0ba4\u0ba9\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bca\u0bb3\u0bbf\u0b95\u0bb3\u0bcd \u0baa\u0baf\u0ba9\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bae\u0bcd \u0baa\u0bb2\u0bcd\u0bb5\u0bb5\u0bb1\u0bc1 \u0b89\u0ba4\u0bcd\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0b9a\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bca\u0ba9 \u0b9a\u0baa\u0bca\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0bb5\u0bbf\u0bb4\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0ba3\u0bca\u0bcd\u0bb5\u0bc1. \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0b95 \u0b9a\u0baa\u0bca\u0bb2\u0bbf \u0bca\u0bca\u0bcd, \u0b9a\u0baa\u0bca\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0baf\u0bae\u0bbf\u0ba9\u0bcd\u0bb1\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0bcd\u0bb5\u0ba4\u0b95\u0bae\u0bbf\u0ba9\u0bcd\u0bb1\u0bbf \u0bb5\u0bca\u0bb4\u0b95\u0bcd\u0b95\u0bc2\u0b9f\u0bbf\u0baf \u0b92\u0bb0\u0bc1 \u0bbf\u0bb1\u0ba8\u0bcd\u0ba4 \u0b9a\u0bc2\u0bb4\u0b95\u0bb2 \u0b89\u0bb0\u0bc1\u0bb5\u0bca\u0b95\u0bcd\u0b95\u0bb5\u0bc1\u0bae\u0bcd, \u0b85\u0bb5\u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0bbf\u0bb0\u0bc1\u0bae\u0bcd\u0baa\u0bc1\u0bae\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0b95\u0baf\u0bbf\u0ba9\u0bcd \u0b85\u0b95\u0ba9\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0bbf\u0bb0\u0bb5\u0ba4 \u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b9a\u0bc1\u0ba4\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0\u0bae\u0bca\u0b95 \u0bcd \u0b9a \u0bb2\u0bcd\u0bb2\u0bc1\u0bae\u0bcd \u0b89\u0bca\u0bbf\u0b95\u0bae\u0b95\u0baf \u0baa\u0bca\u0ba4\u0bc1\u0b95\u0bca\u0b95\u0bcd\u0b95\u0bb5\u0bc1\u0bae\u0bcd, 24 \u0bae\u0ba3\u0bbf \u0bb5\u0ba8\u0bb0\u0bae\u0bc1\u0bae\u0bcd \u0b85\u0bca\u0bcd\u0baa\u0bcd\u0baa\u0ba3\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0b9f\u0ba9\u0bcd \u0bb5 \u0b95\u0bb5\u0baf\u0bca\u0bb1\u0bcd\u0bb1\u0bbf \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd. \u0b87\u0bb5\u0bcd\u0bb5\u0bca\u0bb1\u0bca\u0ba9 \u0b85\u0b95\u0bae\u0ba4\u0bbf\u0baf\u0bca\u0ba9 \u0b9a\u0bc2\u0bb4\u0b95\u0bb2 \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bca\u0b95 \u0ba8\u0bca\u0b9f\u0bb3\u0bca\u0bb5\u0bbf\u0baf \u0bca\u0bc0\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd 607 \u0b9a\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0b95\u0bb2\u0baf\u0b99\u0bcd\u0b95\u0b95\u0bb3 \u0b89\u0bb3\u0bcd\u0bb3\u0b9f\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bb5\u0b95\u0b95\u0baf\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3 \u0b9a\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bca\u0bca\u0bbf\u0b95\u0bb3\u0bcd \u0baa\u0bb2\u0bcd\u0bb5\u0bb5\u0bb1\u0bc1 \u0ba8\u0b9f\u0bb5\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0b95\u0b95\u0bb3\u0bcd \u0bb5\u0bae\u0bb1\u0bcd\u0b9a\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd. \u0b87\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bc1\u0bae\u0bcd, \u0b9a\u0baa\u0bca\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b95\u0bb5\u0ba9\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bb1\u0bb5\u0bc1 \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0b85\u0bb2\u0b9f\u0bcd \u0bbf\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bca\u0bb2\u0bcd \u0b8e \u0bcd \u0bca\u0bbf\u0b95\u0bcd\u0b95\u0b95\u0baf\u0bbf\u0ba9\u0bcd\u0bb1\u0bbf \u0b9a \u0baf\u0bb2\u0bcd\u0baa\u0b9f\u0bc1\u0bb5\u0ba4\u0bca\u0bb2\u0bcd, \u0b85\u0bb5\u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bca\u0bb0\u0ba4\u0bc1\u0bc2\u0bb0\u0bae\u0bca\u0ba9 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1",
