    "text": "\u0d9a\u0dd2\u0dbb\u0dd3\u0db8. \u2022 \u0dad\u0db8\u0db1\u0dca \u0dc3\u0db1\u0dca\u0dad\u0d9a \u0db8\u0dd4\u0daf\u0dda, \u0dbb\u0db1\u0dca \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d86\u0daf\u0dd2\u0dba \u0db4\u0d9a\u0db4\u0dbb\u0dc4\u0dd2 \u0dc0\u0dd0\u0da9\u0dd2 \u0d85\u0dc0\u0db0\u0dcf\u0db1\u0dba\u0d9a\u0dca \u0db4\u0dba\u0dcf\u0db8\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8. \u2022 \u0d94\u0db6\u0da7 \u0db1\u0dd2\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0dc0\u0db1 \u0dba\u0db8\u0dca \u0dc3\u0dd0\u0d9a\u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0db4\u0dd4\u0daf\u0dca\u0db0\u0d9c\u0dbd\u0db4\u0dba\u0d9a\u0dd4, \u0dc0\u0dcf\u0dc4\u0db1\u0dba\u0d9a\u0dca \u0db4\u0dc4\u0ddd \u0dba\u0db8\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0d9a",
