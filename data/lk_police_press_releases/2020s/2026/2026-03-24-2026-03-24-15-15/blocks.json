    "text": "\u0db6\u0dd3\u0db8 \u0dc0\u0dbb\u0dca\u0d9c \u0db4\u0dc4\u0ddd \u0dcf\u0db1\u0dd3\u0dba \u0da2\u0dbd\u0dba \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8. \u2022 \u0dc0\u0dd2\u0dc2 \u0dc3\u0dca\u0db4\u0dda \u0dc0\u0dbb\u0dca\u0d9c, \u0db8\u0dd2\u0dbb\u0dd2\u0dc3\u0dca \u0d9a\u0dd4\u0da9\u0dd4 \u0dc0\u0dd0\u0db1\u0dd2 \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba\u0dba\u0db1\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dbb \u0db4\u0dd4\u0daf\u0dca\u0db0\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0d85\u0da9 \u0db1 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8. \u0d89\u0dc4\u0dad \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0db1\u0dca\u0dc0\u0dbd\u0da7 \u0d94\u0db6 \u0dc0\u0dd2\u0db1\u0dca\u0daf\u0dd2\u0dad\u0db4\u0dba\u0d9a\u0dd4 \u0db4\u0db1\u0dcf\u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0db8\u0db8 \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0db4\u0d9a\u0db4\u0dbb\u0dc4\u0dd2\u0daf \u0dc3\u0dd0\u0dc5\u0d9a\u0dd2\u0dbd\u0dd2\u0db8\u0dad\u0dca \u0dc0\u0db1 \u0db4\u0dbd\u0dc3\u0da7\u0daf \u0daf\u0dd0\u0db1\u0dd4\u0dc0\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db4\u0dda.",
