    ],
    "text": "\u0b89\u0baf\u0bbf\u0bca\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bb5\u0bca\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b89\u0b9f\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bca\u0ba9 \u0baa\u0bbf\u0bae\u0bb0\u0ba4 \u0baa\u0bca\u0bbf\u0bae\u0b9a\u0bca\u0ba4\u0b95\u0ba9 \u0bb1\u0bca\u0b95 \u0b95\u0bb5\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9a\u0bca\u0b95\u0bb2\u0baf\u0bbf\u0bb2\u0bcd \u0ba8\u0b9f\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
