    ],
    "text": "\u0b95\u0ba8\u0bcd\u0ba4\u0bca\u0b95\u0ba9 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0bae \u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0b95\u0ba3\u0b95\u0b95\u0bb3 \u0bae \u0bb1\u0bcd\u0baa\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd.",
    "fonts": [
