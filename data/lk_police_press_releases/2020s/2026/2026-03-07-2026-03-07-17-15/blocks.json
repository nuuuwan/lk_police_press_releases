      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      85.82,
      215.27,
      561.71,
      339.85
    ],
    "text": "\u0b87\u0bc6\u0bcd \u0bc6\u0bbf\u0bbe\u0bbf\u0bc6\u0bbe\u0ba9\u0ba4\u0bc1, \u0bb5\u0bc6\u0ba3\u0bcd\u0bc8\u0bb3\u0bc1\u0bc8\u0bcd\u0b95\u0bc1 \u0b8e\u0bc8\u0bbf\u0bb0\u0bbe\u0ba9 \u0bc6\u0ba9\u0bcd\u0bae\u0bc1\u0b95\u0bb1\u0bc8\u0bb3\u0bcd, \u0b95\u0bc1\u0b9f\u0bc1\u0bae\u0bcd\u0bc6 \u0bc6\u0ba9\u0bcd\u0bae\u0bc1\u0b95\u0bb1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba4\u0bc1\u0bb7\u0bcd\u0bc6\u0bbf\u0bb0\u0ba4\u0baf\u0bbe\u0bc8\u0b99\u0bcd\u0bc8\u0bb3\u0bcd \u0bb5\u0bc8\u0bbe\u0b9f\u0bbe\u0bcd\u0bc6\u0bbe\u0bc8 \u0bc6\u0bbf\u0b9a\u0bbe\u0bb0\u0b95\u0ba3\u0bc8\u0b95\u0bb3 \u0ba4\u0bae\u0bb1\u0bcd\u0bb5\u0bc8\u0bbe\u0bb3\u0bcd\u0bc8\u0bbf\u0bb1\u0ba4\u0bc1. \u0b87\u0bc8\u0ba9\u0bcd \u0b8a\u0b9f\u0bbe\u0bc8 \u0bc6\u0bbe\u0bc8\u0bbf\u0bc8\u0bcd\u0bc8\u0bc6\u0bcd\u0bc6\u0b9f\u0bcd\u0b9f \u0bb5\u0bc6\u0ba3\u0bcd\u0bc8\u0bb3\u0bcd \u0bc6\u0bbe\u0ba4\u0bc1\u0bc8\u0bbe\u0bc6\u0bcd\u0bc6\u0bbe\u0bc8\u0bc6\u0bc1\u0bae\u0bcd \u0ba8\u0bae\u0bcd\u0bc6\u0bbf\u0bc8\u0bcd\u0b95\u0bc8\u0baf\u0bc1\u0b9f\u0ba9\u0bc1\u0bae\u0bcd \u0bc8\u0b99\u0bcd\u0bc8\u0bb3\u0bcd \u0bc8\u0bb0\u0bc1\u0bc8\u0bcd\u0ba4\u0bc1\u0bc8\u0b95\u0bb3 \u0bb5\u0bc6\u0bb3\u0bbf\u0bc6\u0bcd\u0bc6\u0b9f\u0bc1\u0bc8\u0bcd\u0bc8 \u0bc6\u0bbe\u0baf\u0bcd\u0bc6\u0bcd\u0bc6\u0bc1\u0bc8\u0bb3\u0bcd \u0bc6\u0bb4\u0b99\u0bcd\u0bc8\u0bc6\u0bcd\u0bc6\u0b9f\u0bc1\u0bc8\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9. \u2022 \u0bc8\u0bbf\u0bb0\u0bbe\u0bae \u0bae\u0b9f\u0bcd\u0b9f\u0bc8\u0bcd\u0bc8\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0ba3\u0bcd\u0bc8\u0b95\u0bb3 \u0bc6\u0bbf\u0bb4\u0bbf\u0bc6\u0bcd\u0bc6\u0bc1\u0ba3\u0bbe\u0bcd\u0bb5\u0bc2\u0b9f\u0bcd\u0b9f\u0bc1\u0bae\u0bcd \u0bc8\u0bbf\u0b9f\u0bcd\u0b9f\u0b99\u0bcd\u0bc8\u0bb3\u0bc1\u0bae\u0bcd \u0bc6\u0bbe\u0b9f\u0b9a\u0bbe\u0b95\u0bb2 \u0bae\u0bbe\u0ba3\u0bc6\u0bbe\u0bcd\u0bc8\u0bb3\u0bbf\u0ba9\u0bcd \u0bc6\u0bbe\u0ba4\u0bc1\u0bc8\u0bbe\u0bc6\u0bcd\u0bc6\u0bc1 \u0bb5\u0bc8\u0bbe\u0b9f\u0bbe\u0bcd\u0bc6\u0bbe\u0ba9 \u0ba8\u0bbf\u0bc8\u0bb4\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf\u0bc8\u0bb3