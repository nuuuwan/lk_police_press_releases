    ],
    "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0bb5\u0bc6\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0bc6\u0bb2 \u0bc6\u0bbf\u0ba4\u0b9a\u0b9f \u0bc6\u0bbf\u0bbe\u0bbf\u0bc6\u0bc1\u0bc8\u0b95\u0bb3 \u0ba8\u0b9f\u0bc8\u0bcd\u0ba4\u0bc1\u0bc8\u0bbf\u0bb1\u0ba4\u0bc1. \u2022 \u0b9a\u0bbf\u0bb1\u0bc1\u0bc6\u0bbe\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bc8\u0bb3\u0bc0\u0bbe\u0bcd \u0bc6\u0ba3\u0bbf\u0baf\u0bc8\u0bae\u0bcd: \u0bb5\u0bc6\u0bb0\u0bc1\u0bae\u0bcd\u0bc6\u0bbe\u0bb2\u0bbe\u0ba9 \u0bb5\u0bc6\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0b95\u0bb2\u0baf\u0b99\u0bcd\u0bc8\u0bb3\u0bbf\u0bb2\u0bcd \u0b87\u0baf\u0b99\u0bcd\u0b95\u0bc1\u0bae\u0bcd",
    "fonts": [
      "ArialMT",
