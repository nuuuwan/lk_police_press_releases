  {
    "page_number": 1,
    "bbox": [
      107.42,
      78.13,
      521.3,
      119.01
    ],
    "text": "Investigations have been initiated by the Thirappane Police Station following a report received on the night of 9 May 2026 that a person had died after a shotgun discharge in a henna cultivation area in Uttimaduwa, within the Thirappane Police Division.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      133.57,
      413.71,
      146.85
    ],
    "text": "The deceased is a 54-year-old resident of the Uttimaduwa area.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      161.41,
      525.14,
      202.29
    ],
    "text": "The individual suspected of discharging the firearm has been arrested, and a locally manufactured firearm used by the deceased for hunting has also been taken into police custody.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      216.73,
      508.16,
      243.81
    ],
    "text": "The body has been placed at the Anuradhapura Hospital mortuary for post-mortem examination, and further inquiries are ongoing.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
