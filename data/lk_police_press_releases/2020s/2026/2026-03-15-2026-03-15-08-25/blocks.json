    "text": "\u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0ddc\u0db0\u0dca\u200d\u0dba \u0db4 \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0dba. \u0baf\u0bbf\u0bb2\u0bbf\u0bb2\u0bcd \u0bb0\u0bae\u0bca\u0ba4\u0bbf \u0bae \u0bc8\u0bae\u0bcd \u2013 \u0b85\u0bae\u0bcd\u0baa\u0bb2\u0b99\u0bcd\u0baa\u0b95\u0bca\u0b9f \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1 2026.03.14 \u0bae\u0bca\u0ba4\u0bb2, \u0b85\u0bae\u0bcd\u0baa\u0bb2\u0b99\u0bcd\u0baa\u0b95\u0bca\u0b9f \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1\u0b9f\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b95\u0ba8\u0bcd\u0bb0\u0ba4\u0baa\u0b95\u0bca\u0b9f \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1, \u0bae\u0bb0\u0bc1\u0ba4\u0bca\u0ba4\u0ba9 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0baa\u0baa\u0bb2\u0bbf\u0baf\u0ba4\u0bcd\u0ba4 \u0bb5\u0ba4 \u0baa\u0bc6\u0ba9\u0bcd\u0bb1 \u0baf\u0bbf\u0bb2\u0bbf\u0bb2\u0bcd \u0bb0\u0bae\u0bca\u0ba4\u0bbf \u0b92\u0bb0\u0bc1\u0bb5\u0bca\u0bcd \u0b89\u0baf\u0bbf\u0bca\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bca\u0bca\u0bcd. \u0b89\u0baf\u0bbf\u0bca\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bb5\u0bca\u0bcd 62 \u0bb5\u0baf\u0ba4\u0bc1, \u0b95 \u0ba8\u0bcd\u0baa\u0ba4\u0ba9\u0bbf\u0baf \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0bb1\u0bca\u0bca\u0bcd. \u0bb0\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0bc6\u0bca \u0ba4\u0bc8 \u0b85\u0bae\u0bcd\u0baa\u0bb2\u0b99\u0bcd\u0baa\u0b95\u0bca\u0b9f \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0ba8\u0ba4\u0b9f\u0baa\u0baa\u0bb1\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1. \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0b8a\u0b9f\u0b95\u0baa\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1",
