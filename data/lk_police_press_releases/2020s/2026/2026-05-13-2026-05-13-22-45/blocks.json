    "text": "\u0d9a\u0dd6\u0da8 \u0dbd\u0dda\u0d9b\u0db1 \u0dc3\u0d9a\u0dc3\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc4\u0dcf \u0d8a\u0da7 \u0d86\u0db0\u0dcf\u0dbb \u0d85\u0db1\u0dd4\u0db6\u0dbd \u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dbd\u0dd9\u0db1\u0dca \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 06 \u0dbd\u0dd9\u0dbd\u0db1\u0d9a\u0dd4 \u0dc4\u0dcf \u0dc3\u0dd0\u0d9a\u0d9a\u0dcf\u0dbb\u0dd2\u0dd9\u0db1\u0dca 03 \u0dbd\u0dd9\u0dbd\u0db1\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 - \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dc0\u0dd2\u0dbd \u0dca\u0dc2 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0dc0\u0dd2\u0db8\u0dbb\u0dca \u0db1 \u0d85\u0d82 \u0dd9. 2012 \u0dc0\u0dbb\u0dca\u0dc2\u0dba\u0dda \u0dc3\u0dd2\u0da7 2019 \u0dc0\u0dbb\u0dca\u0dc2\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0daf\u0dc5\u0daf\u0dcf \u0dc0\u0dd3\u0daf\u0dd2\u0dba\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db6 \u0dd0\u0d82\u0d9a\u0dd4 \u0dc1\u0dcf\u0d9b\u0dcf\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dbd\u0daf \u0dab\u0dba \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0dab\u0dba \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0db4\u0dad\u0dca\u200d\u0dbb \u0dc3\u0dc4 \u0dab\u0dba \u0d9c\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8\u0dca \u0dc0\u0dba\u0dcf\u0da2 \u0dba\u0dbd\u0dc3 \u0dc3\u0d9a\u0dc3\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dba\u0db1\u0dca 2022.08.28 \u0daf\u0dd2\u0db1 \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dc0\u0dd2\u0dba\u0dc1\u0dca\u0dc2 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d85\u0dd0\u0d82\u0dc1\u0dba\u0da7 \u0dbd\u0daf \u0db4 \u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dba\u0db1\u0dca \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0dba\u0d9a\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2. 2026.05.13 \u0daf\u0dd2\u0db1 \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dc0\u0dd2\u0dba\u0dc1\u0dca\u0dc2 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d85\u0dd0\u0d82\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d91\u0db8 \u0db6 \u0dd0\u0d82\u0d9a\u0dd4\u0dba\u0dda \u0dba\u0dc3\u0dca\u0dc0\u0dba\u0dda \u0db1\u0dd2\u0dba\u0dd4\u0dad\u0dd4 \u0db6 \u0dd0\u0d82\u0d9a\u0dd4 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca 06 \u0d9a\u0dca \u0dc4\u0dcf \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dab\u0dd2\u0dba\u0db1\u0dca 03 \u0dba\u0daf\u0dba\u0db1\u0d9a\u0dd4 \u0d9a\u0dd6\u0da8 \u0dba\u0dbd\u0dca\u0d9b\u0db1 \u0dc3\u0d9a\u0dc3\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc4\u0dcf \u0d8a\u0da7 \u0d86\u0db0\u0dcf\u0dbb \u0d85\u0db1\u0dd4\u0db6\u0dbd \u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dba\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0dd0\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0dba\u0d9c\u0db1 \u0d87\u0dad. \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc4\u0dcf \u0dc3\u0dd0\u0d9a\u0d9a\u0dcf\u0dbb\u0dd2\u0dd9\u0db1\u0dca \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 32 \u0dad\u0dca 58 \u0dad\u0dca \u0d85\u0dad\u0dbb \u0dc0\u0dd9\u0dc3\u0dca\u0dc0\u0dbd \u0db4\u0dc3\u0dd4\u0dc0\u0db1 \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb, \u0dbd\u0dda\u0dbb\u0dcf\u0dbd\u0dd9\u0dab\u0dd2\u0dd9, \u0d9a\u0da7\u0dd4\u0d9c\u0dc3\u0dca\u0dbd\u0dad\u0dcf\u0da7, \u0db4\u0dd4\u0dc3\u0dca\u0dc3\u0dd0\u0dda\u0dbd\u0dcf\u0dc0, \u0dc4\u0dd3\u0dbb\u0dc3\u0dca\u0dc3\u0d9c\u0dbd, \u0d9a\u0dd4\u0dbb\u0dd4\u0dab\u0dd1\u0d9c\u0dbd, \u0db4\u0dd2\u0dc5\u0dd2\u0db8\u0dad\u0dbd\u0dcf\u0dc0, \u0dc4\u0dda\u0d94\u0dc5\u0dd4\u0dc0 \u0dc4\u0dcf \u0d9c\u0dd4\u0dbb\u0dd4\u0dbd\u0dd9\u0db1\u0dd2\u0dd9 \u0db4\u0dca\u200d\u0dbb\u0dbd\u0dda \u0dc0\u0dbd \u0db4\u0daf\u0d82\u0da0\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dbd\u0dda. 2026.05.13 \u0daf\u0dd2\u0db1 \u0dc3 \u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc4\u0dcf \u0dc3 \u0d9a\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0db1\u0dca \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0d9c\u0dbb\u0dd4 \u0db8\u0dba\u0dc4\u0dca\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0da7 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0dba\u0db8\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 05 \u0db6 \u0d9c\u0dd2\u0db1\u0dca \u0dc1\u0dbb\u0dd3\u0dbb \u0d87\u0db4 \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dbb \u0d87\u0dad. \u0dba\u0db8\u0db8 \u0db1\u0da9\u0dd4\u0dc0 2026.09.23 \u0daf\u0dd2\u0db1 \u0db1 \u0dc0\u0dad \u0d9a \u0db3\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0d85\u0dad\u0dbb \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dc0\u0dd2\u0dba\u0dc1\u0dca\u0dc2 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d85\u0dd0\u0d82\u0dc1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0 \u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2.",
