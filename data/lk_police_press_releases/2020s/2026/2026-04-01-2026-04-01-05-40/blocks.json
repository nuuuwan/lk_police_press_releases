    "text": "\u0b85\u0bb5\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0ba4\u0bbf\u0bb0\u0bcb\u0b95 \u0ba4\u0b99\u0bcd\u0b95\u0bcb\u0b9f\u0bb2 \u0b95\u0b95\u0bcc\u0bb0\u0bb5 \u0bc7\u0bc0\u0ba4\u0bbf\u0bb5\u0bcb\u0ba9\u0bcd \u0bc7\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0b9f\u0ba3\u0baf\u0bbf\u0bb2\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 07 \u0bb5\u0bb4\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bcb\u0b95 \u0baa\u0bbf\u0b9f\u0bbf\u0baf\u0bcb\u0b9f\u0ba3\u0b95\u0bb3\u0bcd \u0baa\u0bbf\u0bb1\u0baa\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9. \u0baa\u0bae\u0bb2\u0bc1\u0bae\u0bcd, \u0ba4\u0b99\u0bcd\u0b95\u0bcb\u0b9f\u0bb2 \u0b95\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bbf\u0bb2\u0bcd \u0baa\u0bb2 \u0b95\u0b9a\u0bcb\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0bbf\u0bb0\u0bc1\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb4\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bc1\u0bae\u0bcd \u0b87\u0bb5\u0bcb\u0bcd \u0baa\u0ba4\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc7\u0bcd\u0ba4\u0bb5\u0bcb\u0bcd \u0b8e\u0ba9\u0bcd\u0baa\u0ba4\u0bc1 \u0b95\u0ba4\u0bcb\u0bbf\u0baf\u0bb5\u0bc7\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
