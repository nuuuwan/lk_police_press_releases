    "text": "\u0db8\u0ddc\u0dbd\u0db4\u0dda \u0db4 \u0ddc\u0dbd\u0dd2 \u0dca \u0dc0 \u0db4\u0db8\u0dca \u0db8\u0ddc\u0dbd\u0db4\u0dda \u0db1\u0d9c\u0dbb\u0db4\u0dda \u0d82\u0dc0\u0dd2\u0db0\u0dca\u200d\u0ddc\u0db1\u0dba \u0d9a\u0dbd \u0db6\u0dad\u0dca \u0daf\u0db1\u0dca \u0dbd\u0d9a \u0d86 \u0ddc\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dba\u0db1 \u0db4 \u0ddd\u0dbd\u0dd2\u0db8\u0d9a \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0db4\u0dba\u0d9a\u0dd4 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d91\u0db8 \u0db4 \u0ddd\u0dbd\u0dd2\u0db8\u0da7 \u0db4\u0dd2\u0da7\u0dad\u0dd2\u0db1\u0dca \u0d91\u0d9a\u0dad\u0dd4 \u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0dd4\u0daf\u0dca\u0db0\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0db4\u0daf\u0db4\u0daf\u0db4\u0db1\u0d9a\u0dd4 \u0d8b\u0dad\u0dca \u0ddc \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0db8\u0dca\u0daf\u0dd3 \u0d91\u0dba\u0da7 \u0dc0\u0dd2\u0dbb\u0dd4\u0daf\u0dca\u0db0\u0db0\u0dca\u200d\u0dc0 \u0dc0\u0dd3\u0db8 \u0db4 \u0dca\u0dad\u0dd4\u0db4\u0dc0\u0db1\u0dca \u0db4\u0db8\u0db8 \u0d9c\u0dd0\u0da7\u0dd4\u0db8 \u0d87\u0dad\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0daf\u0dd0\u0db1\u0da7 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0db4\u0dda\u0daf\u0dd3 \u0d85\u0db1\u0ddc\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0d87\u0dad. \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dad\u0dca \u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 2026.07.01 \u0d85\u0daf \u0daf\u0dd2\u0db1 \u0d9a\u0da9\u0dd4\u0db4\u0dc0\u0dbd \u0d9c\u0dbb\u0dd4 \u0db8\u0db4 \u0dca \u0dca\u0dbb\u0ddc\u0dad\u0dca \u0d85\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0db4\u0dc0\u0dad \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0d87\u0dad. \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0da7 \u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dca\u200d \u0d85\u0db4\u0db1\u0d9a\u0dca \u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7