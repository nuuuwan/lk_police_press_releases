    "text": "\u0b9a\u0bae\u0bcd\u0baa\u0bb5\u0ba4\u0bcd\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd \u0ba4\u0ba4\u0bb0\u0b9f\u0bb0\u0bcd\u0baa\u0bc1\u0bb3\u0b9f\u0baf \u0b8f\u0bb3\u0ba9\u0baf \u0b9a\u0ba8\u0bcd\u0ba4\u0ba4\u0b95\u0ba8\u0baa\u0bb0\u0bcd\u0b95\u0bb3\u0bb3\u0b95\u0bcd \u0bb3\u0b95\u0ba4\u0bc1 \u0ba4\u0b9a\u0baf\u0bcd\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bb0\u0b95 \u0bae\u0bb0\u0bb2\u0bae\u0bcd\u0ba4\u0baa \u0ba4\u0baa\u0bb0\u0bb2\u0bbf\u0bb8\u0bb0\u0bb0\u0bcd \u0ba4\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bb0\u0bb0\u0bb3\u0ba3\u0b95\u0bb3\u0bb3 \u0ba4\u0ba4\u0bb0\u0b9f\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba4\u0bae\u0bb1\u0bcd\u0ba4\u0b95\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd.",
