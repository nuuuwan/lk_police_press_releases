    "text": "\u0b9a\u0ba8\u0bcd\u0ba4\u0ba4\u0b95\u0ba8\u0baa\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0ba4\u0bbf\u0bb0\u0bbe\u0b95 \u0bc8\u0bc0\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bb5\u0b95\u0bbe\u0b9f, \u0bb9\u0bbf\u0b95\u0bcd\u0b95\u0b9f\u0bc1\u0bb5, \u0b85\u0bb9\u0bc1\u0b99\u0bcd\u0b95\u0bb2\u0bcd\u0bb2, \u0b95\u0bb0\u0ba8\u0bcd\u0ba4\u0ba4\u0ba9\u0bbf\u0baf, \u0b87\u0bc8\u0ba4\u0bc1\u0bb5 \u0bc8\u0bb1\u0bcd\u0bb1\u0bc1\u0bc8\u0bcd \u0b9c\u0bbe-\u0b8e\u0bb2 \u0bb5\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bbe\u0bbf\u0bb5\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0b87\u0b9f\u0bc8\u0bcd\u0bb5\u0baa\u0bb1\u0bcd\u0bb1 \u0ba4\u0bc1\u0baa\u0bcd\u0baa\u0bbe\u0b95\u0bcd\u0b95\u0bbf\u0b9a\u0bcd \u0b9a\u0bc2\u0b9f\u0bc1 \u0b9a\u0bc8\u0bcd\u0baa\u0bb5\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0bc8\u0bb1\u0bcd\u0bb1\u0bc1\u0bc8\u0bcd",
