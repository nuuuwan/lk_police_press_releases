    "text": "\u0dc0\u0dd2\u0daf\u0dda\u0dc1\u0d9c\u0dad\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d85\u0db4\u0dbb\u0dcf\u0db0\u0d9a\u0dbb\u0dd4\u0daf\u0dc0\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0daf\u0d9c\u0db1 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0daf\u0db8\u0dbb\u0da7\u0da7 \u0dbb\u0dd0\u0daf\u0d9c\u0db1 \u0d92\u0db8 - \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0daf\u0dda\u0db1\u0dca\u0dd4\u0dc0. \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0dc3 \u0dda\u0dc0\u0dcf\u0dc0 \u0dc4\u0dcf \u0d85 \u0dbb\u0dca\u0db6\u0dba\u0dd2\u0da2\u0dcf\u0db1\u0dca \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0dc3 \u0dda\u0dc0\u0dcf\u0dc0 \u0dc0\u0db1 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d86\u0dbb\u0d9a\u0dca\u200d\u0dc2\u0d9a \u0dc3 \u0dda\u0dc0\u0dcf\u0dc0 (State Security Service of Azerbaijan) \u0d91\u0d9a\u0dca\u0dc0 \u0d91\u0dbb\u0da7\u0daf\u0dd2 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0d92\u0d9a\u0dcf\u0db6\u0daf\u0dca\u0db0\u0db0 \u0dc3\u0dd9\u0dc3\u0dc4\u0dba\u0dd4\u0dd9\u0d9a\u0dca \u0dd9\u0d9c\u0dd2\u0db1\u0dca \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dad\u0dd4\u0dbd \u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dcf\u0dad\u0dca\u0dd9\u0d9a \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0dc4 \u0db8\u0dad\u0dca\u0dbb\u0dc0\u0dba \u0da2\u0dcf\u0dc0\u0dcf\u0dbb\u0db8\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbd \u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc3\u0dc0\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dbd\u0daf\u0dd3. \u0d91\u0dd9 \u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0dc3\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0dc3\u0db8\u0dca\u0db1\u0dca\u0dad\u0dd4\u0dc3\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0dd9\