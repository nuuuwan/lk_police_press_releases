    ],
    "text": "\u0ba8\u0b9f\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bc6\u0bae\u0bcd\u0baa\u0bc6\u0bae\u0bcd \u0b87\u0bc6\u0bbe\u0bbf\u0ba9\u0bcd \u0b86\u0ba4\u0bb0\u0bc6\u0bbe\u0bb3\u0bbe\u0bcd\u0bc8\u0bb3\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0b9a\u0bae\u0bb1\u0bcd\u0bb5\u0bc8\u0bbe\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bbe\u0bc8\u0bc6\u0bc1\u0bae\u0bcd \u0bc6\u0bbf\u0bc6\u0bbe\u0bb0\u0b95\u0ba3\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0ba4\u0bbe\u0bbf\u0baf\u0bc6\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
