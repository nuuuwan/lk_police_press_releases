    ],
    "text": "\u0bc6\u0ba8\u0bcd\u0b9a\u0ba4\u0bc8\u0ba8\u0baa\u0bb0\u0bc1\u0bc8\u0bcd\u0b95\u0bc1 72 \u0bae\u0ba3\u0bbf \u0b9a\u0ba8\u0bb0 \u0ba4\u0b9f\u0bc1\u0baa\u0bcd\u0baa\u0bc1\u0bc8\u0bcd \u0bc8\u0bbe\u0bc6\u0bb2\u0bcd \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bc6\u0bc1 \u0bb5\u0baa\u0bb1\u0bcd\u0bb1\u0bc1, \u0b9a\u0bae\u0bb2\u0ba4\u0bbf\u0bc8 \u0bc6\u0bbf\u0bc6\u0bbe\u0bb0\u0b95\u0ba3\u0bc8\u0bb3\u0bcd \u0bb5\u0bc8\u0bbe\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd\u0baa\u0bbf\u0bbe\u0bbf\u0bc6\u0bbe\u0bb2\u0bcd \u0ba8\u0b95\u0b9f\u0bb5\u0baa\u0bb1\u0bcd\u0bb1\u0bc1 \u0bc6\u0bb0\u0bc1\u0bc8\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9.",
    "fonts": [
      "Kavivanar-Regular"
    ],
