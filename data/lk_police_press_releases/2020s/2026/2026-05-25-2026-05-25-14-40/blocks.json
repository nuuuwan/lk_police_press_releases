    "text": "\u0b87\u0baa\u0bcd \u0baa\u0ba3\u0bcd\u0b9f\u0bbf\u0b95\u0bc8\u0b95\u0bc8 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1, \u0bae\u0ba4 \u0bb5\u0bb4\u0bbf\u0baa\u0bca\u0b9f\u0bc1\u0bc8\u0bb3\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0b87\u0bb8\u0bcd\u0bb2\u0bca\u0bae\u0bbf\u0bc8 \u0bae\u0bc8\u0bcd\u0bc8\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0bca\u0ba4\u0bc1\u0bc8\u0bca\u0baa\u0bcd\u0b95\u0baa \u0b89\u0bb1\u0bc1\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0bc8\u0bca\u0bc8 \u0b9a\u0ba4\u0b95\u0bb5\u0bc8\u0bca\u0ba9 \u0ba8\u0b9f\u0bb5\u0b9f\u0bbf\u0bc8\u0bcd\u0b95\u0bc8\u0bc8\u0b95\u0bb3 \u0b9a\u0bae\u0bb1\u0bcd\u0baa\u0bc8\u0bca\u0bb3\u0bcd\u0bb3\u0bc1\u0bae\u0bca\u0bb1\u0bc1 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd\u0bae\u0bca \u0b85\u0ba4\u0bbf\u0baa\u0bca\u0bcd \u0ba8\u0bca\u0b9f\u0bb3\u0bca\u0bb5\u0bbf\u0bc8 \u0bca\u0bc0\u0ba4\u0bbf\u0bc8\u0bbf\u0bb2\u0bcd \u0b85\u0b95\u0ba9\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0b95\u0bb2\u0bc8\u0b99\u0bcd\u0bc8\u0bb3\u0bc1\u0bc8\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b9a\u0ba4\u0b95\u0bb5\u0bc8\u0bca\u0ba9 \u0b85\u0bb1\u0bbf\u0bb5\u0bc1\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd\u0bc8\u0b95\u0bb3 \u0bb5\u0bb4\u0b99\u0bcd\u0bc8\u0bbf\u0bc8\u0bc1\u0bb3\u0bcd\u0bb3\u0bca\u0bca\u0bcd.",
