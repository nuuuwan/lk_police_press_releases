    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      696.21,
      526.41,
      737.09
    ],
    "text": "During the raid, officers arrested a 73-year-old female resident of Katukenda in possession of 1,000 litres of fermented wash (\"Goda\"), believed to have been intended for the illicit manufacture of liquor.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
