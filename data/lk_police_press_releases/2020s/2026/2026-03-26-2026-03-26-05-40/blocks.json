    "text": "\u0d91\u0da9\u0dda\u0dbb\u0db8\u0dd4\u0dbd\u0dca\u0dbd \u0da9 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca\u0dad \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0baa\u0bc6\u0bb0\u0bca\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u2018\u0b90\u0bb8\u0bcd\u2019 \u0baa\u0baa\u0bca\u0b95\u0ba4\u0baa\u0bcd\u0baa\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bc1\u0b9f\u0ba9\u0bcd \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95 \u0ba8\u0baa\u0bca\u0bcd \u0b95\u0b95\u0ba4\u0bc1 \u2013 \u0b8e\u0ba8\u0bcd\u0baa\u0ba4\u0bb0\u0bae\u0bc1\u0bb2\u0bcd\u0bb2 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0b95\u0bb2\u0baf\u0bae\u0bcd 2026.03.25 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bca\u0b95\u0bb2, \u0b8e\u0ba8\u0bcd\u0baa\u0ba4\u0bb0\u0bae\u0bc1\u0bb2\u0bcd\u0bb2 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bc1\u0ba4\u0bcd\u0ba4\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5 \u0b9c\u0baf\u0ba8\u0bcd\u0ba4\u0bbf \u0bae\u0bca\u0bb5\u0ba4\u0bcd\u0b95\u0ba4\u0baf\u0bbf\u0bb2\u0bcd, \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bca\u0bca\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb4\u0bc1 \u0b92\u0ba9\u0bcd\u0bb1\u0bc1 \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bbf\u0b9f\u0bae\u0bca\u0ba9 \u0bae\u0bc1\u0b9a\u0bcd\u0b9a\u0b95\u0bcd\u0b95\u0bb0 \u0bb5\u0bca\u0b95\u0ba9\u0ba4\u0bcd\u0b95\u0ba4 \u0baa\u0b9a\u0bca\u0ba4\u0b95\u0ba9 \u0baa\u0b9a\u0baf\u0bcd\u0ba4\u0ba4\u0bc1. \u0b85\u0ba4\u0bbf\u0bb2\u0bcd \u2018\u0b90\u0bb8\u0bcd\u2019 1 \u0b95\u0bbf\u0baa\u0bb2\u0bca 30 \u0b95\u0bbf\u0bb0\u0bca\u0bae\u0bcd, \u0baa\u0bc6\u0bb0\u0bca\u0baf\u0bbf\u0ba9\u0bcd 1 \u0b95\u0bbf\u0baa\u0bb2\u0bca 30 \u0b95\u0bbf\u0bb0\u0bca\u0bae\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0baa\u0bca\u0b95\u0ba4\u0baa\u0bcd\u0baa\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bcd \u0bb5\u0bbf\u0bb1\u0bcd\u0baa\u0b95\u0ba9\u0baf\u0bca\u0bb2\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bca\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bca\u0b95 \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0bb0\u0bc2.130,000 \u0b89\u0b9f\u0ba9\u0bcd \u0baa\u0baf\u0ba3\u0bae\u0bcd \u0baa\u0b9a\u0baf\u0bcd\u0ba4 \u0ba8\u0baa\u0bca\u0bcd \u0bb5\u0bca\u0b95\u0ba9\u0ba4\u0bcd\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd \u0b95\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bca\u0bca\u0bcd.",
