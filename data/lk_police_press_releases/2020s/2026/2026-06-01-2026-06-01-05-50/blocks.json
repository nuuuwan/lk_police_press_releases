    ],
    "text": "\u0bb9 \u0ba4\u0bc1 \u0b95\u0b9a\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b9a\u0ba8\u0bcd\u0ba8\u0ba4 \u0ba8\u0baa\u0bb0\u0bb0\u0ba9 \u0b9a\u0bb0\u0bb0\u0ba4\u0bbf 42 \u0bb5\u0baf\u0ba4\u0bc1\u0bb9\u0b9f\u0baf \u0baa\u0bbf\u0bb2\u0bbf\u0baf\u0ba8\u0bcd\u0ba4\u0bb9\u0bb2 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0bb9\u0baf\u0b9a\u0bcd \u0ba8\u0b9a\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bb0\u0bcd. \u0bb5\u0bbf\u0baa\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba8\u0ba8\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b85\u0bb5\u0bb0\u0bcd \u0bae\u0ba4\u0bc1\u0ba8\u0baa\u0bb0\u0bb9\u0ba4\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0ba4\u0bc1 \u0b89\u0bb1\u0bc1\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bc8\u0bcd\u0bc8\u0ba4\u0bc1.",
