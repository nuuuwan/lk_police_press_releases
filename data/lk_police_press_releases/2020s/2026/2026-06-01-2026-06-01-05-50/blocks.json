    "text": "\u0b89\u0baf\u0bbf\u0bb0\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4 \u0b86\u0ba3\u0bcd \u0bc8\u0bcd 35 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd 38 \u0bb5\u0baf\u0ba4\u0bc1 \u0bcd\u0b95\u0bc1\u0b9f\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bb5\u0bb0\u0bcd \u0bc8\u0bcd. \u0b85\u0bb5\u0bb0\u0bcd \u0bc8\u0bcd \u0bc8\u0b99\u0bcd\u0b95\u0bb5\u0bb2\u0bcd\u0bb2 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b85\u0bb5\u0bbf\u0b9a\u0bb0\u0bb5\u0bb9\u0bc8 \u0baa\u0b95\u0bc1\u0ba4\u0bbf \u0bb9\u0bc8\u0b9a\u0bcd \u0ba8\u0b9a\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bb0\u0bcd \u0bc8\u0bcd. \u0b89\u0baf\u0bbf\u0bb0\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4 \u0b95\u0baa\u0ba3\u0bcd \u0bc8\u0bcd 15 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd 56 \u0bb5\u0baf\u0ba4\u0bc1 \u0bcd\u0b95\u0bc1\u0b9f\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bb5\u0bb0\u0bcd \u0bc8\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0bbf\u0bb2\u0bbf\u0baf\u0ba8\u0bcd\u0ba4\u0bb9\u0bb2 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0bb9\u0baf\u0b9a\u0bcd \u0ba8\u0b9a\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bb0\u0bcd \u0bc8\u0bcd \u0b86\u0bb5\u0bb0\u0bcd.",
