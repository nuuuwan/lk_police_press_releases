    ],
    "text": "\u0b87\u0ba8\u0bcd\u0ba4 \u0b9a\u0bae\u0bcd\u0baa\u0bb5\u0bae\u0bcd \u0b95\u0ba4\u0bb0\u0b9f\u0bb0\u0bcd\u0baa\u0bb0\u0ba9 \u0ba8\u0bae\u0bb2\u0ba4\u0bbf \u0bb5\u0bbf\u0b9a\u0bb0\u0bb0\u0bb9\u0ba3 \u0bb9\u0bc8 \u0bae\u0bc0\u0b95 \u0bb0\u0b9f \u0b95\u0baa\u0bb0\u0bb2\u0bbf\u0bb8\u0bb0\u0bb0\u0bcd \u0ba8\u0bae\u0bb1\u0bcd\u0b95 \u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1 \u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd.",
