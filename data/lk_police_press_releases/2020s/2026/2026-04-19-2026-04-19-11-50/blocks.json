    "text": "\u0db8\u0dc4\u0da2\u0db1\u0dad\u0ddc\u0dd9 \u0db4 \u0ddc\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dd9\u0ddc\u0dc4\u0db1 \u0db4\u0dc3\u0dca\u0dd9\u0ddc \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0db8\u0dca\u0daf\u0dd3 \u0db1\u0ddc\u0db3\u0dd4\u0db1\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0dc0\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0d9f \u0d87\u0dad\u0dd2 \u0dbb \u0d9c\u0db1\u0dca\u0db1\u0ddc \u0dc4\u0dd2\u0dad\u0dd9\u0dad\u0dca \u0db8\u0dca \u0db8\u0dad \u0d87\u0dad\u0dd0\u0db8\u0dca \u0d85\u0dd9\u0dc3\u0dca\u0dae\u0ddc\u0dd9\u0dbd \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dad\u0dca\u0dd9\u0db1 \u0daf\u0dca\u200d\u0dbb\u0dd9\u0dba \u0dc3\u0dc4\u0dd2\u0dad \u0db4 \u0da7\u0dd2 \u0d86\u0dc4\u0ddc\u0dbb \u0dc4\u0ddc \u0ddc\u0db1 \u0dd9\u0dbb\u0dca\u0d9c \u0dbd\u0db6\u0ddc\u0daf\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0d91\u0dd9\u0dd0\u0db1\u0dd2 \u0db1\u0ddc\u0db3\u0dd4\u0db1\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0dc0\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0ddc\u0db4\u0daf\u0db1 \u0d86\u0dc4\u0ddc\u0dbb \u0db4\u0dc4\u0ddd \u0ddc\u0db1 \u0dd9\u0dbb\u0dca\u0d9c \u0dbd\u0db6\u0ddc \u0d9c\u0dd0\u0db1\u0dd3\u0db4\u0db8\u0dca\u0daf\u0dd3 \u0d89\u0dad\u0ddc \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dd2\u0db8\u0dad\u0dca\u0dd9 \u0dc4\u0ddc \u0db6\u0dd4\u0daf\u0dca\u0dc0\u0dd2\u0db8\u0dad\u0dca\u0dd9 \u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dbb\u0db1 \u0db4\u0dbd\u0dc3\u0da7 \u0db8\u0dd3\u0da7 \u0db4 \u0dbb \u0d9a\u0dd2\u0dc4\u0dd2 \u0d85\u0dd9\u0dc3\u0dca\u0dae\u0ddc\u0dd9 \u0db8 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0daf\u0dd0\u0db1\u0dd4\u0dd9\u0dad\u0dca \u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db4\u0db8\u0dd9\u0dd0\u0db1\u0dd2 \u0dd9\u0dd2\u0d82\u0da0\u0db1\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0dc0\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0dc4\u0dc3\u0dd4 \u0db4\u0db1\u0ddc\u0dd9\u0db1 \u0db4\u0dbd\u0dc3 \u