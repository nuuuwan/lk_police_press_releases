    "text": "\u0baa\u0baa\u0bca\u0ba4\u0bc1 \u0bae\u0baa\u0bca\u0b95\u0bcd\u0b95\u0bc1\u0bb5\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0baa\u0baf\u0bc8\u0bae\u0bcd \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0bc1\u0bae\u0bcd \u0bae\u0baa\u0bca\u0ba4\u0bc1, \u0b85\u0ba8\u0bcd\u0ba8\u0bbf\u0baf\u0bca\u0bcd\u0b95\u0bb3\u0bbf\u0b9f\u0bae\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0b89\u0bc8\u0bb5\u0bc1 \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0baa\u0bca\u0ba9\u0bae\u0bcd \u0baa\u0baa\u0bb1 \u0bae\u0bb5\u0bc8\u0bcd\u0b9f\u0bca\u0bae\u0bcd \u0b8e\u0ba9 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0baa\u0baa\u0bca\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bbf\u0b9f\u0bae\u0bcd \u0bae\u0bc0\u0bc8\u0bcd\u0b9f\u0bc1\u0bae\u0bcd \u0b8e\u0b9a\u0bcd\u0b9a\u0bca\u0bbf\u0b95\u0bcd\u0bb5\u0b95 \u0bb5\u0bbf\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bca\u0bcd.",
