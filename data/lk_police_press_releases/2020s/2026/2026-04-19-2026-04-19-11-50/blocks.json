    "text": "\u0b87\u0b9a\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bb5\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bc1\u0bb5\u0b9f\u0baf 54 \u0bb5\u0baf\u0ba4\u0bc1\u0bb5\u0b9f\u0baf \u0b9a\u0ba8\u0bcd\u0bae\u0ba4\u0b95\u0ba8\u0baa\u0bca\u0bcd 2026.04.17 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bca\u0bb5\u0bb2 \u0baa\u0bc8\u0bcd\u0b9f\u0bc1\u0bb2\u0b95\u0bae \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0bca\u0bca\u0bcd. \u0b85\u0bb5\u0bca\u0bcd \u0b9a\u0bca\u0bb2\u0bbf\u0baf\u0baa\u0bb5\u0bb5 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0bb5\u0baf\u0b9a\u0bcd \u0bae\u0b9a\u0bca\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bca\u0bcd.",
