    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      91.93,
      511.02,
      119.01
    ],
    "text": "The seized quantities included 23 milligrams, 700 milligrams, and 3 grams and 100 milligrams of the narcotic substance.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      133.45,
      559.15,
      160.53
    ],
    "text": "The suspects, aged 30, 31, and 33, are airport security officers residing in the Andiambalama, Wattala, and Minuwangoda areas.",
    "fonts": [
