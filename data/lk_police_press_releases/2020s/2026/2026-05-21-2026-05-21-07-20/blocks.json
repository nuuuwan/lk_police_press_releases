    "text": "\u0b88\u0b9a\u0bbf\u0baa\u0b95\u0bb8\u0bcd \u0bae\u0bc1\u0ba4\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bcd \u0bb5\u0bcb\u0bcd\u0bc8\u0bcd\u0bc8\u0b95\u0bae\u0bcd \u0baa\u0bae\u0bc8\u0bcd\u0baa\u0b95\u0bcb\u0bc8\u0bcd\u0b9f\u0bc8\u0bcb\u0b95 \u0b9a\u0ba8\u0bcd\u0baa\u0bc8\u0b95\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0b87\u0bb0\u0bc1 \u0ba8\u0baa\u0bcb\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bc8\u0bcb\u0b9f\u0bcb\u0bcd\u0baa\u0bbf\u0bb2\u0bcd, \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa\u0bb0\u0bcb\u0bc8 \u0baa\u0b9a\u0bcb\u0bc8\u0bcd\u0ba4\u0bc1 \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bc1 \u0baa\u0bc8\u0baa\u0bae\u0bcb\u0b9a\u0b9f\u0bbf \u0bc8\u0b9f\u0bc1\u0baa\u0bcd\u0baa\u0bc1 \u0b9a\u0b9f\u0bcd\u0b9f\u0bc8\u0bcd\u0bc8\u0bbf\u0ba9\u0bcd \u0b95\u0bc0\u0bb4\u0bcd \u0ba8\u0bc0\u0bc8\u0bcd\u0b9f\u0b95\u0bcb\u0bb2 \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0bc8\u0ba4\u0baf \u0baa\u0bae\u0bc8\u0bcd\u0baa\u0b95\u0bcb\u0bc8\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
