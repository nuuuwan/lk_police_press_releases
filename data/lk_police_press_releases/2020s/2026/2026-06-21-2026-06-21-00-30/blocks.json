    "text": "\u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca\u0db4\u0dda \u0d85\u0dc0\u0dc1\u0dba\u0dad\u0ddc\u0dc0\u0dba\u0db1\u0dca \u0dbb\u0dd2\u0daf\u0dd2 \u0dc0\u0dd2\u0dc1\u0ddc\u0dbd \u0dc0\u0dc1\u0db4\u0dba\u0db1\u0dca \u0db4\u0db8\u0dbb\u0da7 \u0db4\u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0dc3\u0d82\u0da0\u0dd2\u0dad \u0d85\u0db1\u0dd3\u0dad\u0dd2\u0d9a\u0dc0 \u0db4\u0db8\u0dbb\u0da7\u0dd2\u0db1\u0dca \u0db6\u0dd0\u0dc4\u0dd0\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0ddc \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0db1\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0ddc\u0d9c\u0db8\u0dca \u0dbd\u0dd2\u0dba\u0ddc \u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d9a\u0dbb, \u0d91\u0db8 \u0dc3\u0db8\u0ddc\u0d9c\u0db8\u0dca \u0db1\u0db8\u0dd2\u0db1\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca, \u0d91\u0db8 \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db7\u0ddc\u0dab\u0dca\u0da9 \u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dc4\u0d9f\u0dc0\u0ddc \u0dc0\u0dd2\u0db4\u0daf\u0dca\u0dc1 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc3\u0d82\u0da0\u0dd2\u0dad \u0db4\u0db8\u0dbb\u0da7\u0dd2\u0db1\u0dca \u0db6\u0dd0\u0dc4\u0dd0\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7\u0dad\u0dca, \u0d92 \u0dc3\u0db3\u0dc4\u0ddc \u0d9a\u0dd6\u0da8 \u0db4\u0dbd\u0dca\u0d9b\u0dab \u0dc3\u0d9a\u0dc3\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc4\u0ddc \u0dc0\u0d82\u0da0\u0ddc \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0db4\u0dba\u0db1\u0dca \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0db4\u0dc0\u0d9a\u0dd4 2026.06.19 \u0daf\u0dd2\u0db1 \u0db8\u0dd3\u0d9c\u0db8\u0dd4\u0dc0 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0db8\u0dca \u0db4 \u0dbb\u0dd2\u0dba\u0db8\u0dd4\u0dbd\u0dca\u0dbd \u0db4\u0dca\u200d\u0dbb\u0db4\u0d