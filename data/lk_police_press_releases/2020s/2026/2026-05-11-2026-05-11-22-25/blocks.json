    "text": "\u0da7\u0dd3-56 \u0dc0\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0d9c\u0dd2\u0db1\u0dd2 \u0d85\u0dc0\u0dd2\u0dba\u0d9a\u0dca \u0dba \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db7\u0ddc\u0dbb\u0dba\u0da7 \u0d9c\u0dd0\u0db1\u0dd3\u0db8 - \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0d85 \u0dbb\u0ddc\u0db0\u0dca\u200d \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d9a\u0ddc\u0dbb\u0dca\u0dba\u0d82\u0dc1\u0dba. 2026.05.09 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0d85\u0db4\u0dbb\u0dcf\u0db0\u0dca\u200d \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0d82\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dca\u200d\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dba\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba \u0dc3\u0db8\u0d9f \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 38 \u0d9a\u0dca \u0dc0\u0dd6 \u0db8\u0dd3\u0da7\u0dd2\u0dba\u0dcf\u0dba \u0dcf\u0da9 \u0db4\u0dca\u200d\u0dbb\u0dba\u0dda\u0dc1\u0dba\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dba\u0dc0\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0daf\u0dca\u200d\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0dba \u0db1 \u0dbb\u0dd0\u0db3\u0dc0\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0dba\u0dba\u0ddd \u0db8\u0dad \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0dba \u0db1 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd3. \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dba \u0db1\u0dca \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dca\u0daf\u0dca\u200d \u0dba\u0dad\u0dcf\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0db8\u0dad \u0db8\u0dd3\u0da7\u0dd2\u0dba\u0dcf\u0dba \u0da9 \u0dba\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0dba\u0db8\u0dca \u0d9a\u0dd2\u0dbb\u0dbd \u0dc4\u0dba\u0dc0\u0dbd \u0db4\u0dca\u200d\u0dbb\u0dba\u0dda\u0dc1\u0dba\u0dda \u0db4\u0