    "text": "\u0dbb\u0dd0\u0db3\u0dc0\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0dba\u0dba\u0ddd \u0dba\u0da7\u0dba\u0dad\u0dca\u0daf\u0dca\u200d \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 2023.10.09 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dbb\u0dad\u0dca\u0daf\u0dca\u200d \u0db8 \u0dba\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0dba\u0db8\u0dca\u0daf\u0dd3 \u0dba\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0d9a \u0dc0\u0dbb\u0dba\u0dba\u0d9a\u0dd4\u0da7 \u0dba\u0dc0\u0da9\u0dd2 \u0dad\u0db6\u0dcf \u0d9d\u0dcf\u0dad\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0dba\u0db8\u0dca \u0dc3\u0dd2\u0dda\u0dd2\u0dba\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dca\u200d \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0dba\u0dad\u0dd4\u0dbb\u0dd4 \u0db4\u0dd0\u0daf\u0dd2\u0dba \u0db4\u0dd0\u0daf\u0dc0\u0dd6 \u0db4\u0dd0\u0daf\u0dd2\u0d9a\u0dbb\u0dd4 \u0db6\u0dc0\u0da7 \u0daf\u0dd0\u0db1\u0da7 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0d87\u0dad. \u0d91\u0db8 \u0d85\u0db4\u0dbb\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dba\u0db8\u0db8 \u0d9c\u0dd2\u0db1\u0dd2 \u0d85\u0dc0\u0dd2\u0dba \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dbb \u0dad\u0dd2\u0dba\u0dda\u0daf \u0dba\u0db1\u0dca\u0db1 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dca\u200d\u0dc0 \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0d85\u0db4\u0dbb\u0dcf\u0db0\u0dca\u200d \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0d82\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dca\u200d\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0dba \u0db1 \u0dba\u0db1\u0dd4 \