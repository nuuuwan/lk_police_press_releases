    "text": "\u0baa\u0bae\u0bc8\u0bcd\u0baa\u0b95\u0bcb\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0bc8\u0b95\u0bb3\u0bbf\u0bb2\u0bcd, \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0bc8\u0bcd\u0bc8\u0bb2\u0bbf\u0ba9\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bcb\u0bc8\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0bc8\u0bc8\u0bcd\u0bc8\u0bbf\u0bb2\u0bcd, \u0b9a\u0ba8\u0bcd\u0baa\u0bc8\u0b95\u0ba8\u0baa\u0bcb\u0bbf\u0ba9\u0bcd \u0baa\u0baa\u0bc8\u0bcb\u0bbf\u0bb2\u0bc1\u0bae\u0bcd \u0b85\u0bb5\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0ba8\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bae\u0bcb\u0ba9 \u0b92\u0bb0\u0bc1\u0bb5\u0bcb\u0bbf\u0ba9\u0bcd \u0baa\u0baa\u0bc8\u0bcb\u0bbf\u0bb2\u0bc1\u0bae\u0bcd \u0b9a\u0bc1\u0bae\u0bcb\u0bcb\u0bcd 20 \u0b87\u0bb2\u0b9f\u0bcd\u0b9a\u0bae\u0bcd \u0bb0\u0bc2\u0baa\u0bcb\u0bc8\u0bcd \u0baa\u0baa\u0bb1\u0bc1\u0bae\u0bc8\u0bbf\u0bc8\u0bcb\u0ba9 \u0b87\u0bb0\u0bc8\u0bcd\u0b9f\u0bc1 \u0bae\u0bc1\u0b9a\u0bcd\u0b9a\u0b95\u0bcd\u0b95\u0bb0 \u0bb5\u0bc8\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bcd, \u0baa\u0bae\u0bb2\u0bc1\u0bae\u0bcd \u0b9a\u0ba8\u0bcd\u0baa\u0bc8\u0b95\u0ba8\u0baa\u0bcb\u0bbf\u0ba9\u0bcd \u0bae\u0b95\u0ba9\u0bbf\u0ba9\u0bcd \u0baa\u0baa\u0bc8\u0bcb\u0bbf\u0bb2\u0bcd \u0b9a\u0bc1\u0bae\u0bcb\u0bcb\u0bcd 30 \u0b87\u0bb2\u0b9f\u0bcd\u0b9a\u0bae\u0bcd \u0bb0\u0bc2\u0baa\u0bcb\u0bc8\u0bcd \u0baa\u0baa\u0bb1\u0bc1\u0bae\u0bc8\u0bbf\u0bc8\u0bcb\u0ba9 \u0b92\u0bb0\u0bc1 \u0baa\u0baa\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bb5\u0bcb\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0bc8\u0ba4\u0bc1 \u0baa\u0bc8\u0bcb\u0bbf\u0bc8\u0bb5\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
