    ],
    "text": "\u0baa\u0baa\u0bca\u0bb2\u0bbf \u0b86\u0bb5\u0ba3\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0baf\u0bca\u0bca\u0bbf\u0ba4\u0bcd\u0ba4\u0bae\u0bc8 \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0b95\u0bca\u0ba3\u0bbf \u0baa\u0ba4\u0bbf\u0bb5\u0bca\u0bb3\u0bca\u0bcd \u0b92\u0bb0\u0bc1\u0bb5\u0bca\u0bcd \u0bae\u0b95\u0ba4\u0bc1 \u2013 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbf\u0baf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0bae\u0ba3\u0ba4\u0bcd \u0ba4\u0bbf\u0bae\u0ba3\u0b95\u0bcd\u0b95\u0bb3\u0bc8\u0bcd",
