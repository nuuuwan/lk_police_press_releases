    ],
    "text": "03. \u0dc4\u0dc2\u0dd3\u0dc2\u0dca \u0db8\u0dad\u0dca\u0dbb\u0dd9\u0dba \u0dc3\u0db8\u0d9f \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dd9\u0da7 - \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0dbb\u0dd9\u0dba \u0ddc\u0dbb\u0dca\u0dba\u0d82\u0dc1\u0dba 2026.07.07 \u0daf\u0dd2\u0db1 \u0dbb\u0ddc\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d9a\u0dd4\u0dbd\u0dd2\u0dba\u0ddc\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dd9\u0dc3\u0db4\u0db8\u0dca \u0db4 \u0ddc\u0db4\u0dbb\u0ddc\u0dad\u0dca\u0dad\u0dd4\u0db4 \u0ddc\u0dd9 \u0db4\u0dd9\u0dda\u0dba\u0ddc\u0dba \u0d86\u0dc3\u0db1\u0dca\u0db1\u0db4\u0dda\u0daf\u0dd3 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0dbb\u0dd9\u0dba \u0ddc\u0dbb\u0dca\u0dba\u0d82\u0dc1\u0db4\u0dda \u0dd2\u0dd9\u0db0\u0dca\u200d\u0ddc\u0dbb\u0dd2\u0db1\u0dca \u0dab\u0dca\u0da9\u0ddc\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dd9\u0daf \u0db4\u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0db8\u0dad \u0dd9\u0dd0\u0da7\u0dbd\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb \u0dc4\u0dc2\u0dd3\u0dc2\u0dca \u0db8\u0dad\u0dca\u0dbb\u0dd9\u0dba \u0d9a\u0dd2\u0db4\u0dd9\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 01 \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 10 \u0d9a\u0dca \u0dc3\u0db1\u0dca\u0dad \u0db4\u0dda \u0dad\u0db6\u0ddc\u0db4\u0d9c\u0db1 \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dd9\u0da7 \u0db4\u0d9c\u0db1 \u0d87\u0dad.",
