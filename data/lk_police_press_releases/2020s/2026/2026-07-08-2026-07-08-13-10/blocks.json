    "text": "\u0db4 \u0ddc\u0dc5\u0db9 \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda \u0d89\u0da9\u0db8\u0dca \u0db4\u0dbb\u0da2\u0dd2\u0dc3\u0dca\u0dbb\u0ddc\u0dbb\u0dca \u0ddc\u0dbb\u0dca\u0dba\u0ddc\u0dd9\u0dba \u0d89\u0da9\u0db8\u0dca \u0db4\u0dbb\u0da2\u0dd2\u0dc3\u0dca\u0dbb\u0ddc\u0dbb\u0dca\u0dd9\u0dbb\u0dd2\u0dba \u0dd9\u0dc1\u0db4\u0dba\u0db1\u0dca \u0dc3\u0dd2\u0da7 \u0d91\u0db8 \u0ddc\u0dbb\u0dca\u0dba\u0ddc\u0dd9\u0db4\u0dda \u0dad\u0dca\u0dd2\u0dbb\u0dd4, \u0db4\u0dd9\u0dc5\u0dd4\u0db8\u0dca \u0d94\u0db4\u0dca\u0db4\u0dd4\u0dd9\u0dd9 \u0db4\u0daf\u0dd9\u0db1 \u0db4\u0dd2\u0da7 \u0dad\u0dca \u0dd9\u0dd9 \u0db4\u0dd9\u0dc5\u0dd4\u0db8\u0dca\u0dd9\u0dd9\u0da7 \u0db6\u0dd0\u0db3 \u0d87\u0dd2 \u0db4\u0dda\u0d9b\u0db1 \u0db6\u0ddc\u0dc4\u0dd2\u0dbb \u0ddc\u0dbb\u0dca\u0dc1\u0dd9\u0dba\u0db1\u0dca\u0da7 \u0dd9\u0db6\u0ddc\u0daf\u0dd3 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dca\u200d\u0ddc\u0db1\u0ddc\u0dad\u0dca\u0db8 \u0d85 \u0dbb\u0ddc\u0db0\u0dca\u200d \u0dc3\u0db3\u0dc4\u0ddc \u0d86\u0db0\u0dca\u200d\u0ddc\u0dbb \u0d85\u0db1\u0dd4\u0db6\u0dd9\u0daf\u0dd3\u0db8, \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dbb\u0dab\u0dba \u0dc4\u0ddc \u0db1\u0dd3\u0dad\u0dba\u0ddc\u0db1\u0dd4\u0d9a\u0dd6\u0dd9 \u0d85\u0dba\u0dd2\u0dd2 \u0dbb\u0dd4\u0dd9\u0db1\u0dca\u0db4\u0d9c\u0db1\u0dca \u0dd9\u0dba\u0ddc\u0da2 \u0db4\u0dda\u0d9b\u0db1 \u0dc3 \u0dc3\u0dca \u0db4 \u0ddc\u0da7 \u0d91\u0db8 \u0d89\u0da9\u0db8 \u0db6\u0dd0\u0dc4\u0dd0\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dca\u200d\u0db4\u0dba\u0db1\u0dca \u0d85 \u0dbb\u0ddc\u0db0\u0dca\u200d \u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0daf \u0ddc\u0dbb\u0dca\u0dad\u0db4\u0db8\u0dca\u0db1\u0dca\u0dad\u0dd4\u0db4\u0dda \u0db8\u0dd6\u0dd9\u0dba \u0d85 \u0dbb\u0ddc\u0db0\u0dca\u200d \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d92 \u0dba \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb\u0db1 \u0dd9\u0daf \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0dba \u0da7 \u0d85\u0daf\u0ddc