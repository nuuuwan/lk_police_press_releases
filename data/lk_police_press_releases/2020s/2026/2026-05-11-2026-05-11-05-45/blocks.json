    ],
    "text": "Murder \u2013 Embilipitiya Police Division",
    "fonts": [
      "TimesNewRomanPS-BoldMT"
    ],
    "sizes": [
      14.039999961853027
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      107.42,
      539.34,
      503.07,
      594.05
    ],
    "text": "Investigations have been initiated by the Embilipitiya Police Station following a report received in the early hours of 10 May 2026 that a person had been fatally assaulted with a blunt object in the Kodikanda area within the Embilipitiya Police Division.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      107.42,
      608.61,
      514.8,
      635.69
    ],
    "text": "The deceased, a 52-year-old resident of Kodikanda, Embilipitiya, was found to have sustained fatal injuries consistent with an attack involving an iron rod.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      107.42,
      650.25,
      509.22,
      691.13
    ],
    "text": "Preliminary investigations have revealed that the incident occurred following a dispute between the victim and two other individuals, during which the assault was carried out.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      107.42,
      705.57,
      487.11,
      732.65
    ],
    "text": "The Embilipitiya Police are conducting further investigations to apprehend the suspects.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
