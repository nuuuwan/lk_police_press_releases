    ],
    "text": "\u0d92 \u0d85\u0db1\u0dd4\u0dd9 \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0db1\u0dd2\u0dbd\u0db0\u0dca\u200d\u0ddc\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0dbd\u0daf \u0db4\u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb \u0da7 \u0d85\u0db1\u0dd4\u0dd9 \u0d89\u0dd9\u0dad \u0d85 \u0dbb\u0ddc\u0db0\u0dca\u200d\u0dba\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dca\u200d \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd4 2026.03.03 \u0daf\u0dd2\u0db1 \u0daf\u0dd9\u0dd9\u0dbd\u0dca\u0dbd \u0db8\u0dc4\u0dd2\u0dba\u0d82\u0d9c\u0db1\u0dba, \u0d85\u0dbb\u0ddc\u0dd9\u0dad\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0db4\u0daf\u0dca\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dd9\u0da7 \u0db4\u0d9c\u0db1 \u0d87\u0dad. \u0dc3\u0dd0 \u0dbb\u0dd4 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 16 \u0d9a\u0dca \u0dd9\u0db1 \u0d85\u0dbb\u0ddc\u0dd9\u0dad\u0dca\u0dad, \u0db8\u0dc4\u0dd2\u0dba\u0d82\u0d9c\u0db1\u0dba \u0db4\u0dca\u200d\u0dbb\u0db4\u0daf\u0dca\u0dc1\u0db4\u0dda \u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd2. \u0db4\u0db8\u0db8 \u0d85 \u0dbb\u0ddc\u0db0\u0dca\u200d\u0dba\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dca\u200d \u0dc3\u0dd0 \u0dbb\u0dd4\u0dd9\u0db1\u0dca 08 \u0db4\u0daf\u0db4\u0db1\u0d9a\u0dd4 \u0db8\u0dd2\u0da7 \u0db4 \u0dbb \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dd9\u0da7 \u0db4\u0d9c\u0db1 \u0d9c\u0dbb\u0dd4 \u0d85\u0db0\u0dd2 \u0dbb\u0dab\u0dba \u0db4\u0dd9\u0dad \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0dad\u0dca \u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db8\u0dc4\u0dd2\u0dba\u0d82\u0d9c\u0db1\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dd9\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2.",
    "fonts": [
