    "text": "\u0db8\u0dd3\u0d9c\u0db8\u0dd4\u0dd9 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dd9\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2.",
