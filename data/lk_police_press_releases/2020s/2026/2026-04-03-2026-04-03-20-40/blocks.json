    "text": "\u0d9a\u0dc5\u0dd4\u0dad\u0dbb \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0ddc\u0dbd\u0db4\u0dda \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4\u0dc0 \u0dbd\u0dd0\u0db6\u0dd6 \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0d9a\u0ddc\u0dc3\u0dca\u0dad\u0ddc \u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca 225 \u0db4\u0daf\u0dca\u200d\u0db4\u0dd9\u0d9a\u0dd4 \u0dc4\u0ddc \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0d9a\u0ddc\u0dc3\u0dca\u0dad\u0ddc \u0dbd\u0dca \u0dbb\u0dd2\u0dba\u0dd0\u0daf\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca 55 \u0db4\u0daf\u0dca\u200d\u0db4\u0dd9\u0d9a\u0dd4 \u0dc0\u0dd2\u0dc3\u0dd2\u0dbb \u0dba\u0ddc\u0db4\u0dda \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba\u0d9a\u0dca 2026.04.03 \u0daf\u0dd2\u0dd9 \u0db8\u0dc4\u0da2\u0dd9 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dc4\u0ddc \u0ddc\u0dbb\u0dca\u0dbd\u0dbd\u0dd2\u0db4\u0dda\u0db1\u0dca\u0dd4 \u0d9a\u0da7\u0dba\u0dd4\u0dd4 \u0d85\u0db8\u0ddc\u0dad\u0dba \u0d86\u0dd9\u0db1\u0dca\u0daf\u0dca\u200d \u0dc0\u0dd2\u0db4\u0dda \u0ddc\u0dbd \u0db8\u0dd0\u0dad\u0dd2\u0dd4\u0db8\u0ddc\u0db4\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0ddc\u0dd9\u0dad\u0dca\u0dc0\u0db4\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0d91\u0db8 \u0d85\u0db8\u0ddc\u0dad\u0dba\u0d82\u0dc1\u0db4\u0dda \u0db4\u0dbd\u0dca\u0d9a\u0dda \u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0ddc\u0db8\u0dd2\u0d9a \u0db4\u0da2\u0dba\u0dc2\u0dca\u0da8 \u0db1\u0dd2\u0db4\u0dba\u0ddc\u0da2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dad\u0dd2 \u0dbb\u0dc0\u0dd3 \u0db4\u0dc3\u0db4\u0dd9\u0dc0\u0dd2\u0dbb\u0dad\u0dca\u0dd9 \u0db8\u0dc4\u0dad\u0ddc\u0db4\u0dda \u0dc4\u0ddc \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dad\u0dd2 \u0db1\u0dd3\u0dad\u0dd3\u0da5 \u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0db1\u0dca\u0dad \u0dc0\u0dd3\u0dbb\u0dc3\u0dd6\u0dbb\u0dd2\u0dba \u0db8\u0dc4\u0dad\u0ddc\u0db4\u0dda \u0dc3\u0dc4\u0db7\u0ddc\u0d9c\u0dd2\u0dad\u0dca\u0dc0\u0db4\u0dba\u0db1\u0dca \u0d9a\u0dc5\u0dd4\u0dad\u0dbb \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0ddc\u0dbd\u0db4\u0dda \u0d85\u0dbd\u0dd4\u0dc0\u0dd2\u0dc4\u0ddc\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0ddc \u0db4\u0dd2\u0da7\u0dd2\u0db4\u0dda\u0daf\u0dd3 \u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2. \u0db4\u0db8\u0dc4\u0dd2\u0daf\u0dd3 \u0daf\u0dca\u200d\u0d9a\u0dca\u0dc2\u0dad\u0db8 \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0d9a\u0ddc\u0dc3\u0dca\u0dad\u0ddc \u0dbd\u0dca \u0db4\u0dbd\u0dc3 107968 \u0d92.\u0d91\u0dda.\u0d95.\u0dc0\u0dd3. \u0db4\u0dc3\u0dd9\u0dc0\u0dd2\u0dbb\u0dad\u0dca\u0dd9 \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd2\u0dba\u0ddc, \u0db4\u0dc4\u0ddc\u0db3\u0db8 \u0d89\u0dbd\u0d9a\u0dca\u0d9a\u0dba\u0da7 \u0db4\u0dc0\u0da9\u0dd2 \u0dad\u0db6\u0db1\u0dca\u0dd9\u0ddc \u0db4\u0dbd\u0dc3 \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0d9a\u0ddc\u0dc3\u0dca\u0dad\u0ddc \u0dbd\u0dca 108087 \u0da9\u0db6\u0dca.\u0d85\u0dba\u0dd2.\u0d91\u0dc3\u0dca. \u0db6\u0dab\u0dca\u0da9\u0ddc\u0dbb \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd2\u0dba\u0ddc \u0dc4\u0ddc \u0db1\u0dd3\u0dad\u0dd2\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0daf\u0dca\u200d\u0d9a\u0dca\u0dc2\u0dad\u0db8 \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0d9a\u0ddc\u0dc3\u0dca\u0dad\u0ddc \u0dbd\u0dca \u0db4\u0dbd\u0dc3 107985 \u0d86\u0dbb\u0dca\u0dbd.\u0d91\u0dda.\u0da9\u0dd3.\u0d91\u0dc3\u0dca \u0db4\u0dc3\u0dca\u0dd9\u0ddc\u0dbb\u0dad\u0dca\u0dd9 \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd2\u0dba\u0ddc \u0db4\u0dad\u0dca\u0dbb\u0dd3 \u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0daf\u0dca\u200d\u0d9a\u0dca\u0dc2\u0dad\u0db8 \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0d9a\u0ddc\u0dc3\u0dca\u0dad\u0ddc \u0dbd\u0dca \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0dd4 \u0db4\u0dbd\u0dc3 108106 \u0d91\u0da0\u0dca.\u0d91\u0dda.\u0da2\u0dd3.\u0d91\u0dda. \u0db4\u0dc4\u0dca\u0dbb\u0dad\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd2\u0dba\u0ddc, \u0db4\u0dc4\u0ddc\u0db3\u0db8 \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0d9a\u0ddc\u0dc3\u0dca\u0dad\u0ddc \u0dbd\u0dca \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0dd4 \u0db4\u0dbd\u0dc3 108104 \u0d86\u0dbb\u0dca\u0dbd.\u0d91\u0dda.\u0d91\u0dc3\u0dca.\u0da7\u0dd3.\u0da9\u0dd3. \u0dbd\u0d82\u0d9a\u0ddc \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd2\u0dba\u0ddc \u0db4\u0dad\u0dca\u0dbb\u0dd3 \u0dad\u0dca\u0dc0 \u0d87\u0dad. \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0d9a\u0ddc\u0dbd\u0dc3\u0dd3\u0db8\u0ddc\u0dc0 \u0dd4\u0dc5 \u0dc0\u0dd2\u0dc1\u0dd2\u0dc2\u0dca\u0da8 \u0daf\u0dca\u200d\u0dc3\u0dca\u0d9a\u0dda \u0daf\u0dca\u200d\u0dd0\u0d9a\u0dca \u0dc0\u0dd6 \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0db4\u0dc0\u0dad \u0dad\u0dba\u0ddc\u0d9c \u0dc3\u0dc4 \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0dad\u0dca \u0d9c\u0dbb\u0dd4 \u0d85\u0db8\u0ddc\u0dad\u0dba\u0dd4\u0db8\u0ddc\u0db4\u0dda \u0dc3\u0dc4 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dad\u0dd2\u0dd4\u0db8\u0ddc\u0db4\u0dda \u0dc3\u0dd4\u0dbb\u0dad\u0dd2\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dca\u200d\u0ddc\u0dd9\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca, \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0dc3\u0dca\u0dc0\u0db4\u0dda \u0dba\u0dc4 \u0dad\u0dca \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba\u0db7\u0ddc\u0dc0\u0db4\u0dba\u0db1\u0dca \u0db1\u0dd2\u0dbb\u0dad\u0dc0\u0dd3\u0db4\u0db8\u0db1\u0dca \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba\u0da7 \u0d91\u0d9a\u0dca\u0d9a\u0dbb \u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0da7\u0dd2\u0dd9\u0ddc\u0d9a\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0db4\u0db8\u0db1\u0dca\u0db8 \u0d85\u0db7\u0dd2\u0db8\u0ddc\u0dd9\u0dc0\u0dad\u0dca \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0dc3\u0dca\u0dc0\u0db4\u0dda \u0dc0\u0dd2\u0dd9\u0dba\u0ddc\u0dab\u0dd4\u0d9a\u0dd6\u0dbd \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0db4\u0dbd\u0dc3 \u0db8\u0dc4\u0da2\u0dd9\u0ddc\u0dc0\u0da7 \u0d85\u0dc0\u0d82\u0d9a\u0dc0 \u0db4\u0dc3\u0dca\u0dc0\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0dd0 \u0dc0\u0dd9 \u0db4\u0dbd\u0dc3\u0da7 \u0daf\u0dca\u200d\u0db1\u0dca\u0dc0\u0db8\u0dd2\u0db1\u0dca \u0dd9\u0dc0\u0d9a \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0dc3\u0dd4\u0db7\u0ddc\u0dc1\u0dd2\u0d82\u0dc2\u0dab \u0d91\u0d9a\u0dca\u0d9a\u0dbb\u0dd9 \u0dbd\u0daf\u0dd3. \u0dc0\u0dd2\u0dc3\u0dd2\u0dbb \u0dba\u0ddc\u0db4\u0dda \u0d8b\u0db4\u0dc5\u0dbd\u0d9a \u0dc3\u0db8\u0ddc\u0db4\u0dca\u0dad\u0dad\u0dd2\u0dba \u0d9c\u0dbb\u0dd4 \u0d9c\u0ddc\u0dda\u0dd3\u0dbb\u0dad\u0dca\u0dc0\u0db4\u0dba\u0db1\u0dca, \u0dbb\u0dc3\u0ddc\u0dc3\u0dca\u0dc0\u0ddc\u0daf\u0dca\u200d\u0db4\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0daf\u0dca\u200d\u0dbb\u0dca\u0dbd\u0dc1\u0db1\u0dd3\u0dba\u0db7\u0ddc\u0dc0\u0db4\u0dba\u0db1\u0dca \u0db1\u0dd2\u0db8\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d91\u0d9a\u0dca\u0dc0\u0dd9 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dd2\u0db4\u0dc1\u0dca\u0dc2 \u0d9a\u0ddc\u0dbb\u0dca\u0dbd\u0dba \u0db6\u0dbd\u0d9a\u0ddc\u0dba, \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db6\u0da7\u0dc4\u0dd2\u0dbb \u0dad\u0dd6\u0dbb\u0dca\u0dbd\u0dba \u0dc0\u0ddc\u0daf\u0dca\u200d\u0dd9 \u0d9a\u0dab\u0dca\u0da9\u0ddc\u0dba\u0db8, \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd \u0dc3\u0dd4\u0dd9\u0d9b \u0db4\u0d9a\u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0dba \u0dc3\u0dc4 \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0ddc\u0dc0\u0db1\u0dca\u0db4\u0d9c\u0db1\u0dca \u0dc3\u0db4\u0dd2\u0dbb\u0dd2 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0ddc\u0dbd \u0d9a\u0dab\u0dca\u0da9\u0ddc\u0dba\u0dda \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dc4\u0ddc \u0dd1 \u0dc3\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dca\u0dbd\u0dc1\u0dd9, \u0dc0\u0ddc\u0daf\u0dca\u200d\u0dd9 \u0dc3\u0dc4 \u0dd9\u0dbb\u0dca\u0dbd\u0dad\u0dd9\u0ddc\u0d82\u0d9c\u0dba\u0db1\u0dca\u0db4\u0d9c\u0db1\u0dca \u0dd0\u0db8\u0dd2\u0dab \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0dd2\u0dba\u0dbd\u0dca\u0dbd\u0db1\u0dca \u0db4\u0dd2\u0dd9\u0dc0\u0dd9 \u0dbd\u0daf\u0dd3. \u0db4\u0da2\u0dba\u0dc2\u0dca\u0da8 \u0db1\u0dd2\u0db4\u0dba\u0ddd\u0da2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dad\u0dd2 \u0dbb\u0dd2 \u0ddc\u0dbd\u0dd9 \u0dc3\u0d82\u0da2\u0dd3\u0dc0 \u0db0\u0dbb\u0dca\u0dbd\u0db8\u0dbb\u0dad\u0dca\u0dd9 \u0db8\u0dc4\u0dad\u0ddc, \u0db6\u0dc3\u0dca\u0dd9\u0ddc\u0dc4\u0dd2\u0dbb \u0dc5\u0ddc\u0dad \u0db7\u0ddc\u0dbb \u0db4\u0da2\u0dba\u0dc2\u0dca\u0da8 \u0db1\u0dd2\u0db4\u0dba\u0ddd\u0da2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dad\u0dd2 \u0dc3\u0da2\u0dd3\u0dc0 \u0db8\u0dd0\u0daf\u0dca\u200d\u0dc0\u0dad\u0dca\u0dad \u0db8\u0dc4\u0dad\u0ddc, \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0dc4\u0ddc \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4",
