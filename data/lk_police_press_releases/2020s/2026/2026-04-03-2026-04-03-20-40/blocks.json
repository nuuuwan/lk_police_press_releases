      201.8,
      197.2,
      219.58
    ],
    "text": "\u0bb5\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0b8a\u0bc8\u0b95\u0baa\u0bcd \u0baa\u0bbf\u0bbe\u0bbf\u0bc6\u0bc1.",
