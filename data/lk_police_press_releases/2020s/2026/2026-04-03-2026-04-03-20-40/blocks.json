    "text": "\u0daf\u0dd2\u0dc3\u0ddc\u0dc0 \u0db7\u0ddc\u0dbb \u0db4\u0da2\u0dba\u0dc2\u0dca\u0da8 \u0db1\u0dd2\u0db4\u0dba\u0ddd\u0da2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dad\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0da5 \u0dc3\u0dda \u0dad\u0dca \u0d9a\u0dd4\u0db8\u0ddc\u0dbb \u0dbd\u0dd2\u0dba\u0dd9\u0db4\u0dda \u0db8\u0dc4\u0dad\u0ddc, \u0db6\u0db3\u0dc0\u0ddc\u0d9c\u0dd0\u0db1\u0dd3\u0dda \u0dc4\u0ddc \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0daf\u0dd2\u0dc3\u0ddc\u0dc0 \u0db7\u0ddc\u0dbb \u0db1\u0dd2\u0db4\u0dba\u0ddd\u0da2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dad\u0dd2 \u0da2\u0d9c\u0dad\u0dca \u0db4\u0dc3\u0dca\u0dbb\u0dda \u0db8\u0dc4\u0dad\u0ddc, \u0db4\u0da2\u0dba\u0dc2\u0dca\u0da8 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0db4\u0db8\u0db1\u0dca\u0db8 \u0db4\u0da2\u0dba\u0dc2\u0dca\u0da8 \u0dbb\u0ddc\u0da2\u0dba \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0dc4\u0ddc \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca\u0db4\u0dda \u0db4\u0daf\u0dca\u200d\u0db8\u0dc0\u0dca\u0db4\u0db4\u0dd2\u0dba\u0db1\u0dca \u0d87\u0dd4\u0dc5\u0dd4 \u0dc0\u0dd2\u0dc1\u0ddc\u0dbd \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db4\u0db8\u0db8 \u0dc0\u0dd2\u0dc3\u0dd2\u0dbb \u0dba\u0ddc\u0db4\u0dda \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba\u0da7 \u0dc3\u0dc4\u0db7\u0ddc\u0d9c\u0dd2 \u0dc0\u0dd2\u0dba. \u0db4\u0db8\u0db8 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0ddc\u0dc0\u0da7 \u0d85\u0daf\u0dca\u200d\u0ddc\u0dbd \u0da1\u0ddc\u0dba\u0ddc\u0dbb\u0dd6 \u0d9a\u0dd2\u0dc4\u0dd2 \u0dba\u0d9a\u0dca \u0db4\u0dda \u0dc3\u0db8\u0d9f \u0d94\u0db6 \u0db4\u0dc0\u0dad \u0db4\u0dba\u0ddc\u0db8\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2. \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dba \u0db4\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba.",
