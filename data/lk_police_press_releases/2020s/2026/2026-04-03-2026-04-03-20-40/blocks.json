    "text": "\u0b95\u0bb3\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0b9f\u0bb1 \u0bb5\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0b95\u0bb2\u0bcd\u0bb2\u0bc1\u0bc2\u0bbe\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bc8 \u0baa\u0baf\u0bbf\u0bb1\u0bcd\u0b9a\u0bbf \u0bb5\u0baa\u0bb1\u0bcd\u0bb1 225 \u0baa\u0baf\u0bbf\u0bb2\u0bc1\u0ba8\u0bbe\u0bcd \u0bb5\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0b95\u0bbe\u0ba9\u0bcd\u0bb8\u0bcd\u0bc8\u0baa\u0bbf\u0bb3\u0bcd\u0b95\u0bb3\u0bc1\u0bae\u0bcd 55 \u0baa\u0baf\u0bbf\u0bb2\u0bc1\u0ba8\u0bbe\u0bcd \u0bb5\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0b95\u0bbe\u0ba9\u0bcd\u0bb8\u0bcd\u0bc8\u0baa\u0bbf\u0bb3\u0bcd \u0b9a\u0bbe\u0bb0\u0ba4\u0bbf\u0b95\u0bb3\u0bc1\u0bae\u0bcd \u0baa\u0baf\u0bbf\u0bb1\u0bcd\u0b9a\u0bbf\u0b95\u0b9f\u0bb3 \u0bae\u0bc1\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0baf\u0bb1\u0bcd\u0bb1 \u0bc6\u0bbf\u0bb4\u0bbe 2026.04.03 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0bb5\u0baa\u0bbe\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0bc6\u0bbf\u0bc6\u0b95\u0bbe\u0bb0\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0b9f\u0bae\u0b9a\u0bcd\u0b9a\u0bb0\u0bbe\u0ba9 \u0b86\u0ba9\u0ba8\u0bcd\u0ba4 \u0bc6\u0bbf\u0baf\u0bc7\u0baa\u0bbe\u0bb2 \u0b85\u0bc6\u0bbe\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0ba4\u0b9f\u0bb2\u0b9f\u0bae\u0baf\u0bbf\u0bb2\u0bc1\u0bae\u0bcd, \u0b85\u0b9f\u0bae\u0b9a\u0bcd\u0b9a\u0bbf\u0ba9\u0bcd \u0bb5\u0b9a\u0baf\u0bb2\u0bbe\u0bb3\u0bbe\u0bcd \u0b93\u0baf\u0bcd\u0bc6\u0bc1 \u0bb5\u0baa\u0bb1\u0bcd\u0bb1 \u0b9a\u0bbf\u0baf\u0bb0\u0bb7\u0bcd\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bbf\u0baa\u0bcd \u0bb5\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd\u0bae\u0bbe \u0b85\u0ba4\u0bbf\u0baa\u0bbe\u0bcd \u0bb0\u0bc6\u0bbf \u0bb5\u0b9a\u0bb5\u0ba9\u0bc6\u0bbf\u0bb0\u0ba4\u0bcd\u0ba9 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb5\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd\u0bae\u0bbe \u0b85\u0ba4\u0bbf\u0baa\u0bbe\u0bcd \u0b9a\u0bc8\u0bcd\u0bc8\u0ba4\u0bcd\u0ba4\u0bb0\u0ba3\u0bbf \u0baa\u0bbf\u0bbe\u0bbf\u0baf\u0ba8\u0bcd\u0ba4 \u0bc6\u0bc0\u0bb0\u0b9a\u0bc2\u0bbe\u0bbf\u0baf \u0b86\u0b95\u0bbf\u0baf\u0baf\u0bbe\u0bbe\u0bbf\u0ba9\u0bcd \u0baa\u0b99\u0bcd\u0baf\u0b95\u0bb1\u0bcd\u0baa\u0bbf\u0bb2\u0bc1\u0bae\u0bcd \u0b95\u0bb3\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0b9f\u0bb1 \u0bb5\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0b95\u0bb2\u0bcd\u0bb2\u0bc1\u0bc2\u0bbe\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b85\u0bb2\u0bc1\u0bc6\u0bbf\u0bb9\u0bbe\u0bb0 \u0bc6\u0bbf\u0b9f\u0bb3\u0baf\u0bbe\u0bc8\u0bcd\u0b9f\u0bc1 \u0b9f\u0bae\u0ba4\u0bbe\u0ba9\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0ba8\u0b9f\u0bc8\u0bb5\u0baa\u0bb1\u0bcd\u0bb1\u0ba4\u0bc1.",
