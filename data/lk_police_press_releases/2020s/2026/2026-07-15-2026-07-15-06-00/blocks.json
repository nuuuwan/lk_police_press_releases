    "text": "2026.07.14 \u0dd9\u0db1 \u0daf\u0dd2\u0db1 \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0dad\u0db9\u0dd4\u0dad\u0dca\u0db4\u0dad\u0dca\u0d9c\u0db8 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dd9\u0dc3\u0db4\u0dda \u0d9a\u0dd4\u0da9\u0ddc\u0db6\u0dd2\u0db6\u0dd2\u0dbd\u0dd2\u0dd9\u0dd0\u0dd9 \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0dad\u0db9\u0dd4\u0dad\u0dca\u0db4\u0dad\u0dca\u0d9c\u0db8 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0db4\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dca\u200d\u0ddc\u0dbb\u0dd3\u0db1\u0dca\u0daf \u0dda\u0da9\u0ddc\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca\u0daf \u0dd9\u0dd0\u0da7\u0dbd\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb \u0db1\u0dd2\u0dd9\u0dc3\u0d9a\u0dca \u0dad\u0dd4\u0dbd \u0db4\u0dd4\u0dbb\u0ddc\u0dd9\u0dc3\u0dca\u0dad\u0dd4 \u0dbd\u0db6\u0ddc\u0d9c\u0dd0\u0db1\u0dd3\u0db4\u0dda \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dd2\u0db1\u0dca\u0daf \u0dd0\u0dab\u0dd3\u0dda \u0dbb\u0db8\u0dd2\u0db1\u0dca\u0daf \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0dd0 \u0dbb\u0dd4\u0dd9\u0db1\u0dca\u0daf \u0db4\u0daf\u0db4\u0daf\u0db4\u0db1\u0d9a\u0dd4 \u0dd0\u0dab\u0dd3\u0dda \u0d8b \u0dbb\u0dab \u0daf \u0dc3\u0db8\u0d9f \u0d85\u0dad\u0dca\u0d85\u0da9\u0dd2\u0d82\u0d9c\u0dd4\u0dd9\u0da7 \u0db4\u0d9c\u0db1 \u0d87\u0dad. \u0dc3\u0dd0 \u0dbb\u0dd4\u0dd9\u0db1\u0dca\u0daf \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 36 \u0dc4\u0ddc 41 \u0dd9\u0dba\u0dc3\u0dca\u0dd9\u0dbd \u0dc3\u0dd4\u0dd9\u0db1 \u0dad\u0db9\u0dd4\u0dad\u0dca\u0db4\u0dad\u0dca\u0d9c\u0db8 \u0dc3\u0dc4 \u0dbd\u0da7\u0dd2\u0dba\u0ddc\u0dd9 \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0dd9\u0dbd \u0daf\u0dd2\u0dd2\u0d82\u0da0\u0dd2 \u0dbb\u0dd4\u0dd9\u0db1\u0dca\u0daf \u0db4\u0dda. \u0dad\u0db9\u0dd4\u0dad\u0dca\u0db4\u0dad\u0dca\u0d9c\u0db8 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca\u0daf \u0dd9\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0