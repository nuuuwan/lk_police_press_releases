    "text": "\u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0db4\u0dd4\u0dbb\u0dcf \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0d85\u0da9\u0dcf\u0dbd \u0d9a\u0dd2\u0dbb\u0dd3\u0db8, \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba \u0dc0\u0dbd\u0da7 \u0d87\u0dad\u0dd2 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8 \u0d85\u0dc0\u0db8 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8, \u0db8\u0db8\u0db8\u0dd9\u0dba\u0dd4\u0db8\u0dca \u0db4\u0dd4\u0dc5\u0dd4\u0dbd\u0dca\u0dbd \u0d9a\u0dd2\u0dbb\u0dd3\u0db8, \u0d87\u0db6\u0dca\u0db6\u0dd0\u0dc4\u0dd2\u0dc0\u0dd6\u0dc0\u0db1\u0dca \u0db4\u0dd4\u0db1\u0dbb\u0dd4\u0dad\u0dca\u0daf\u0dca\u200d\u0dad\u0dcf\u0db4\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8, \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba \u0daf\u0dd4\u0dbb\u0dca\u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8 \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dd4 \u0d9a\u0dbb \u0d9c\u0dad\u0dca\u0daf\u0dca\u200d \u0db1\u0dd2\u0dc0\u0dcf\u0dbb\u0dab \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dd9\u0db1\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0daf\u0dca\u200d\u0db8\u0d9a \u0d9a\u0dd2\u0dbb\u0dd3\u0db8, \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba\u0dc0\u0dbd\u0da7 \u0d91\u0db8\u0dbb\u0dc4\u0dd2\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0da2\u0dcf\u0dc0 \u0db6\u0dbd \u0d9c\u0dd0\u0db1\u0dca\u0dd3\u0db8 \u0dba\u0db1 \u0db6\u0dc4\u0dd4\u0dc0\u0dd2\u0db0 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dda\u0dc1\u0dba\u0db1\u0dca \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0dc0\u0dba\u0dcf\u0db4\u0dca\u0dad\u0dc0 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba \u0da2\u0dcf\u0dc0\u0dcf\u0dbb\u0db8 \u0db8\u0dd0\u0da9\u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0daf\u0dca\u200d\u0dd3\u0db8\u0db8\u0dca \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dd2\u0db1\u0dca 2025.10.30 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dc3\u0dd2\u0da7 \u201c\u0dbb\u0da7\u0db8 \u0d91\u0d9a\u0da7\u201d \u0da2\u0dcf\