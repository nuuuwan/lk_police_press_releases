    "text": "\u0db4\u0db8\u0db8 \u0db4\u0dda\u0dbb\u0dc5 \u0d9c\u0d82\u0da2\u0ddc \u0db4\u0dad\u0ddc\u0d9c\u0dba \u0db0\u0dd3\u0dd9\u0dbb \u0db4\u0db6\u0ddd\u0da7\u0dca\u0dd4\u0dd9\u0dda \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0ddc\u0db4\u0dda \u0dc3\u0dd2\u0da7 \u0db4\u0db8\u0dbb\u0da7\u0da7 \u0dbb\u0dd0\u0db4\u0d9c\u0db1 \u0d91\u0db1 \u0dbd\u0daf \u0db6\u0dd9\u0da7 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc3\u0dd0 \u0dbb\u0db1 \u0d85\u0dad\u0dbb \u0dd9\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dba\u0dd2\u0da7\u0dca\u0dc3\u0dca \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2.",
