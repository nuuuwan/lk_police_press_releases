    "text": "\u0dbb\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0db8\u0dc4\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba \u0d87\u0dc3\u0dc5 \u0daf\u0dd9\u0dbb\u0dc4\u0dbb \u0db8\u0d82\u0d9c\u0dbd\u0dba \u0db1\u0dd2\u0db8\u0dd2\u0dad\u0dca\u0daf\u0dad\u0db1\u0dca \u0dbb\u0dae\u0dc0\u0dcf\u0dc4\u0db1 \u0dd9\u0dcf\u0dbd\u0db1\u0dba \u0dc4\u0dcf \u0dbb\u0dae\u0d9c\u0dcf\u0dbd\u0dca \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0daf\u0dc0\u0db6\u0dca \u0d85\u0da9\u0dc0\u0dd2\u0dba\u0d9a\u0dca \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd3\u0db8. \u0dbb\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0db8\u0dc4\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba \u0d87\u0dc3\u0dc5 \u0daf\u0dd9\u0dbb\u0dc4\u0dd0\u0dbb \u0db8\u0d82\u0d9c\u0dbd\u0dba \u0dd9\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0daf\u0dc0\u0db1 2026.07.15 \u0daf\u0dd2\u0db1 \u0dc3\u0dd2\u0da7 2026.07.30 \u0daf\u0dd2\u0db1 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0dc0\u0db1\u0dca\u0daf\u0db1\u0dcf\u0daf\u0dda \u0dc3\u0dc4 \u0daf\u0dd9\u0dbb\u0dc4\u0dd0\u0dbb \u0db1\u0dd0\u0dbb\u0db9\u0dd3\u0db8\u0da7 \u0dd9\u0dd0\u0db8\u0dd2\u0daf\u0dab\u0db1 \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0db1\u0dca\u0daf\u0dda \u0dc0\u0dcf\u0dc4\u0db1 \u0db1\u0dc0\u0dad\u0dcf \u0dad\u0dd0\u0db6\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0db1\u0d9c\u0dbb\u0daf\u0dda \u0dd9\u0dc0\u0dad\u0dca\u0dc0\u0dcf\u0daf\u0d9c\u0db1 \u0dba\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0dbb\u0dae\u0d9c\u0dcf\u0dbd\u0dca (Parking) \u0dd9\u0dc4\u0dc3\u0dd4\u0daf\u0dc0\u0db1\u0dca \u0daf\u0dc3\u0dcf\u0dba\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0daf\u0dd9\u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0daf\u0dda \u0daf\u0dad\u0dcf\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc1\u0dba 