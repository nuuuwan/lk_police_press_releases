    "text": "\u0db8\u0db8\u0db8 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dd0 \u0db4\u0dd2\u0dc5\u0dd2\u0db8\u0dc0\u0dbd \u0db3 \u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dd9\u0d82\u0d9a\u0dcf \u0db8 \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d85\u0db8\u0db1\u0d9a\u0dd4\u0dad\u0dca \u0dbb\u0dcf\u0da2\u0dba \u0d86\u0dba\u0dad\u0db1 \u0db8\u0d9f \u0d91\u0d9a\u0dca\u0dc0 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb \u0db8\u0db8\u0db8 \u0d8b\u0dc0\u0daf\u0dd4\u0dbb \u0dc0\u0dc5\u0d9a\u0dca\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0db3 \u0dcf \u0d85\u0dc0\u0dc1\u0dba \u0db8\u0dba\u0ddd\u0d9c\u0dba \u0dbd\u0db6\u0dcf \u0db8\u0daf\u0db1 \u0db8\u0db8\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dd9\u0d82\u0d9a\u0dcf \u0db8 \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db8 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0db8\u0d9c\u0db1\u0dca \u0d9a\u0dcf\u0dbb\u0dd4\u0dab\u0dd2\u0d9a\u0dc0 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dd2. \u0da9 \u0dcf\u0dbd\u0dd2 \u0dda \u0db8\u0dcf\u0db0\u0dba \u0da9\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf \u0dba.",
