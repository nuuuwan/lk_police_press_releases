    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      109.33,
      515.96,
      150.21
    ],
    "text": "The Teldeniya Police Station has commenced an inquiry following information received on the afternoon of 01.04.2026 regarding an individual who drowned while bathing in the Victoria Reservoir in the Kumbukkandura area.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      164.77,
      476.26,
      178.05
    ],
    "text": "The deceased is identified as a 22-year-old resident of the Thalathuoya area.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      192.15,
      504.03,
      221.85
    ],
    "text": "Preliminary investigations have revealed that the victim was bathing at the above mentioned location along with five people at the time of the incident.",
    "fonts": [
      "NirmalaUI",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      236.32,
      434.74,
      249.6
    ],
    "text": "Further investigations are being conducted by the Teldeniya Police.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
