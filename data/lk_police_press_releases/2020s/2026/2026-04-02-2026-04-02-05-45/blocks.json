    ],
    "text": "\u0bb5\u0bbf\u0baa\u0bc6\u0bcd\u0ba4\u0bc1 \u0baa\u0bc6\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0bb2\u0bca\u0bca\u0bbf \u0b93\u0b9f\u0bcd\u0b9f\u0bc1\u0ba8\u0bb0\u0bc1\u0bae\u0bcd \u0baa\u0bc1\u0bc6\u0bcd\u0bc6\u0bb3\u0bae\u0bcd \u0bae\u0bb0\u0bc1\u0bc6\u0bcd\u0ba4\u0bc1\u0bb5\u0bae\u0bb3\u0ba9\u0baf\u0bbf\u0bb2\u0bcd \u0b9a\u0bbf\u0b95\u0bbf\u0b9a\u0bcd\u0bb3\u0b9a \u0baa\u0baa\u0bb1\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0bca\u0bca\u0bcd. \u0b9a\u0bca\u0bb2\u0bbf\u0baf\u0baa\u0bb5\u0bb5 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0ba4\u0bae\u0bb2\u0bc6\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0bb3\u0ba3\u0b95\u0bb3\u0bb3 \u0ba4\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd.",
