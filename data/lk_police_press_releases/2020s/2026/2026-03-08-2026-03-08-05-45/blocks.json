    "text": "\u0db4\u0dd4\u0dbd\u0dd2\u0dba\u0db1\u0dca\u0d9a\u0dd4\u0dbd\u0db8 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dd9\u0dc3\u0db8. 2026.03.07 \u0daf\u0dd2\u0db1 \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0db4\u0dd4\u0dbd\u0dd2\u0dba\u0db1\u0dca\u0d9a\u0dd4\u0dbd\u0db8 \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda \u0db4\u0dd4\u0dbd\u0dd2\u0dba\u0db1\u0dca\u0d9a\u0dd4\u0dbd\u0db8 \u0dc0\u0dda\u0db1\u0dd2\u0dba\u0dcf\u0dc0 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0db4\u0dda \u0dbb\u0dcf\u0db8\u0dab\u0dd6\u0dbb\u0dca \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0dc0\u0dda\u0db1\u0dd2\u0dba\u0dcf\u0dc0 \u0db4\u0daf\u0dc3\u0da7 \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0dd6 \u0dcf \u0dd0\u0daf\u0dd2\u0dba\u0d9a \u0d91\u0db8 \u0db4\u0daf\u0dc3\u0da7\u0db8 \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0dd6 \u0dba\u0dad\u0dbb\u0dd4 \u0dd0\u0daf\u0dd2\u0dba\u0d9a\u0dca \u0d9c\u0dd0\u0da7\u0dd3 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad. \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd2\u0db1\u0dca \u0dba\u0dad\u0dbb\u0dd4 \u0dd0\u0daf\u0dd2\u0db4\u0dda \u0dc3\u0dd4 \u0dd0\u0daf\u0dd2\u0d9a\u0dbb\u0dd4 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0db4\u0dba\u0db1\u0dca \u0d89\u0dc0\u0dad\u0da7 \u0dc0\u0dd3\u0dc3\u0dd2\u0dc0\u0dd2 \u0db6\u0dbb \u0dad\u0dbd \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0db4\u0dd4\u0dbd\u0dd2\u0dba\u0db1\u0dca\u0d9a\u0dd4\u0dbd\u0db8 \u0db4\u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d87\u0dad\u0dd4\u0dbd\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0db8\u0db1\u0dca \u0dc3\u0dd4 \u0db8\u0dd2\u0dba\u0db4\u0d9c\u0dcf\u0dc3\u0dca \u0d87\u0dad. \u0db8\u0dbb\u0dab \u0dbb\u0dd4 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 59 \u0d9a\u0dca \u0dc0\u0dd6 \u0da7\u0dd4\u0db4 \u0ddc\u0dad \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda \u0daf\u0d82\u0da0\u0dd2 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd2. \u0db4\u0dd4\u0dbd\u0dd2\u0dba\u0db1\u0dca\u0d9a\u0dd4\u0dbd\u0db8 \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d