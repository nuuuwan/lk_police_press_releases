    "text": "\u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad \u0dad\u0dd4\u0dbd \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db8\u0dbb\u0dca\u0db0\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dd4 \u0d9a\u0dbb \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dad\u0dcf\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd0\u0dba 24 \u0db4\u0dd4\u0dbb\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0db1\u0dc0 WhatsApp \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1\u0dba \u0d85\u0d82\u0d9a\u0dba\u0d9a\u0dca \u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf\u0daf\u0dd3 \u0d87\u0dad. \u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad \u0dad\u0da2\u0dd9\u0dc2\u0dca\u0da8 \u0db1\u0dd2\u0dad\u0dba\u0ddd\u0da2\u0dd9 \u0dad\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dad\u0dda \u0dc3\u0dca\u0dae\u0dcf\u0db4\u0dd2\u0dad \u0dc0\u0dd2\u0dad \u0dca\u0dc2 \u0dad\u0db8\u0dad\u0dc4\u0dba\u0dd4\u0db8\u0dca \u0db8\u0dd0\u0daf\u0dd2\u0dbb\u0dd2\u0dba \u0dad\u0dc0\u0dad \u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad \u0dad\u0dd4\u0dbd \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1 \u0d85\u0db4\u0dbb\u0dcf\u0db0, \u0db8\u0dad\u0dca\u0dbb\u0dc0\u0dd9 \u0da2\u0dcf\u0dc0\u0dcf\u0dbb\u0db8\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0dad\u0dbb\u0ddd\u0db0\u0dd3 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dad\u0dba\u0db1\u0dca \u0dad\u0dad\u0dcf\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dad\u0db8\u0db8 \u0db1\u0dc0 WhatsApp \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0d85\u0d82\u0d9a\u0dba \u0d94\u0dc3\u0dca\u0dad\u0dc3\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0dad\u0db8\u0dca \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0 \u0d87\u0dad. \u0dad\u0dad\u0dcf\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dbd\u0db6\u0dcf\u0dad\u0dd9\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca\u0dad\u0dda \u0dbb\u0dc4\u0dc3\u0dd9\u0db7\u0dcf\u0dc0\u0dba \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dad\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. WhatsApp \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0d85\u0d82\u0d9a\u0dba - 0777128128 \u0dad\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dba \u0dad\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba. \u0bae\u0bc7\u0bb2\u0bcd \u0bc7\u0bbe\u0b95\u0bbe\u0ba3\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0b99\u0bcd\u0b95\u0bb3\u0bc8 \u0b95\u0b9f\u0bcd\u0b9f\u0bc1\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0baa\u0baa\u0bbe\u0ba4\u0bc1\u0bc7\u0b95\u0bcd\u0b95\u0bc8\u0bbf\u0b9f\u0bc7\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba4\u0b95\u0bb5\u0bb2\u0bcd \u0baa\u0baa\u0bb1 \u0baa\u0bc1\u0ba4\u0bbf\u0baf WhatsApp \u0b8e\u0ba3\u0bcd \u0b85\u0bb1\u0bbf\u0bae\u0bc1\u0b95\u0bc7\u0bcd \u0bae\u0bc7\u0bb1\u0bcd\u0b95\u0bc1 \u0bc7\u0bbe\u0b95\u0bbe\u0ba3\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0b9a\u0bcd\u0baa\u0b9a\u0baf\u0bb2\u0bcd\u0b95\u0bb3\u0bc8 \u0ba4\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bc7\u0bcd \u0bae\u0ba8\u0bbe\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd, \u0baa\u0baa\u0bbe\u0ba4\u0bc1\u0bc7\u0b95\u0bcd\u0b95\u0bc8\u0bbf\u0b9f\u0bc7\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba4\u0b95\u0bb5\u0bb2\u0bcd\u0b95\u0bb3\u0bc8 \u0baa\u0baa\u0bb1\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0b95 24 \u0bc7\u0ba3\u0bbf \u0bae\u0ba8\u0bb0\u0bae\u0bc1\u0bc7\u0bcd \u0baa\u0b9a\u0baf\u0bb2\u0bcd\u0baa\u0b9f\u0bc1\u0bc7\u0bcd \u0baa\u0bc1\u0ba4\u0bbf\u0baf WhatsApp \u0baa\u0ba4\u0bbe\u0bb3\u0bb2\u0bae\u0baa\u0b9a\u0bbf \u0b8e\u0ba3\u0bcd \u0b85\u0bb1\u0bbf\u0bae\u0bc1\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bc8\u0bcd\u0bc8\u0ba4\u0bc1. \u0bae\u0bc7\u0bb2\u0bcd \u0bc7\u0bbe\u0b95\u0bbe\u0ba3 \u0b9a\u0bbf\u0bae\u0bb0\u0bb7\u0bcd\u0b9f\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bbf\u0baa\u0bcd \u0baa\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd\u0bc7\u0bbe \u0b85\u0ba4\u0bbf\u0baa\u0bbe\u0bcd \u0b85\u0bb2\u0bc1\u0bb5\u0bb2\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b85\u0bb3\u0bc7\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bc8\u0bcd\u0bc8 \u0b9a\u0bbf\u0bb1\u0baa\u0bcd\u0baa\u0bc1 \u0baa\u0b9a\u0baf\u0bb2\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb3\u0bc7\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1, \u0bae\u0bc7\u0bb2\u0bcd \u0bc7\u0bbe\u0b95\u0bbe\u0ba3\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0ba8\u0bb3\u0b9f\u0baa\u0baa\u0bb1\u0bc1\u0bc7\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0b9a\u0bcd\u0baa\u0b9a\u0baf\u0bb2\u0bcd\u0b95\u0bc8\u0bcd, \u0bae\u0baa\u0bbe\u0bb3\u0ba4\u0baa\u0bcd\u0baa\u0baa\u0bbe\u0bb0\u0bc1\u0bc8\u0bcd \u0b95\u0b9f\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd \u0b89\u0bc8\u0bcd\u0bc8\u0bbf\u0b9f\u0bcd\u0b9f \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0bae\u0bb0\u0bbe\u0ba4 \u0baa\u0b9a\u0baf\u0bb2\u0bcd\u0baa\u0bbe\u0b9f\u0bc1\u0b95\u0bc8\u0bcd \u0baa\u0ba4\u0bbe\u0b9f\u0bbe\u0bcd\u0baa\u0bbe\u0ba9 \u0ba4\u0b95\u0bb5\u0bb2\u0bcd\u0b95\u0bb3\u0bc8, \u0b87\u0ba8\u0bcd\u0ba4 \u0baa\u0bc1\u0ba4\u0bbf\u0baf WhatsApp \u0b8e\u0ba3\u0bcd\u0ba3\u0bbf\u0ba9\u0bcd \u0bae\u0bc2\u0bb2\u0bc7\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95 \u0bae\u0bc1\u0b9f\u0bbf\u0baf\u0bc1\u0bc7\u0bcd.",
