    "text": "\u0dbd\u0db4\u0dcf\u0dbd\u0dca\u0db4\u0dd2\u0dad\u0dd2\u0d9c\u0db8 \u0dbd\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dca\u200d\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dd9\u0db6\u0dba\u0dd2. \u0baa\u0b95\u0bca\u0b9f\u0bca \u0b89\u0b9f\u0ba9\u0bcd \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95 \u0ba8\u0baa\u0bca\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u2013 \u0baa\u0baa\u0bca\u0baa\u0bbf\u0bb2\u0bcd\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bbf\u0b95\u0bae \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1. 2026.03.14 \u0bae\u0ba4\u0bbf\u0baf \u0baa\u0bb5\u0ba4\u0bb3\u0baf\u0bbf\u0bb2\u0bcd, \u0baa\u0baa\u0bca\u0bb2\u0bcd\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bbf\u0b95\u0bae \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f, \u0baa\u0baa\u0bca\u0bb2\u0bcd\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bbf\u0b95\u0bae \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bca\u0bca\u0bbf\u0b95\u0bb3\u0bcd 1444 \u0bb2\u0bbf\u0b9f\u0bcd\u0b9f\u0bca\u0bcd (8 \u0baa\u0baa \u0bb2\u0bcd\u0b95\u0bb3\u0bcd) \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa \u0bca\u0ba4 \u0bae\u0ba4\u0bc1\u0baa\u0bca\u0ba9\u0bae\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0b95\u0bca\u0b9f\u0bca \u0b89\u0b9f\u0ba9\u0bcd \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95 \u0ba8\u0baa\u0ba4 \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0ba4\u0ba9\u0bca\u0bcd. \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95 \u0ba8\u0baa\u0bca\u0bcd \u0bb5\u0baf\u0ba4\u0bc1 38, \u0baa\u0baa\u0bca\u0bb2\u0bcd\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bbf\u0b95\u0bae \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0ba4\u0baf\u0b9a\u0bcd \u0baa\u0b9a\u0bca\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bca\u0bcd. \u0baa\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8 \u0ba8\u0ba4\u0b9f\u0baa\u0baa\u0bb1\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1. 04. \u0db6\u0dd3\u0da9\u0dd2 \u0db4 \u0ddc\u0dd9 \u0db4\u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db7\u0ddc\u0dbb\u0dba\u0da7 - \u0daf\u0dd4\u0db1\u0dca\u0d9c\u0dbd\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0dba. 2026.03.14 \u0daf\u0dd2\u0db1 \u0d85\u0dc5\u0dd4\u0dba\u0db8\u0dca \u0d9a\u0dcf\u0dd9\u0dbd\u0dda \u0daf\u0dd4\u0db1\u0dca\u0d9c\u0dbd\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dbd\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u200d \u0dc0\u0dca\u200d\u0dc3\u0dbd\u0db8\u0dca \u0d9a\u0dd0\u0db4\u0dd4\u0db8\u0dca\u0dbd\u0d9c\u0dcf\u0da9 \u0dbd\u0dc0\u0dca\u200d\u0dbb\u0dc5 \u0dad\u0dd3\u0dbb\u0dbd\u0dda\u0daf\u0dd3 \u0daf\u0dd4\u0db1\u0dca\u0d9c\u0dbd\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dbd\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u200d \u0dc3\u200d\u0dae\u0dcf\u0db1\u0dbd\u0dda \u0db1\u0dd2\u0dd9\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0dbd\u0dbb\u0ddd\u0db0\u0dd3 \u0dbd\u0dd9\u0dc3 \u0dbd\u0db8\u0dbb\u0da7\u0da7 \u0dbd\u0d9c\u0db1\u0dca\u0dc0\u0dca\u200d\u0db1 \u0dd9\u0daf \u0db6\u0dd3\u0da9\u0dd2 \u0dbd\u0d9a\u0dcf\u0dc5 \u0d9a\u0dd2\u0dbd\u0dd9\u0ddd \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 1654 \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 615 \u0d9a\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dcf\u0dc4\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0dd9\u0dcf\u0dbb\u0dd2 \u0dbb\u0dae\u0dba\u0d9a\u0da7 \u0db4\u0da7\u0dc0\u0dca\u200d\u0dcf \u0dad\u0dd2\u0db6\u0dd2\u0dba\u0daf\u0dd3 \u0dbd\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u200d \u0db7\u0dcf\u0dbb\u0dba\u0da7 \u0dbd\u0d9c\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0dbd\u0db8\u0db8 \u0db6\u0dd3\u0da9\u0dd2\u0dbd\u0d9a\u0dcf\u0dc5 \u0dbd\u0dad\u0dcf\u0d9c\u0dba \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca \u0dbb\u0dd0\u0dbd\u0d9c\u0db1\u0dc0\u0dd2\u0dad\u0dca\u0daf\u0dca\u200d \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dca\u200d\u0da7 \u0dc3\u0dd0\u0d9a\u0d9a\u0d9a\u0dbb\u0db1 \u0dbd\u0db6\u0ddd\u0da7\u0dca\u0dd4\u0dc0\u0dca\u200d\u0d9a\u0dca\u0daf \u0dbd\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u200d \u0db7\u0dcf\u0dbb\u0dba\u0da7 \u0dbd\u0d9c\u0db1 \u0d87\u0dad.",
