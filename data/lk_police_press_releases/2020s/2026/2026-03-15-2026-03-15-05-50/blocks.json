    "text": "\u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa \u0bca\u0ba4 \u0baa\u0b9a\u0bca\u0ba4\u0bcd\u0ba4\u0bc1 \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1 \u0b87\u0ba4\u0bb1\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bc1\u0ba4\u0b9f\u0baf \u0baa\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8\u0b95\u0ba4\u0bb3 \u0ba8\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bc1\u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1. 02. \u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0db4\u0dbb\u0ddd\u0db0\u0dd3 \u0db8\u0dad\u0dca \u0dd0\u0db1\u0dca \u0dc4\u0ddc \u0db4\u0d9c\u0ddd\u0da9\u0ddc \u0dc3\u0db8\u0d9f \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dd9\u0da7 - \u0dd9\u0dd9\u0ddc\u0db1 \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0daf\u0dd6\u0dc2\u0dab \u0db8\u0dbb\u0dca\u0db0\u0dca\u200d\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dc4\u0ddc\u0dbb \u0d92 \u0dba. 2026.03.14 \u0daf\u0dd2\u0db1 \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0d9a\u0dcf\u0dd9\u0dbd\u0dda \u0dc0\u0dca\u200d\u0dcf\u0daf\u0dca\u0db0\u0dd6\u0dc0\u0dca\u200d \u0dbd\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u200d \u0dc0\u0dca\u200d\u0dc3\u0dbd\u0db8\u0dca \u0dbd\u0db6\u0dcf\u0dbd\u0dca\u0dbd\u0d9c\u0dcf\u0da9 \u0d9c\u0d82 \u0d89\u0dc0\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dbd\u0daf\u0dca\u0db0\u0dc1\u0dbd\u0dda\u0daf\u0dd3 \u0dc0\u0dca\u200d\u0dd9\u0dcf\u0db1 \u0db8\u0db0\u0dba\u0db8 \u0dd6\u0dc2\u0dab \u0db8\u0dbb\u0dca\u0db0\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0d9a \u0d92\u0d9a\u0d9a\u0dbd\u0dda \u0db1\u0dd2\u0dd9\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dca\u200d\u0dd0\u0da7\u0dbd\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb \u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0dbd\u0dbb\u0ddd\u0db0\u0dd3 \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0db4\u0dd0\u0db1\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca 112 \u