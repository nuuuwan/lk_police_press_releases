    "text": "\u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0dbd\u0dbb\u0ddd\u0db0\u0dd3\u0dc0\u0dca\u200d\u0dad\u0dca\u0daf\u0dca\u200d\u0d9a\u0db8\u0dca \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dbd\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0dc0\u0dca\u200d\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dd9\u0db6\u0dba\u0dd2. \u0baa\u0baa\u0bca\u0ba4\u0ba4\u0baa\u0bcd \u0baa\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bb5\u0bca\u0bbf\u0ba9\u0bcd \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa \u0bca\u0ba4 \u0baa\u0b9a\u0bca\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0ba4\u0bb3 \u0bae\u0bc1\u0b9f\u0b95\u0bcd\u0b95\u0bc1 \u0ba8\u0b9f\u0bb5\u0b9f\u0bbf\u0b95\u0bcd\u0ba4\u0b95 \u2013 \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa \u0bca\u0ba4 \u0baa\u0b9a\u0bca\u0ba4\u0bcd\u0ba4\u0bc1 \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1 \u0baa\u0baa\u0bca\u0ba4\u0ba4\u0baa\u0bcd \u0baa\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0baa\u0baa\u0bb1\u0bcd\u0bb1 \u0baa\u0b9a\u0bca\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0ba4\u0bb3 \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa \u0bca\u0ba4\u0bae\u0bca\u0b95 \u0ba4\u0b95\u0baf\u0bca\u0bc8\u0bcd\u0b9f \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bca\u0b95 \u0bb5\u0bb0\u0bc1\u0ba4\u0b95 \u0bb5\u0ba8\u0bcd\u0ba4 \u0bae\u0bc1\u0ba4\u0bb1\u0baa\u0bcd\u0baa\u0bca\u0b9f\u0bcd\u0b9f\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0b9f\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8 \u0baa\u0ba4\u0bca\u0b9f\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.",
