    "text": "\u0baa\u0bc0\u0b9f\u0bbf \u0b87\u0ba4\u0bb2\u0ba4\u0baf\u0baa\u0bcd \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0baa\u0bb1\u0bbf\u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u2013 \u0ba4\u0bc1\u0b99\u0bcd\u0b95\u0bb2\u0bcd \u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf\u0baf \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0ba4\u0bb2\u0baf\u0bae\u0bcd. 2026.03.14 \u0b95\u0bca\u0ba4\u0bb2 \u0baa\u0ba8 \u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd, \u0ba4\u0bc1\u0b99\u0bcd\u0b95\u0bb2\u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf\u0baf \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0baa\u0b95\u0baa\u0bcd\u0baa\u0bc1\u0bae\u0bcd\u0baa\u0b95\u0bca\u0b9f \u0b95\u0b9f\u0bb1\u0bcd\u0b95\u0ba4 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd, 1654.615 \u0b95\u0bbf\u0baa\u0bb2\u0bca \u0baa\u0bc0\u0b9f\u0bbf \u0b87\u0ba4\u0bb2\u0ba4\u0baf \u0bb2\u0bca\u0bca\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0bca\u0ba4\u0bc1\u0b95\u0bca\u0baa\u0bcd\u0baa\u0bc1 \u0ba8\u0b9f\u0bb5\u0b9f\u0bbf\u0b95\u0bcd\u0ba4\u0b95\u0baf\u0bc1\u0b9f\u0ba9\u0bcd \u0baa\u0bb1\u0bbf\u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0baa\u0bc0\u0b9f\u0bbf \u0b87\u0ba4\u0bb2\u0ba4\u0baf \u0b95\u0b9f\u0bb2\u0bcd \u0bb5\u0bb4\u0bbf\u0baf\u0bca\u0b95 \u0baa\u0b95\u0bca\u0bc8\u0bcd\u0b9f\u0bc1 \u0bb5\u0ba8\u0bcd\u0ba4\u0ba4\u0bca\u0b95 \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0baa\u0b9f\u0ba4\u0b95 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0baa\u0bb1\u0bbf\u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0baa\u0b9a\u0baf\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bca\u0bcd. \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95 \u0ba8\u0baa\u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0baa\u0bcd\u0baa\u0bbf\u0b9a\u0bcd\u0baa\u0b9a\u0ba9\u0bcd\u0bb1\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0b85\u0bb5\u0bca\u0bcd\u0b95\u0ba4\u0bb3 \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0baf \u0ba4\u0bc1\u0b99\u0bcd\u0b95\u0bb2\u0bcd\u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0b9a\u0bca\u0bca\u0bcd \u0baa\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8\u0b95\u0bb3\u0bcd \u0baa\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd. 05. \u0db4\u0dd9\u0ddc\u0dbb\u0dd2 \u0dbb\u0dae\u0dba \u0d9c\u0dd0\u0da7\u0dd3 \u0daf \u0db4\u0dba\u0d9a\u0dd4 \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0d9a\u0dca\u0dc2\u0dba\u0da7 - \u0dd2\u0dc5\u0dd2\u0dba\u0db1\u0dca\u0daf\u0dd9 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dd9\u0dc3\u0db8.",
