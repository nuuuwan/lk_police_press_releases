    "text": "2026.03.14 \u0b86\u0ba8\u0bcd \u0ba4\u0bbf\u0b95\u0ba4\u0bbf \u0baa\u0b95\u0bb2\u0bcd \u0baa\u0bb5\u0ba4\u0bb3\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0bbf\u0bb2\u0bbf\u0baf\u0ba8\u0bcd\u0ba4\u0bb2 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1\u0b9f\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0bc1\u0ba4\u0bbf\u0baf \u0baa\u0baa\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba4\u0bca\u0bbf\u0baa\u0bcd\u0baa\u0bbf\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0baa\u0bb2\u0bca\u0bca\u0bbf\u0baf\u0bbf\u0bb2\u0bcd, \u0bb5\u0bc0\u0ba4\u0bbf\u0ba4\u0baf \u0bae\u0bca\u0bb1\u0bbf \u0baa\u0baf\u0bc8\u0bbf\u0ba4\u0bcd\u0ba4 \u0baa\u0bca\u0ba4\u0b9a\u0bca\u0bca\u0bbf \u0baa\u0bae\u0bb2\u0bcd \u0baa\u0bae\u0bca\u0ba4\u0bbf \u0bb5\u0bbf\u0baa\u0ba4\u0bcd\u0ba4\u0bc1 \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0bb5\u0bbf\u0baa\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0baa\u0b9f\u0bc1\u0b95\u0bca\u0baf\u0bae\u0ba4\u0b9f\u0ba8\u0bcd\u0ba4 \u0baa\u0bca\u0ba4\u0b9a\u0bca\u0bca\u0bbf \u0baa\u0bbf\u0bb2\u0bbf\u0baf\u0ba8\u0bcd\u0ba4\u0bb2 \u0ba4\u0bb5\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9a\u0bca\u0ba4\u0bb2\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0ba9\u0bcd \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0bca\u0bcd \u0b89\u0baf\u0bbf\u0bca\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bca\u0bca\u0bcd. \u0b89\u0baf\u0bbf\u0bca\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bb5\u0bca\u0bcd 71 \u0bb5\u0baf\u0ba4\u0bc1\u0ba4\u0b9f\u0baf \u0bae\u0b9f\u0baa\u0bca\u0ba9 \u0baa\u0bbf \u0baa\u0ba4\u0b9a\u0ba4\u0bcd\u0ba4\u0ba4\u0b9a\u0bcd \u0baa\u0b9a\u0bca\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bca\u0bcd. \u0bb5\u0bbf\u0baa\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bca\u0b95 \u0baa\u0bb2\u0bca\u0bca\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b93\u0b9f\u0bcd\u0b9f\u0bc1\u0ba8\u0bca\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0baa\u0bbf\u0bb2\u0bbf\u0baf\u0ba8\u0bcd\u0ba4\u0bb2 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0b9a\u0bca\u0bca\u0bcd \u0baa\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8\u0b95\u0ba4\u0bb3 \u0baa\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0bc8\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd. 06. \u0dba\u0dad\u0dd4\u0dbb\u0dd4 \u0dd0\u0daf\u0dba \u0d9c\u0dd0\u0da7\u0dd3 \u0daf \u0ddc\u0db1\u0dca\u0dad\u0ddc\u0dd9\u0d9a\u0dca \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0d9a\u0dca\u0dc2\u0dba\u0da7 - \u0db4\u0daf\u0ddc\u0db8\u0dca\u0db4\u0dda \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dd9\u0dc3\u0db8.",
