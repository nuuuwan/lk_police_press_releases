    "text": "\u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0dca\u200d\u0db1\u0dca \u0db4\u0dd9\u0dcf\u0dbd\u0d9c\u0dcf\u0dc3\u200d \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d85\u0dad\u0dca\u0daf\u0dca\u200d\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0dca\u200d\u0da7 \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0daf\u0dd4\u0db1\u0dca\u0d9c\u0dbd\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dbd\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dca\u200d\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dd9\u0db6\u0dba\u0dd2.",
