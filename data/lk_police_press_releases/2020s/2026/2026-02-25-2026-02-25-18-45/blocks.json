  {
    "page_number": 2,
    "bbox": [
      72.02,
      295.46,
      539.85,
      343.16
    ],
    "text": "The Kalutara North Police Station and the Kalutara Divisional Crime Investigation Bureau are conducting investigations to apprehend suspects in connection with a murder that occurred on 14.02.2026 within the Kalutara North Police Division.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      14.039999961853027
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      357.74,
      547.98,
      389.36
    ],
    "text": "The incident involved two unidentified individuals who arrived on a motorcycle and fatally shot a man inside a shop located in the Wadiyamankada Junction area.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      14.039999961853027
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      403.96,
      521.32,
      451.66
    ],
    "text": "Based on ongoing investigations, information has emerged regarding one of the suspects, and his photographs are being released to the media to assist in identification.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      14.039999961853027
    ]
  },
