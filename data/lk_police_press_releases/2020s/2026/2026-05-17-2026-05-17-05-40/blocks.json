  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      538.62,
      491.01,
      579.53
    ],
    "text": "On the morning of 16.05.2026, the Mount Lavinia Police received information regarding the suspicious death of an individual inside a residence located in the Badowita area within the Mount Lavinia Police Division.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      594.09,
      517.34,
      621.17
    ],
    "text": "The deceased was identified as a 54-year-old resident of the Badowita area in Mount Lavinia.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      635.73,
      526.26,
      662.81
    ],
    "text": "Preliminary investigations have revealed that the deceased had been living alone at the residence. A minor cut injury was also observed on the neck of the deceased.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      677.25,
      516.9,
      718.13
    ],
    "text": "The body has been placed at the Kalubowila Hospital mortuary for a post-mortem examination, while further investigations are being carried out by the Mount Lavinia Police.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
