    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      64.43,
      513.86,
      105.33
    ],
    "text": "Investigations were initiated by the Kotawhera Police on the morning of 16.05.2026 following information received that a woman had died due to electrocution in the Palugolla area within the Kotawhera Police Division.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      119.89,
      495.82,
      133.17
    ],
    "text": "The deceased was identified as a 69-year-old resident of Palugolla, Galgamuwa.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      147.73,
      496.8,
      174.81
    ],
    "text": "Preliminary investigations have revealed that the electrocution was caused by an electrical leakage from a wire connected to a water motor.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      189.25,
      441.82,
      202.53
    ],
    "text": "Further investigations are being carried out by the Kotawhera Police.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
