  {
    "page_number": 1,
    "bbox": [
      107.42,
      127.09,
      541.82,
      167.97
    ],
    "text": "The Kalawanchikudy Police Station has commenced investigations following a complaint received on the night of 18.04.2026 regarding the fatal assault of an individual in the Helpage Housing Complex area within the Kalawanchikudy Police Division.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      182.53,
      435.7,
      195.81
    ],
    "text": "The deceased is a 58-year-old resident of the Kalawanchikudy area.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      210.37,
      526.42,
      237.45
    ],
    "text": "Preliminary investigations have revealed that the victim was attacked and killed with a sharp weapon while seated in a field on his cultivated land.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      251.92,
      541.83,
      279.0
    ],
    "text": "The suspects responsible for the crime have not yet been identified. Further investigations are being carried out by the Kalawanchikudy Police.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
