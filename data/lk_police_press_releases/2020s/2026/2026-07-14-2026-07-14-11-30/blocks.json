    "text": "\u0baa\u0ba3 \u0ba8\u0bae\u0bca\u0b9a\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0b89\u0ba4\u0bb5\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b92\u0ba4\u0bcd\u0ba4\u0bc1\u0b9f\u0bb4\u0baa\u0bcd\u0baa\u0bc1 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0b9a\u0bc7\u0bcd\u0ba8\u0ba4\u0b95\u0bc7\u0baa\u0bca\u0bcd \u0b9f\u0b95\u0ba4\u0bc1 \u2013 \u0b95\u0ba3\u0bbf\u0ba9\u0bbf \u0b95\u0bc1\u0bb1\u0bcd\u0bb1 \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0b9f\u0ba3\u0baa\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1, \u0bb5\u0b9f\u0ba8\u0bae\u0bb2\u0bcd \u0bae\u0bca\u0b95\u0bca\u0ba3\u0baa\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1",
