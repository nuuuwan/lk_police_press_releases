    "text": "\u0d91\u0db8 \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0d9c\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dbd \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1 \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0dda\u0daf\u0dd3 2026.03.07 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0da2\u0dcf\u0d87\u0dbd \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda\u0daf\u0dd3 \u0db1\u0dd2\u0dc0\u0dc3 \u0da7 \u0db4\u0dc0\u0da9\u0dd2 \u0dad\u0dd0\u0db6\u0dd3\u0db4\u0dda \u0dc3\u0dd2\u0dda\u0dd2\u0dba\u0da7 \u0d86\u0db0\u0dcf\u0dbb \u0d85\u0db1\u0dd4\u0db6\u0dbd \u0daf\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dda \u0db1\u0dd2\u0dc0\u0db4\u0dc3\u0dca \u0dc3\u0d9f\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0db4\u0db6\u0ddd\u0dbb 12 \u0dc0\u0dbb\u0dca\u0d9c\u0db4\u0dda \u0d9c\u0dd2\u0db1\u0dd2 \u0d85\u0dc0\u0dd2\u0dba\u0d9a\u0dca, \u0d91\u0db8 \u0dad\u0db4\u0dbb\u0dcf\u0dda 14\u0d9a\u0dca \u0dc4\u0dcf \u0dc0\u0dba\u0dcf\u0da2 \u0d85\u0d82 \u0dad\u0dc4\u0da9\u0dd4 \u0db4\u0dba\u0dcf\u0dd9\u0db1 \u0dbd\u0dd9 \u0dba\u0dad\u0dd4\u0dbb\u0dd4 \u0dd0\u0daf\u0dd2\u0dba\u0d9a\u0dca \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db7\u0dcf\u0dbb\u0dba\u0da7 \u0db4\u0d9c\u0db1 \u0d87\u0dad. \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0d9c\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dbd \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1 \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0dda\u0daf\u0dd3 2025.07.03 \u0daf\u0dd2\u0db1 \u0dbb\u0dcf\u0d9c\u0db8 \u0db6\u0da7\u0dd4\u0dc0\u0dad\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0db4\u0dd4\u0dda\u0d9c\u0dbd\u0db4\u0dba\u0d9a\u0dd4\u0da7 \u0db4\u0dc0\u0da9\u0dd2 \u0dad\u0db6\u0dcf \u0d9d\u0dcf\u0dad\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0dda \u0dc3\u0dd2\u0dda\u0dd2\u0dba\u0da7 \u0d86\u0db0\u0dcf\u0dbb \u0d85\u0db1\u0dd4\u0db6\u0dbd \u0daf\u0dd4\u0db1\u0dca \u0dad\