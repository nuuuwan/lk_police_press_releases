    "text": "\u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d9a\u0dbb\u0dca\u0dad\u0dd8 / \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0d9a\u0dbb\u0dca\u0dad\u0dd8, \u0d85\u0db0\u0dba\u0d9a\u0dca\u0dc2 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 / \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0d9a\u0dc5\u0db8\u0dab\u0dcf\u0d9a\u0dbb\u0dd4, \u0dc3\u0dd2\u0dba\u0dc5\u0dd4\u0db8 \u0db8\u0dcf\u0db0\u0dba \u0d86\u0dba\u0dad\u0db1. \u0dc4\u0dd1\u0dc2\u0dca \u0dc4\u0dcf \u0d9a\u0dd4\u0dc2\u0dca \u0db8\u0dad\u0dca\u0dad\u0dbb\u0dc0\u0dba \u0dc3\u0db1\u0dca\u0dad\u0d9a\u0dba\u0dda \u0dad\u0db6\u0dcf\u0d9c\u0dad\u0dca\u0dad \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0dc1\u0dd2\u0dc2\u0dba\u0dba\u0dba\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0dad\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 - \u0dba\u0dda\u0dbb\u0dcf\u0dba\u0daf\u0dca\u200d\u0dab\u0dd2\u0dba \u0dba \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba. \u0db4\u0dda\u0dbb\u0dcf\u0db4\u0dd9\u0dab\u0dd2\u0dba \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda \u0db4\u0dda\u0dbb\u0dcf\u0db4\u0dd9\u0dab\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0 \u0dc0\u0dd2\u0dd9\u0dba\u0dcf\u0dbd \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba\u0db4\u0dba\u0d9a\u0dd4 \u0dc4\u0dd1\u0dc2\u0dca\u200d\u0dca \u0dc4\u0dcf \u0d9a\u0dd4\u0dc2\u0dca\u200d\u0dca \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dba \u0dbd\u0d9f \u0dad\u0db6\u0dcf \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0d85\u0db4\u0dd9\u0dc0\u0dd2 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0da7 \u0db4\u0dda\u0dbb\u0dcf\u0db4\u0dd9\u0dab\u0dd2\u0dba \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dcf\u0db0\u0dd2 \u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0db4\u0dc0\u0dad \u0dbd\u0dd9 \u0db4\u0dad\u0dcf\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0d85\u0db1\u0dd4\u0dc0 2026.03.07 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d9a\u0dcf\u0dbd\u0db4\u0dda \u0dc0\u0dd0\u0da7\u0dbd\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb \u0dc4\u0dd1\u0dc2\u0dca \u0db8\u0dad\u0dca\u0dad\u0dbb\u0dc0\u0dba \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 85 \u0db8\u0dd2\u0dbd\u0dd2 \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 260 \u0d9a\u0dca \u0dc4\u0dcf \u0d9a\u0dd4\u0dc2\u0dca \u0db8\u0dad\u0dca\u0dad\u0dbb\u0dc0\u0dba \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 11 \u0db8\u0dd2\u0dbd\u0dd2\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 210 \u0d9a\u0dca \u0dc3\u0db1\u0dca\u0dad\u0d9a\u0db4\u0dda \u0dad\u0db6\u0dcf \u0db4\u0d9c\u0db1 \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0dd0\u0d9a\u0d9a\u0dcf\u0dbb \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba\u0dba\u0dcf \u0db4\u0dda\u0dbb\u0dcf\u0db4\u0dd9\u0dab\u0dd2\u0dba \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0db4\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dca\u0daf\u0dca\u200d\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0db4\u0d9c\u0db1 \u0d87\u0dad. \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 23 \u0d9a\u0dca \u0dc0\u0db1 \u0dba\u0dc4\u0ddd\u0d9a\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dba\u0dda\u0dc1\u0dba\u0dda \u0daf\u0d82\u0da0\u0dd2\u0d9a\u0dbb\u0dd4\u0dba\u0dc0\u0d9a\u0dd2. \u0d85\u0dad\u0dca\u0daf\u0dca\u200d\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dad\u0dca\u0daf\u0dca\u200d \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0d9c\u0dbb\u0dd4 \u0db8\u0db4\u0dc4\u0dca\u0dc3\u0dca\u0dbb\u0dcf\u0dad\u0dca\u0daf\u0dca\u200d \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0db4\u0dc0\u0dad \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0dad\u0dca\u0daf\u0dca\u200d \u0d9a\u0dbb 2026.03.12 \u0dc0\u0db1 \u0d85\u0dd9 \u0daf\u0dd2\u0db1 \u0dd9\u0d9a\u0dca\u0dc0\u0dcf \u0daf\u0dd2\u0db1 05\u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0dd0\u0db3\u0dc0\u0dd4\u0dda \u0db1\u0dd2\u0db4\u0dba\u0ddd\u0d9c \u0dbd\u0db6\u0dcf \u0db4\u0d9c\u0db1 \u0db4\u0dda\u0dbb\u0dcf\u0db4\u0dd9\u0dab\u0dd2\u0dba \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0db4\u0dda \u0dbb\u0db3\u0dc0\u0dcf\u0db4\u0d9c\u0db1 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0dba \u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dba \u0dba\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba. \u0bb9\u0bc7\u0bb7\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u2018\u0b95\u0bc1\u0bb7\u0bcd\u2019 \u0bb9\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0ba4\u0bc8 \u0ba4\u0bc8\u0bc8\u0bcd\u0bc8\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0bc8 \u0baa\u0bb2\u0bcd\u0b95\u0ba4\u0bb2\u0b95\u0bcd\u0b95\u0bb4\u0b95 \u0bae\u0bcb\u0ba3\u0bc8\u0bcb\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u2013 \u0bb9\u0baa\u0bb0\u0bcb\u0bc8\u0ba4\u0bc8 \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0ba4\u0bb2\u0baf\u0bae\u0bcd \u0bb9\u0baa\u0bb0\u0bcb\u0bc8\u0ba4\u0bc8 \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0b9f \u0baa\u0bbf\u0bcb\u0bbf\u0bc8\u0bbf\u0bb1\u0bcd\u0b95\u0bc1\u0b9f\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb9\u0baa\u0bb0\u0bcb\u0bc8\u0ba4\u0bc8 \u0baa\u0b95\u0bc1\u0bc8\u0bbf\u0baf\u0bbf\u0bb2\u0bcd, \u0b92\u0bb0\u0bc1 \u0baa\u0bb2\u0bcd\u0b95\u0ba4\u0bb2\u0b95\u0bcd\u0b95\u0bb4\u0b95 \u0bae\u0bcb\u0ba3\u0bc8\u0bcb\u0bcd \u0bb9\u0bc7\u0bb7\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u2018\u0b95\u0bc1\u0bb7\u0bcd\u2019 \u0bb9\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0ba4\u0bc8 \u0ba4\u0bc8\u0bc8\u0bcd\u0bc8\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bc8\u0bbf\u0bb1\u0bcd\u0baa\u0ba4\u0bc8 \u0baa\u0bc6\u0baf\u0bcd\u0ba4\u0bc1 \u0bc8\u0bb0\u0bc1\u0bc8\u0bc8\u0bcb\u0b95 \u0bb9\u0baa\u0bb0\u0bcb\u0bc8\u0ba4\u0bc8 \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0ba4\u0bb2\u0baf \u0baa\u0baa\u0bcb\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bc8\u0bbf\u0b95\u0bcb\u0bcb\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0b95\u0bbf\u0ba4\u0b9f\u0bc8\u0bcd\u0bc8 \u0bc8\u0b95\u0bc8\u0bb2\u0bbf\u0bc8\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0b9f\u0baf\u0bbf\u0bb2\u0bcd, 2026.03.07 \u0b85\u0bc8\u0bcd\u0bb1\u0bc1 \u0b87\u0bb0\u0bc8\u0bc1 \u0bb9\u0ba8\u0bb0\u0bc8\u0bcd\u0bc8\u0bbf\u0bb2\u0bcd \u0bb9\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bcb\u0bc8\u0bcd\u0bc8\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb9\u0bc6\u0bcb\u0bc8\u0ba4\u0bc8\u0baf\u0bbf\u0bb2\u0bcd, \u0bb9\u0bc7\u0bb7\u0bcd \u0bb9\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bc8\u0bcd 85 \u0b95\u0bbf\u0bb0\u0bcb\u0bae\u0bcd 260 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0b95\u0bbf\u0bb0\u0bcb\u0bae\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u2018\u0b95\u0bc1\u0bb7\u0bcd\u2019 \u0bb9\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bc8\u0bcd 11 \u0b95\u0bbf\u0bb0\u0bcb\u0bae\u0bcd 210 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0b95\u0bbf\u0bb0\u0bcb\u0bae\u0bcd \u0ba4\u0bc8\u0bc8\u0bcd\u0bc8\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0bc8 \u0bc6\u0ba8\u0bcd\u0bb9\u0bc8\u0b95",
