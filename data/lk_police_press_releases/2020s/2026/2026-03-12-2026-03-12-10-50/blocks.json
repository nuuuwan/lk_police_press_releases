    "text": "\u0ba8\u0baa\u0bb0\u0bcb\u0bc8 \u0bae\u0bcb\u0ba3\u0bc8\u0bcb\u0bcd \u0bb9\u0baa\u0bb0\u0bcb\u0bc8\u0ba4\u0bc8 \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0b85\u0bc8\u0bbf\u0b95\u0bcb\u0bcb\u0bbf\u0b95\u0bc8\u0bcd \u0b95\u0bc1\u0bb4\u0bc1\u0bc8\u0bcb\u0bb2\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bc8\u0bcd\u0bc8\u0bcb\u0bcb\u0bcd. \u0bc6\u0ba8\u0bcd\u0bb9\u0bc8\u0b95\u0ba8\u0baa\u0bcb\u0bcd 23 \u0bc8\u0baf\u0ba4\u0bc1\u0ba4\u0b9f\u0baf\u0bc8\u0bcb\u0bcd; \u0b85\u0bc8\u0bcb\u0bcd \u0bb9\u0bc7\u0bcb\u0b95\u0ba8\u0bcd\u0bc8\u0bb0 \u0baa\u0b95\u0bc1\u0bc8\u0bbf\u0ba4\u0baf\u0bc6\u0bcd \u0bb9\u0bc6\u0bcb\u0bcd\u0ba8\u0bcd\u0bc8\u0bc8\u0bcb\u0bcd \u0b86\u0bc8\u0bcb\u0bcb\u0bcd. \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bc6\u0ba8\u0bcd\u0bb9\u0bc8\u0b95\u0ba8\u0baa\u0bcb\u0bcd \u0b95\u0ba3\u0bcd\u0b9f\u0bbf \u0ba8\u0bbf\u0bc8\u0bbf\u0bc8\u0bcb\u0bc8\u0bcd \u0ba8\u0bc0\u0bc8\u0bbf\u0bae\u0bc8\u0bcd\u0bb1\u0bc8\u0bcd\u0bc8\u0bbf\u0bb2\u0bcd \u0b86\u0b9c\u0bcb\u0bcd\u0baa\u0b9f\u0bc1\u0bc8\u0bcd\u0bc8\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1, 2026.03.12 \u0bc8\u0ba4\u0bb0 05 \u0ba8\u0bcb\u0b9f\u0bcd\u0b95\u0bc8\u0bcd \u0bc8\u0b9f\u0bc1\u0baa\u0bcd\u0baa\u0bc1 \u0b89\u0bc8\u0bcd\u0bc8\u0bb0\u0bc8\u0bc1 \u0baa\u0baa\u0bb1\u0bcd\u0bb1\u0bc1, \u0bb9\u0baa\u0bb0\u0bcb\u0bc8\u0ba4\u0bc8 \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0ba4\u0bb2\u0baf\u0bc8\u0bcd\u0bc8\u0bbf\u0bb2\u0bcd \u0ba4\u0bc8\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb9\u0bae\u0bb2\u0bc8\u0bbf\u0b95 \u0bc8\u0bbf\u0bc6\u0bcb\u0bb0\u0ba4\u0ba3\u0b95\u0bc8\u0bcd \u0bb9\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bcb\u0bc8\u0bcd\u0bc8\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0b95\u0bbf\u0bc8\u0bcd\u0bb1\u0bc8. \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0b8a\u0b9f\u0b95 \u0baa\u0bbf\u0bcb\u0bbf\u0bc8\u0bc1",
