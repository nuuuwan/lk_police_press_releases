    ]
  },
  {
    "page_number": 1,
    "bbox": [
      72.02,
      96.13,
      547.2,
      137.01
    ],
    "text": "On the afternoon of 08.07.2026, a container truck travelling from Avissawella towards Peliyagoda overturned while making a right turn at the Orugodawatte Junction within the Grandpass Police Division, obstructing two lanes of the carriageway between Dematagoda and Peliyagoda.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      72.02,
      151.45,
      556.33,
      178.53
    ],
    "text": "To minimise the resulting traffic congestion, police have implemented traffic diversions for vehicles travelling from Dematagoda to Peliyagoda and from Peliyagoda to Dematagoda.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      72.02,
      193.09,
      556.42,
      220.17
    ],
    "text": "Authorities are taking the necessary measures to clear the obstruction and restore the normal flow of traffic as swiftly as possible.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
