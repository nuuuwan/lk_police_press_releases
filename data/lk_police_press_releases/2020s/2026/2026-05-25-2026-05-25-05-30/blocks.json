    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      195.13,
      515.43,
      236.01
    ],
    "text": "Investigations were initiated by the Gomarankadawala Police Station following a report received on 24.05.2026 regarding the death of a person due to a wild elephant attack in the Ottichchankulam area within the Gomarankadawala Police Division.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      250.48,
      515.38,
      263.76
    ],
    "text": "The deceased has been identified as a 65-year-old resident of the Bakmeegama area.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      278.32,
      522.7,
      305.4
    ],
    "text": "Preliminary investigations have revealed that the deceased had gone to a forested area with a group to collect honey when they encountered a herd of wild elephants.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      319.96,
      505.82,
      360.84
    ],
    "text": "The body has been placed at the Trincomalee Hospital mortuary for post-mortem examination. Further investigations are being conducted by the Gomarankadawala Police.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
