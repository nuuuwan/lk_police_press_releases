    "text": "2026.03.29 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0d9a \u0ddc\u0dc5\u0db9 \u0daf\u0dd2\u0dc3\u0ddc \u0d85\u0db4\u0dbb\u0ddc\u0db0 \u0d9a \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0d9a\u0dda (CCD) \u0dbb\u0dd0\u0db3\u0dc0\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0d9a \u0ddd\u0d9c \u0db8\u0dad \u0dbb\u0db3\u0dc0\u0ddc \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d89\u0dc2\u0ddc\u0dbb\u0ddc \u0d9a\u0dc3\u0dc0\u0dca\u0dc0\u0db1\u0dca\u0daf\u0daf\u0dd2 \u0db1 \u0dc3\u0dd0 \u0ddc\u0dbb\u0dd2 \u0d9a\u0dda \u0d8b\u0db4\u0db1\u0dca\u0daf \u0daf\u0dd2\u0db1 \u0d9a\u0dc0\u0db1\u0dd4\u0d9a\u0dc0\u0db1\u0dca\u0daf \u0d9a \u0ddc\u0dc5\u0db9 \u0d85\u0db4\u0dbb\u0ddc\u0db0 \u0d9a \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0d9a\u0dda\u0daf\u0dd3 \u0d9a\u0dda\u0dda \u0db4\u0ddc \u0dc3\u0ddc\u0daf \u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd6 \u0db6\u0dc0\u0da7 \u0d9a\u0db8\u0dca \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0dc3\u0db8\u0ddc\u0da2 \u0db8\u0ddc\u0db0\u0dba\u0da2\u0ddc\u0dbd\u0ddc \u0d94\u0dc3\u0dda\u0d9a\u0dc3\u0dda \u0db4\u0dd4\u0dc0\u0dad\u0dda \u0dc3\u0d82\u0dc3\u0dbb\u0dab \u0d9a\u0dc0\u0db8\u0dd2\u0db1\u0dca\u0daf \u0db4\u0dc0\u0dad\u0dd3. \u0d9a \u0ddc\u0dc5\u0db9 \u0d85\u0db4\u0dbb\u0ddc\u0db0 \u0d9a \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0d9a\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0daf\u0dd4\u0dd6 \u0db6\u0dc0 \u0d9a\u0dd2 \u0db1 \u0d9a\u0db8\u0db8 \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2 \u0da7 \u0d85\u0daf\u0ddc\u0dbd\u0dc0 \u0dc3\u0dad\u0dba \u0d9a\u0db1\u0ddc\u0dc0\u0db1 \u0dbb\u0dd4\u0dab\u0dd4\u0daf \u0dc3\u0db8\u0ddc\u0da2 \u0db8\u0ddc\u0db0\u0dba\u0d9a\u0dda \u0db4\u0dca\u200d\u0dbb\u0da0\u0ddc\u0dbb \u0dc0\u0dd3\u0db8 \u0db1\u0dd2\u0dbb\u0dd3\u0dda\u0dc2\u0dab \u0dc0\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca\u0daf \u0d9a\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0dc3\u0dad\u0dba \u0dad\u0dad\u0dca\u0dc0\u0dad\u0dca\u0dc0\u0dc0 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0daf\u0db0 \u0dc0\u0ddc\u0dbb\u0dca\u0dad\u0ddc\u0dc0\u0dda \u0d9a \u0ddc\u0dc5\u0db9 \u0daf\u0dd2\u0dc3\u0ddc\u0dc0 \u0db7\u0ddc\u0dbb \u0db1\u0dd2\u0d9a \u0ddd\u0da2\u0dba \u0d9a\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dda\u0db4\u0dad\u0dd2\u0dc0\u0dbb \u0ddc \u0d9a\u0dc0\u0dad\u0dd2\u0db1\u0dca\u0daf \u0dd0\u0db3\u0dc0\u0dd3\u0db8\u0da7 \u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dbb\u0db1 \u0dbd\u0daf \u0d85\u0dad\u0dbb \u0d91\u0db8 \u0dc0\u0ddc\u0dbb\u0dca\u0dad\u0ddc\u0dc0\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0dc4\u0dad \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dbb\u0dd4\u0dab\u0dd4 \u0db4\u0dd0\u0dc4\u0dd0\u0daf\u0dd2\u0dbd\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0d9a\u0dda. \u0d89\u0dc4\u0dad \u0db1\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0db1\u0dca\u0daf \u0dc3\u0dd0 \u0ddc\u0dbb\u0dd2 \u0d9a\u0dda \u0d8b\u0db4\u0db1\u0dca\u0daf\u0daf\u0dd2\u0db1 \u0d9a\u0dc0\u0db1\u0dd4\u0d9a\u0dc0\u0db1\u0dca\u0daf \u0d8b\u0db4\u0db1\u0dca\u0daf\u0daf\u0dd2\u0db1 \u0d9a\u0dda\u0dda \u0dd0\u0db4\u0dd3\u0d9a\u0db8\u0dca \u0dc3\u0dd0\u0dbd\u0dc3\u0dd4\u0db8\u0dda \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0d9a \u0ddc\u0dc5\u0db9 \u0daf\u0dd2\u0dc3\u0ddc\u0dc0 \u0db7\u0ddc\u0dbb \u0db1\u0dd2\u0d9a \u0ddd\u0da2\u0dba \u0d9a\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dda\u0db4\u0dad\u0dd2\u0dc0\u0dbb \u0ddc \u0d9a\u0dc0\u0dad \u0d9a\u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dda \u0dbd\u0dd0\u0db6\u0dd3 \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0\u0dad\u0dca\u0dc0, \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d9a\u0db8\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd2 \u0ddc\u0dc0 \u0dc0\u0dd0\u0dc5\u0dd0\u0dda\u0dc0\u0dd3\u0db8\u0da7 \u0d9a \u0ddc\u0dc5\u0db9 \u0daf\u0dd2\u0dc3\u0ddc\u0dc0 \u0db7\u0ddc\u0dbb \u0db1\u0dd2\u0d9a \u0ddd\u0da2\u0dba \u0d9a\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dda\u0db4\u0dad\u0dd2\u0dc0\u0dbb \u0ddc \u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db1\u0dd2\u0d9a \u0ddd\u0da2\u0dba \u0d9a\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dda\u0db4\u0dad\u0dd2\u0dc0\u0dbb \u0ddc \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca\u0daf \u0dc0\u0ddc\u0dbb\u0dca\u0dad\u0ddc \u0dbb \u0d87\u0dad. \u0db4\u0dc3\u0dd4\u0dc0 \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd6\u0dbd\u0dd2 \u0db4\u0dd2 \u0dc0\u0dbb\u0dda \u0dc0\u0dc1\u0d9a \u0db1\u0dca\u0daf \u0d9a \u0ddc\u0dc5\u0db9 \u0daf\u0dd2\u0dc3\u0ddc \u0d85\u0db4\u0dbb\u0ddc\u0db0 \u0d9a \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0d9a\u0dda \u0dc3\u0dda\u0dae\u0ddc\u0db1\u0ddc\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb \u0ddc \u0d9a\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dda\u0db4\u0dad\u0dd2\u0dad\u0dd4\u0db8\u0ddc\u0d9a\u0dda \u0db1\u0dd2\u0d9a \u0ddd\u0d9c \u0db8\u0dad \u0dc0\u0dc4\u0ddc\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd2 \u0ddc\u0dad\u0dca\u0dc0\u0db8 \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d9a\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dda \u0dda\u0d9a\u0dc2\u0dda\u0dad\u0dca\u200d\u0dbb \u0db6\u0dbd \u0ddc \u0db8\u0dd6\u0dbd\u0dc3\u0dda\u0dae\u0ddc\u0db1 \u0d9a\u0dc0\u0dad \u0dc3\u0dda\u0dae\u0ddc\u0db1 \u0db8\u0ddc\u0dbb\u0dd4 \u0dbb \u0dd0\u0dc0\u0dd3\u0db8\u0da7 \u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dbb \u0d87\u0dad. \u0d9a\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca\u0daf \u0dc3\u0dd1\u0db8 \u0dc0\u0dd2\u0da7\u0db8 \u0dad\u0db8 \u0dc0\u0dd8\u0dad\u0dca\u0dc0\u0dad\u0dd3\u0db8 \u0d86\u0da0\u0ddc\u0dbb\u0db0\u0dbb\u0dca\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0db4\u0dd0\u0daf\u0dd3\u0db8\u0da7 \u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dba\u0dd4\u0dad\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd2 \u0daf\u0dd3 \u0d9a\u0db8\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0daf\u0db0 \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca\u0daf \u0d85\u0dc0\u0dd2\u0dd2\u0db8\u0dad\u0dca\u0dc0 \u0d9a\u0dbd\u0dc3 \u0d9a\u0dca\u200d\u0dbb\u0dd2 \u0ddc \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc4\u0ddc \u0db1\u0dd3\u0dad\u0dba\u0ddc\u0db1\u0dd4\u0d9a\u0dd6\u0dbd \u0d9a\u0db1\u0ddc\u0dc0\u0db1 \u0d85\u0dba\u0dd4\u0dbb\u0dd2\u0db1\u0dca\u0daf \u0da7\u0dba\u0dd4\u0dad\u0dd4