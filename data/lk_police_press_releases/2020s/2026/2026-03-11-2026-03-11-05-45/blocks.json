    ]
  },
  {
    "page_number": 1,
    "bbox": [
      108.02,
      727.48,
      525.74,
      758.84
    ],
    "text": "\u0bc6\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0bb0\u0bc8\u0bca\u0ba4 \u0bae\u0ba4\u0bc1 \u0baa \u0bca\u0bb0\u0bc1\u0b9f\u0bcd\u0b95\u0bb3\u0bc1\u0b9f\u0ba9\u0bcd \u0bc6\u0ba8\u0bcd\u0bb0\u0ba4\u0b95 \u0ba8 \u0bb0\u0bcd \u0bb2\u0b95\u0ba4\u0bc1 \u2013 \u0b9a\u0bbf\u0bc8\u0bca \u0bae\u0bcd \u0b85 \u0bca\u0baf\u0b95\u0bc8 \u0bb0 \u0bca\u0bb2\u0ba4\u0baa\u0bcd \u0baa \u0bca\u0bb0\u0bc1\u0bb3\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1",
    "fonts": [
      "Kavivanar-Regular",
