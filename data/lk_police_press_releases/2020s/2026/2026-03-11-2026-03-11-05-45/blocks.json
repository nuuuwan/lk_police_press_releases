    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      44.94,
      525.93,
      98.38
    ],
    "text": "2026.03.10 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0b95\u0bb2\u0bbf\u0bb2\u0bcd, \u0bb9 \u0bcb\u0bb5\u0ba4\u0bcd\u0bc8 \u0baa \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bb0\u0bb2\u0bc8\u0b9a\u0bae\u0bcd, \u0b87\u0bb2\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0baa\u0bc8\u0ba3\u0bbf\u0baf \u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd, \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0bb2\u0bb0\u0bcb\u0bc8 \u0bae\u0ba4\u0bc1 \u2013 60 \u0bb2\u0bbf\u0b9f\u0bcd\u0b9f\u0bb0\u0bcd (80 \u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd\u0b95\u0bb3\u0bcd) \u0baa\u0b95\u0bcb\u0ba3\u0bcd\u0b9f \u0b9a\u0ba8\u0bcd\u0bb2\u0bc8\u0b95 \u0ba8 \u0bb2\u0bb0 \u0bb2\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bb0\u0bcd.",
    "fonts": [
      "Kavivanar-Regular",
      "Vijaya"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      112.4,
      397.14,
      130.18
    ],
    "text": "\u0b9a\u0ba8\u0bcd\u0bb2\u0bc8\u0b95 \u0ba8 \u0bb0\u0bcd \u0bb5\u0baf\u0ba4\u0bc1 40, \u0b87\u0bb2\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0baa\u0bc8\u0ba3\u0bbf \u0b95\u0bc1\u0ba4\u0bbf\u0bb2\u0baf\u0b9a\u0bcd \u0bb2\u0b9a\u0bb0\u0bcd\u0ba8\u0bc8\u0bb5\u0bb0\u0bcd.",
    "fonts": [
      "Kavivanar-Regular",
      "Vijaya"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      144.2,
      429.45,
      161.98
    ],
    "text": "\u0b9a\u0bbf \u0bcb \u0bae\u0bcd \u0baa \u0bcb\u0bb2\u0bbf\u0b9a\u0bcb\u0bb0\u0bcd \u0bb2\u0bae \u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0bb2\u0bc8\u0b95\u0bb2\u0bb3 \u0ba8\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd.",
    "fonts": [
      "Kavivanar-Regular",
      "Vijaya"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      176.51,
      510.57,
      208.13
    ],
    "text": "Suspect Arrested with Illegal Liquor \u2013 Chilaw Divisional Narcotics Unit",
    "fonts": [
      "TimesNewRomanPS-BoldMT"
    ],
    "sizes": [
      14.039999961853027
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      222.61,
      518.81,
      277.32
    ],
    "text": "On the afternoon of 10.03.2026, a team of officers from the Chilaw Divisional Narcotics Unit conducted a raid in the Ilippadeniya area within the Chilaw Police Division. During the operation, a suspect was apprehended in possession of 60 litres (approximately 80 bottles) of illicit liquor.",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      291.88,
      494.38,
      318.96
    ],
    "text": "The suspect and the seized liquor were subsequently handed over to the Chilaw Police Station for further legal action.",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      333.4,
      421.66,
      346.68
    ],
    "text": "The suspect is a 40-year-old resident of the Ilippadeniya area.",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      361.24,
      424.66,
      374.52
    ],
    "text": "Further investigations are being conducted by the Chilaw Police.",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      388.58,
      527.08,
      640.49
    ],
    "text": "03. \u0dba\u0dad\u0dd4\u0dbb\u0dd4 \u0dd0\u0daf\u0dba\u0d9a\u0dca \u0db6\u0dc3\u0dca \u0dbb\u0dae\u0dba \u0dc4\u0ddc \u0ddc\u0dbb\u0dca \u0dbb\u0dae\u0dba \u0d9c\u0dd0\u0da7\u0dd3 \u0dba\u0dad\u0dd4\u0dbb\u0dd4 \u0dd0\u0daf \u0dbb\u0dd4 \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0d9a\u0dca\u0dc2\u0dca\u200d\u0dba\u0da7 - \u0d9c\u0db8\u0dca \u0dc4 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dd9\u0dc3\u0db8. 2026.03.10 \u0daf\u0dd2\u0db1 \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0d9c\u0dda \u0dc4 \u0dc0 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0dc0\u0dda \u0da2\u0ddc\u0d87\u0dbd \u0d9c\u0dda \u0dc4 \u0db8\u0ddc\u0dbb\u0dca\u0d9c\u0dc0\u0dda\u0daf\u0dd3 \u0d9c\u0dda \u0dc4 \u0dc0\u0daf\u0dc3\u0da7 \u0db0\u0ddc\u0dc0\u0db1\u0dba \u0dc0\u0dd6 \u0dba\u0dd4\u0dbb\u0dd4 \u0dd0\u0daf\u0dd2\u0dba\u0d9a\u0dca \u0db6\u0dc3\u0dca \u0dbb\u0dae\u0dba\u0d9a\u0da7 \u0d89\u0dc3\u0dca\u0dc3\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dba\u0ddc\u0dc0\u0dda\u0daf\u0dd3 \u0dd0\u0daf\u0dd2\u0d9a\u0dbb\u0dd4\u0da7 \u0dba\u0dd4\u0dbb\u0dd4 \u0dd0\u0daf\u0dd2\u0dba \u0ddc\u0dbd\u0db1\u0dba \u0d9a\u0dbb\u0d9c\u0dad \u0dc0\u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2\u0dc0 \u0dc0 \u0dbb\u0dbd\u0dd3\u0dc0\u0d9c\u0ddc\u0dc3\u0dca \u0d91\u0db8 \u0db6\u0dc3\u0dca \u0dbb\u0dae\u0dc0\u0dda \u0dc4\u0ddc \u0dc0\u0dd2\u0dbb\u0dd4\u0dda\u0db0 \u0dc0\u0daf\u0dc3\u0dd2\u0db1\u0dca\u0dad \u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0d9a\u0ddc\u0dbb\u0dca \u0dbb\u0dae\u0dba\u0d9a \u0d9c\u0dd0\u0da7\u0dd3 \u0d85\u0db1\u0dd4\u0dbb\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad. \u0d85\u0db1\u0dd4\u0dbb\u0dd2\u0db1\u0dca\u0dad \u0dba\u0dd4\u0dbb\u0dd4 \u0dd0\u0daf\u0dd2\u0d9a\u0dbb\u0dd4 \u0db6\u0dbb \u0dad\u0dbd \u0dd4\u0dc0\u0ddc\u0dbd \u0dbd\u0db6\u0ddc \u0d9c\u0dda \u0dc4 \u0dc0\u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d87\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0dc0\u0db8\u0db1\u0dca\u0dad \u0dc3\u0dd4 \u0db8\u0dd2\u0dba\u0dc0\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad. \u0db8\u0dbb\u0dab \u0dbb\u0dd4 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 23 \u0d9a\u0dca \u0dc0\u0dd6 \u0d9c\u0db8\u0dca \u0dc4 \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0dca\u200d\u0db4\u0dda \u0daf\u0d82\u0da0\u0dd2 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd2. \u0d85\u0db1\u0dd4\u0dbb \u0dc3\u0dda\u0db6\u0db1\u0dca\u0dad\u0db0\u0dc0\u0dba\u0db1\u0dca\u0dad \u0db6\u0dc3\u0dca \u0dbb\u0dae\u0dc0\u0dda \u0dbb\u0dd2\u0dba\u0dd0\u0daf\u0dd4\u0dbb\u0dd4 \u0dc4\u0ddc \u0d9a\u0ddc\u0dbb\u0dca \u0dbb\u0dae\u0dc0\u0dda \u0dbb\u0dd2\u0dba\u0dd0\u0daf\u0dd4\u0dbb\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0dc0\u0d9c\u0db1 \u0d87\u0dad. \u0d9c\u0dda \u0dc4 \u0dc0 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca\u0dad \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2.",
