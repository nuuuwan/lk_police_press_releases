    "text": "\u0baa\u0b95\u0bca\u0bb2\u0bb2\u0baf\u0bbf\u0ba9\u0bcd \u0b95\u0bca\u0bb0\u0ba3\u0bae\u0bcd \u0b87\u0ba9\u0bcd\u0ba9\u0bc1\u0bae\u0bcd \u0baa\u0bc6\u0bca\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bb2. \u0b95\u0bbf\u0bca\u0bbf\u0ba8\u0bcd\u0bc6\u0bbf\u0baa\u0bb5\u0bb2\u0bcd\u0bb2\u0bb2 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0bb5\u0bae\u0bb2\u0bc6\u0bbf\u0b95 \u0bb5\u0bbf\u0bc6\u0bca\u0bb0\u0bb2\u0ba3 \u0bb5\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd. 02. \u0d85\u0dba\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0dbb\u0dd9\u0dba \u0dc3\u0db8\u0d9f \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0dd2\u0d82\u0d9c\u0dd4\u0dd9\u0da7 - \u0dad\u0dd2\u0d82\u0d9c\u0dbd\u0dca\u0dbd \u0db4 \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3 \u0dc0\u0dd2\u0dc2\u0dca\u200d \u0db8\u0dad\u0dca\u0dbb\u0dd9\u0dba \u0d92 \u0dba. 2026.03.18 \u0daf\u0dd2\u0db1 \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0d85\u0dda\u0db6\u0dbd\u0db1\u0dca\u0db4\u0dad\u0ddc\u0da7 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda \u0db4\u0daf\u0dc4\u0dd2\u0dd9\u0dc4\u0dbd\u0db1\u0dca\u0daf \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0dad\u0d82\u0dd9\u0dbd\u0dca\u0dbd \u0db4\u0d9a\u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3 \u0dc0\u0dd2\u0dc2 \u0db8\u0dad\u0dca\u0dbb\u0dc0\u0dba \u0d92\u0d9a\u0d9a\u0db4\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0ddc\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da7\u0dbd\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb \u0d85\u0dba\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0dbb\u0dc0\u0dba \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0dda 104 \u0dba\u0dd2 \u0db8\u0dd2\u0dbd\u0dd2\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0dda 610 \u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0db4\u0dc0\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\