    "text": "\u0b85\u0ba9\u0bc1\u0bae\u0bc6\u0bbf \u0bcd \u0bc6\u0bcd\u0bc6\u0bbf\u0bb0\u0bae\u0bbf\u0ba9\u0bcd\u0bb1\u0bbf \u0bae\u0ba3\u0bb2\u0bcd \u0b95\u0b9f\u0bc6\u0bcd\u0bc6\u0bbf\u0baf \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0ba8 \u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0bb2\u0b95\u0ba4\u0bc1 \u2013 \u0baa \u0bca\u0b95\u0bb5\u0ba8\u0bcd\u0bc6\u0bb2\u0bca\u0bb2\u0bb5 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0bbf\u0bb0\u0bb5\u0bc6\u0bc6\u0bae\u0bcd 2026.03.18 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bca\u0bb2\u0bb2, \u0baa \u0bca\u0b95\u0bb5\u0ba8\u0bcd\u0bc6\u0bb2\u0bca\u0bb2\u0bb5 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0bbf\u0bb0\u0bb5\u0bc6\u0bc6\u0bae\u0bcd \u0bb5\u0bae\u0bca\u0bb1\u0bca \u0bb5\u0bc6\u0bcd\u0bc6 \u0b95\u0bc1\u0bc6\u0bbf\u0baf\u0bbf\u0bb2\u0bcd, \u0b85\u0ba9\u0bc1\u0bae\u0bc6\u0bbf \u0bcd \u0bc6\u0bcd\u0bc6\u0bbf\u0bb0\u0bae\u0bbf\u0ba9\u0bcd\u0bb1 \u0bae\u0ba3\u0bb2\u0bcd \u0b8e\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bb5 \u0bca\u0ba4\u0bc1 \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0ba8 \u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0baa \u0bca\u0b95\u0bb5\u0ba8\u0bcd\u0bc6\u0bb2\u0bca\u0bb2\u0bb5 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0bb5\u0bc6\u0bca\u0bc6\u0bb2\u0ba9 \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0bb2\u0b95\u0bc6\u0bca\u0b95\u0bbf, \u0b85\u0ba9\u0bc1\u0bae\u0bc6\u0bbf\u0baf\u0bbf\u0ba9\u0bcd\u0bb1\u0bbf \u0bae\u0ba3\u0bb2\u0bcd \u0b8e\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b89 \u0b95\u0bb0\u0ba3\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b9f\u0ba9\u0bcd \u0bb2\u0b95\u0ba4\u0bc1 \u0baa\u0bc6\u0baf\u0bcd\u0baf \u0bcd \u0b9f\u0bcd\u0b9f\u0ba9\u0bca\u0bcd. \u0bc6\u0ba8\u0bcd\u0bb5\u0bc6\u0b95 \u0ba8 \u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0baf\u0ba4\u0bc1 52 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd 59, \u0baa \u0bca\u0b95\u0bb5\u0ba8\u0bcd\u0bc6\u0bb2\u0bca\u0bb2\u0bb5 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb2\u0bca\u0b99\u0bcd\u0baa\u0b95\u0bca\u0b9f \u0bbf\u0bb0\u0bb5\u0bc6\u0bc6\u0bb5\u0bca\u0bc6\u0bbf\u0b95\u0bb3\u0bcd. \u0baa \u0bca\u0b95\u0bb5\u0ba8\u0bcd\u0bc6\u0bb2\u0bca\u0bb2\u0bb5 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0bb5\u0bae\u0bb2\u0bc6\u0bbf\u0b95 \u0bb5\u0bbf\u0bc6\u0bca\u0bb0\u0bb2\u0ba3 \u0bb5\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd. \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0b8a\u0b9f\u0b95 \u0bcd \u0bbf\u0bca\u0bbf\u0bb5\u0bc1",
