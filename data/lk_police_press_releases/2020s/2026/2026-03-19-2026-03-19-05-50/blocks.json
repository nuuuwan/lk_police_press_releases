    "text": "\u0bc6\u0ba8\u0bcd\u0bb5\u0bc6\u0b95 \u0ba8 \u0bca\u0bcd \u0bb5\u0baf\u0ba4\u0bc1 18, \u0b95\u0bb2\u0bcd\u0b95\u0bbf\u0bb2\u0bc6 \u0bbf\u0bb0\u0bb5\u0bc6\u0bc6\u0bc6\u0bcd\u0bc6\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd. \u0b95\u0bb2\u0bcd\u0b95\u0bbf\u0bb2\u0bc6 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0bb5\u0bae\u0bb2\u0bc6\u0bbf\u0b95 \u0bb5\u0bbf\u0bc6\u0bca\u0bb0\u0bb2\u0ba3 \u0ba8\u0b9f\u0bc6\u0bcd\u0ba4\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd. 04. \u0daf\u0db4\u0dda \u0d9c\u0dd2\u0dbd\u0dd3 \u0dc5\u0db8\u0db4\u0dba\u0d9a\u0dd4 \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0d9a\u0dca\u0dc2\u0dca\u200d\u0dba\u0da7 - \u0dc4\u0db6\u0dbb\u0ddc\u0daf\u0dd6\u0dd9 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dd9\u0dc3\u0db8. 2026.03.18 \u0daf\u0dd2\u0db1 \u0daf\u0dc4\u0dc0\u0dbd\u0dca \u0dc4\u0db6\u0dbb\u0ddc\u0daf\u0dd6\u0dc0 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda \u0dc4\u0dd0\u0dac\u0dd2\u0dc0\u0dad\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda \u0db8\u0dd4\u0dc4\u0dd4\u0db4\u0dda \u0dc3\u0dbb\u0dca\u0dd2\u0db1\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0ddc\u0db4\u0dda \u0db4\u0dba\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0dc5\u0db8\u0db4\u0dba\u0d9a\u0dd4 \u0daf\u0dd2\u0db4\u0dda \u0d9c\u0dd2\u0dbd\u0dd3\u0db8 \u0db4\u0dc4\u0dca\u0dad\u0dd4\u0db4\u0dc0\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0dc0\u0ddc\u0dc3\u0dd3\u0db1\u0dca \u0dc4\u0ddc \u0db4\u0dc0\u0dbb\u0dc5 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dda\u0dbb\u0ddc \u0db4\u0dd9\u0db1 \u0d9a\u0dbb\u0ddc\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0db4\u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0db8\u0db1\u0dca \u0dc3\u0dd4 \u0db8\u0dd2\u0dba\u0db4\u0dd9\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0dc4\u0db6\u0dbb\u0ddc\u0daf\u0dd6\