    "text": "\u0db8\u0dbb\u0dab\u0d9a\u0ddc\u0dbb\u0dd2\u0dba \u0db1\u0dd2\u0dc0\u0db4\u0dc3\u0dca \u0dad\u0db1\u0dd2\u0dc0 \u0da2\u0dd3\u0dc0\u0dad\u0dca\u0dc0 \u0dc3\u0dd2\u0da7 \u0d87\u0dad. \u0db4\u0db8\u0db8 \u0d9a\u0ddc\u0db1\u0dca\u0dad\u0ddc\u0dc0\u0db4\u0dda \u0db4\u0dd9\u0db4\u0dbd\u0dc4\u0dd2 \u0db4\u0dbb\u0daf\u0dd2 \u0da7\u0dd2\u0dba\u0d9a\u0dca \u0dc3\u0dc4\u0dd2\u0dad\u0dc0 \u0dc3\u0dc4 \u0d87\u0db4\u0dda \u0d9a\u0dab \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda \u0dad\u0dd4\u0dc0\u0ddc\u0dbd \u0dc3\u0dc4\u0dd2\u0dad\u0dc0 \u0db1\u0dd2\u0dc0\u0db4\u0dc3\u0dc4\u0dd2 \u0dc3\u0dd0\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0db4\u0dbd\u0dc3 \u0db8\u0dd2\u0dba\u0db4\u0dd9\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db1\u0dd2\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0db4\u0db8\u0dba \u0d9d\u0ddc\u0dad\u0db1\u0dba\u0d9a\u0dca \u0db6\u0dc0\u0da7 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc3\u0dd0\u0d9a \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0dc3\u0dd2\u0dda\u0dd2\u0dba \u0dc3\u0dda\u0db6\u0db1\u0dca\u0db0\u0db4\u0dba\u0db1\u0dca \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 61 \u0d9a \u0db4\u0dd4\u0dda\u0dd9\u0dbd\u0db4\u0dba\u0d9a\u0dd4 \u0dc3\u0dd0\u0d9a\u0db4\u0dd2\u0da7 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0db4\u0dd9\u0db1 \u0d87\u0dad. \u0d9d\u0ddc\u0dad\u0db1\u0dba\u0da7 \u0db4\u0dc4\u0dca\u0dad\u0dd4\u0dc0 \u0db4\u0db8\u0db4\u0dad\u0d9a\u0dca \u0d85\u0db1\u0ddc\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0db4\u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d9a\u0dd2\u0dbb\u0dd2\u0db3\u0dd2\u0dc0\u0dd0\u0dbd \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0dba\u0dd2. \u0bae\u0ba9\u0bbf\u0bc6 \u0bcd \u0b9f\u0bc1\u0baa\u0b95\u0bca\u0bb2\u0bb2 \u2013 \u0b95\u0bbf\u0bca\u0bbf\u0ba8\u0bcd\u0bc6\u0bbf\u0baa\u0bb5\u0bb2\u0bcd\u0bb2\u0bb2 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0bbf\u0bca\u0bbf\u0bb5\u0bc1. 2026.03.18 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bca\u0bb2\u0bb2, \u0b95\u0bbf\u0bca\u0bbf\u0ba8\u0bcd\u0bc6\u0bbf\u0baa\u0bb5\u0bb2\u0bcd\u0bb2\u0bb2 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1\u0bb1\u0bcd \u0b9f\u0bcd\u0b9f \u0bb9\u0bbf\u0bb8\u0bcd\u0bb5\u0bb5\u0bb2\u0bcd\u0bb2\u0bb2 \u0b95\u0bc1\u0bc6\u0bbf\u0baf\u0bbf\u0bb2\u0bc1\u0bb3\u0bcd\u0bb3 \u0bb5\u0bc0\u0b9f\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd \u0b92\u0bb0\u0bc1 \u0baa \u0ba3\u0bcd\u0bb2\u0ba3 \u0baa\u0b95\u0bca\u0bb2\u0bb2 \u0baa\u0bc6\u0baf\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bc6\u0bca\u0b95 \u0bc6\u0b95\u0bb5\u0bb2\u0bcd \u0b95\u0bbf\u0bb2\u0b9f\u0bc6\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9. \u0b87\u0bc6\u0ba9\u0bcd \u0b9f\u0bbf \u0b95\u0bbf\u0bca\u0bbf\u0ba8\u0bcd\u0bc6\u0bbf\u0baa\u0bb5\u0bb2\u0bcd\u0bb2\u0bb2 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bca\u0bca\u0bcd \u0bb5\u0bbf\u0bc6\u0bca\u0bb0\u0bb2\u0ba3 \u0ba8\u0b9f\u0bc6\u0bcd\u0bc6 \u0b86\u0bb0\u0bae\u0bcd \u0bbf\u0bc6\u0bcd\u0bc6\u0ba9\u0bca\u0bcd.",
