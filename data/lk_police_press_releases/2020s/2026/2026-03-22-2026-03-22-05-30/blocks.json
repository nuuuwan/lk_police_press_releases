    "text": "\u0db8\u0dbb\u0dab\u0d9a\u0dbb\u0dd4 \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0dba\u0dda\u0d9a\u0dca\u0dd4\u0dbd\u0db8 \u0db4\u0dca\u200d\u0dbb\u0dba\u0dda\u0dc1\u0dba\u0dda \u0dd4\u0db9\u0dd4\u0dbb\u0dd4 \u0dd9\u0dcf\u0dba\u0dda \u0dd0\u0dbd\u0dca \u0dbb\u0dd0\u0d9a\u0dd3\u0db8\u0da7 \u0dad\u0dc0\u0dad\u0dca \u0db4\u0dd4\u0dda\u0d9c\u0dbd\u0dba\u0dd9\u0dd4 \u0dc3\u0db8\u0d9f \u0dd9\u0dad\u0dd4\u0dbb\u0dd4 \u0dd0\u0daf\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dd9\u0daf\u0dd3 \u0dba\u0db8\u0dba\u0dbd\u0dc3 \u0dc0\u0db1 \u0d85\u0dbd\u0dd2 \u0dc4\u0dbb\u0daf\u0dd3\u0db8\u0da7 \u0dbd\u0d9a\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dd9 \u0dc0\u0dd3 \u0d87\u0dad. \u0daf\u0dd2\u0dd9\u0dba\u0db6\u0daf\u0dd4\u0db8 \u0dba \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dd9 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0b95\u0bca\u0b9f\u0bcd\u0b9f\u0bc1 \u0baf\u0bca\u0b95\u0ba9 \u0ba4\u0bca\u0b95\u0bcd\u0b95\u0bbf\u0baf\u0ba4\u0bbf\u0bb2\u0bcd \u0b92\u0bb0\u0bc1\u0bb5\u0bca\u0bcd \u0b89\u0baf\u0bbf\u0bca\u0bbf\u0bb4\u0baa\u0bcd\u0baa\u0bc1 \u2013 \u0ba4\u0bbf\u0baf\u0baa\u0baa\u0ba4\u0bc1\u0bae\u0bca \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1 2026.03.21 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bca\u0b95\u0bb2, \u0ba4\u0bbf\u0baf\u0baa\u0baa\u0ba4\u0bc1\u0bae \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f, \u0ba4\u0b95\u0bca\u0ba4\u0bc1\u0bb0\u0bc1\u0bb5\u0bca\u0bb5 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b92\u0bb0\u0bc1\u0bb5\u0b95\u0bb0 \u0b95\u0bca\u0b9f\u0bcd\u0b9f\u0bc1 \u0baf\u0bca\u0b95\u0ba9 \u0ba4\u0bca\u0b95\u0bcd\u0b95\u0bbf\u0baf\u0ba4\u0bc1\u0bb2\u0bcd \u0ba4\u0bbf\u0baf\u0baa\u0baa\u0ba4\u0bc1\u0bae \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bae\u0b95\u0ba9\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1, \u0ba4\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bc6\u0bbf\u0b95\u0bbf\u0bc6\u0bcd\u0b95\u0bc6\u0b95\u0bcd\u0b95\u0bca\u0b95 \u0baa\u0baa\u0bca\u0bb2\u0ba9\u0bcd\u0ba9\u0bb1\u0bc1\u0b95\u0bb5 \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bae\u0b95\u0ba9\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4 \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0bca\u0bcd \u0b89\u0baf\u0bbf\u0bca\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bca\u0b95 \u0ba4\u0bbf\u0baf\u0baa\u0baa\u0ba4\u0bc1\u0bae \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0b95\u0bb2\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0b95\u0bbf\u0b95\u0b9f\u0ba4\u0bcd\u0ba4 \u0ba4\u0b95\u0bb5\u0bb2\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0b95\u0b9f\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0bc6\u0bca\u0bb0\u0b95\u0ba3 \u0b86\u0bb0\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0bae\u0bb0\u0ba3\u0bae\u0b95\u0b9f\u0ba8\u0bcd\u0ba4\u0bb5\u0bca\u0bcd \u0bb5\u0baf\u0ba4\u0bc1 61, \u0b85\u0ba4\u0bcd\u0ba4\u0ba9\u0b95\u0b9f\u0bb5\u0bb2 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0b95\u0baf\u0bc6\u0bcd \u0ba4\u0bc6\u0bca\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bca\u0bcd.",
