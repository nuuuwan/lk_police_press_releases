    "text": "\u0b87\u0bb0\u0bb5\u0bbf\u0bb2\u0bcd \u0baa\u0baa\u0b95\u0bcd\u0b95\u0bc1\u0bb3\u0bae \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 \u0baa\u0ba8\u0bb2\u0bcd \u0bb5\u0baf\u0bb2\u0bcd\u0b95\u0b95\u0bb3\u0baa\u0bcd \u0baa\u0bca\u0ba4\u0bc1\u0b95\u0bca\u0baa\u0bcd\u0baa\u0ba4\u0bb1\u0bcd\u0b95\u0bca\u0b95 \u0bae\u0bb1\u0bcd\u0baa\u0bb1\u0bca\u0bb0\u0bc1\u0bb5\u0bb0\u0bc1\u0b9f\u0ba9\u0bcd \u0ba4\u0bae\u0bca\u0b9f\u0bcd\u0b9f\u0bca\u0bca\u0bcd \u0b95\u0bc6\u0b95\u0bcd\u0b95\u0bbf\u0bb3\u0bbf\u0bb2\u0bcd \u0baa\u0bc6\u0ba9\u0bcd\u0bb1\u0bc1\u0baa\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0ba4\u0baa\u0bca\u0ba4\u0bc1 \u0b95\u0bca\u0b9f\u0bcd\u0b9f\u0bc1 \u0baf\u0bca\u0b95\u0ba9 \u0ba4\u0bca\u0b95\u0bcd\u0b95\u0bbf\u0baf\u0ba4\u0bca\u0b95 \u0bb5\u0bbf\u0bc6\u0bca\u0bb0\u0b95\u0ba3\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0ba4\u0bca\u0bbf\u0baf\u0bb5\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
