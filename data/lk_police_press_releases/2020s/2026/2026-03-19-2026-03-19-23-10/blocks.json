    ],
    "text": "\u0da0\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0da0 \u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba. \u0b93\u0b95\u0bcd\u0bb8\u0bcd\u0b83\u0baa \u0bcb\u0bcb\u0bcd\u0b9f\u0bc1 \u0b9a\u0bc6\u0bb8\u0bcd\u0b9f\u0bcb\u0bcd \u0b89\u0baf\u0bcb\u0bcd\u0b95\u0bb2\u0bcd\u0bb5\u0bbf \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd 75 \u0bae\u0bc1\u0bb4\u0bc1 \u0bc1\u0bb2\u0bae\u0bc8 \u0bcb\u0bbf\u0bc6\u0bbf\u0bb2\u0bcd \u0ba8\u0bbf\u0ba4\u0bbf\u0baf\u0bc1\u0ba4\u0bb5\u0bbf \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0ba4\u0bc1 \u0b87\u0bb2\u0b99\u0bcd\u0bae\u0b95\u0baf\u0bbf\u0ba9\u0bcd \u0bc8\u0bcb\u0ba3\u0bb5\u0bcb\u0bcd \u0ba4\u0bae\u0bb2\u0bae\u0bc1\u0bae\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0b95\u0bb2\u0bcd\u0bb5\u0bbf \u0b95\u0ba9\u0bb5\u0bc1\u0b95\u0bae\u0bc8 \u0ba8\u0ba9\u0bb5\u0bcb\u0b95\u0bcd\u0b95\u0bc1\u0bc8\u0bcd \u0baa\u0ba8\u0bcb\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd, \u0b93\u0b95\u0bcd\u0bb8\u0bcd\u0b83\u0baa \u0bcb\u0bcb\u0bcd\u0b9f\u0bc1 \u0b9a\u0bc6\u0bb8\u0bcd\u0b9f\u0bcb\u0bcd \u0b89\u0baf\u0bcb\u0bcd\u0b95\u0bb2\u0bcd\u0bb5\u0bbf \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bc8\u0bcd (OCU) 2026.03.19 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 75 \u0bae\u0bc1\u0bb4\u0bc1 \u0bc1\u0bb2\u0bae\u0bc8 \u0bcb\u0bbf\u0bc6\u0bbf\u0bb2\u0bcd \u0ba8\u0bbf\u0ba4\u0bbf\u0baf\u0bc1\u0ba4\u0bb5\u0bbf\u0b95\u0bae\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0ba4\u0bc1. \u0b87\u0ba8\u0bcd \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bc1, \u0b95\u0b99\u0bcd\u0b95\u0bcb\u0bb0\u0bcb\u0bc8 \u0bb5\u0bbf\u0b95\u0bcb\u0bb0\u0bcb\u0ba4\u0bbf \u0ba4\u0bbf \u0bb5\u0ba3\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bc8\u0bbf\u0baf \u0b95\u0bbf\u0bcb\u0bbf\u0ba8\u0bcd\u0baa\u0ba4 \u0b85\u0bb8\u0bcd\u0bb8\u0b9c\u0bbf \u0b85\u0bb5\u0bcb\u0bcd\u0b95\u0bc8\u0bbf\u0ba9\u0bcd \u0bbf\u0bc8\u0ba8\u0bcd\u0ba4 \u0ba8\u0bcb\u0bae\u0bc8 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1, \u0b85\u0bb5\u0bcb\u0bcd\u0b95\u0bc8\u0ba4\u0bc1 \u0baa\u0ba8\u0bb0\u0b9f\u0bbf \u0bb5\u0bb4\u0bbf\u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bb2\u0bbf\u0bb2\u0bc1\u0bc8\u0bcd, \u0bc6\u0bbf\u0bc8 \u0bcd \u0bcb\u0ba9 \u0b95\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bc8\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf \u0bcd \u0bae\u0b9f\u0baf\u0bbf\u0bb2\u0bc1\u0bc8\u0bcd \u0b8f\u0bc8\u0bcd \u0bcb\u0b9f\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf \u0bcd \u0b9f\u0bcd\u0b9f\u0ba4\u0bc1. \u0b9a \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd\u0bc8\u0bcb \u0b85\u0ba4\u0bbf \u0bcb\u0bcd \u0b85\u0bb5\u0bcb\u0bcd\u0b95\u0bc8\u0bbf\u0ba9\u0bcd \u0b99\u0bcd\u0baa\u0b95\u0bc8\u0bcd \u0bc1\u0b9f\u0ba9\u0bcd, \u0b87\u0ba8\u0bcd \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bc1 \u0b9a \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0ba4\u0bae\u0bb2\u0bae\u0bc8\u0baf\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b86\u0bb0\u0bc8\u0bcd \u0bbf\u0b95\u0bcd\u0b95 \u0bcd \u0b9f\u0bcd\u0b9f\u0ba4\u0bc1. \u0b85\u0ba4\u0bc8\u0bcd\u0b95\u0bcb\u0b95 \u0b9a \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bc6\u0bae\u0bb5 \u0bb5\u0ba9\u0bbf\u0bae\u0ba4\u0baf\u0bcb\u0bcd \u0bbf\u0bcb\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0ba4\u0bae\u0bb2\u0bb5\u0bcb\u0bcd, \u0bc6\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bb0\u0ba3\u0bbf \u0ba8\u0bbf\u0bb2\u0bcd\u0bc8\u0bbf\u0ba9\u0bbf \u0ba8\u0bc0\u0b9f\u0bcd\u0b9f\u0bcb \u0bc6\u0bc8\u0bb0\u0ba4\u0bc1\u0b99\u0bcd\u0b95 \u0b85\u0bb5\u0bcb\u0bcd\u0b95\u0bb3\u0bc1\u0bc8\u0bcd \u0b99\u0bcd\u0baa\u0b95\u0bc8\u0bcd\u0bc8\u0ba9\u0bcb\u0bcd. \u0b87\u0ba8\u0bcd\u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bbf\u0bb2\u0bcd, \u0ba8\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0bc8\u0bcd\u0b95\u0bcb\u0b95 \u0b85\u0bcb\u0bcd \u0bcd \u0ba3\u0bbf \u0bcd \u0bcb\u0ba9 \u0baa\u0bc6\u0bae\u0bb5\u0bae\u0baf \u0b9a\u0bc6\u0baf\u0bcd\u0ba4 \u0b9a \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bcb\u0bcb\u0bbf\u0b95\u0bc8\u0bbf\u0ba9\u0bcd \u0b95\u0bc1\u0bb4\u0ba8\u0bcd\u0bae\u0ba4\u0b95\u0bc8\u0bcd \u0bc8\u0bc8\u0bcd\u0bb1\u0bc1\u0bc8\u0bcd \u0b9a \u0bcb\u0bb0\u0bc1\u0bc8\u0bcb\u0ba4\u0bcb\u0bb0 \u0bc6\u0bbf\u0bb0\u0bc8\u0b99\u0bcd\u0b95\u0bae\u0bc8 \u0b8e\u0ba4\u0bbf\u0bcb\u0bcd\u0b9a\u0b95\u0bcb\u0ba3\u0bcd\u0b9f\u0bc1 \u0b95\u0bb2\u0bcd\u0bb5\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0baa\u0ba9\u0bb1\u0bc1\u0bc8\u0bcd \u0ba4\u0bbf\u0bc8\u0bae\u0bc8\u0baf\u0bcb\u0ba9 \u0bc8\u0bcb\u0ba3\u0bb5\u0bcb\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b9a\u0b95\u0bc8\u0bb0\u0bb5\u0bc8\u0bcb\u0b95 \u0b87\u0ba4\u0bcd \u0ba4\u0bbf\u0b9f\u0bb5\u0bbf\u0baf\u0bb2\u0bcd \u0ba8\u0bbf\u0ba4\u0bbf\u0baf\u0bc1\u0ba4\u0bb5\u0bbf \u0bb5\u0bb4\u0b99\u0bcd\u0b95 \u0bcd \u0b9f\u0bcd\u0b9f\u0ba4\u0bc1. \u0b87\u0ba8\u0bcd\u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bbf\u0bb2\u0bcd, \u0b87\u0bb2\u0b99\u0bcd\u0bae\u0b95 \u0b95\u0bb2\u0bcd\u0bb5\u0bbf \u0ba4\u0bc1\u0bae\u0bc8\u0bae\u0baf \u0bc6\u0bcb\u0bcd\u0bb5\u0baa\u0ba4\u0bc6 \u0ba4\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0ba8\u0bbf\u0bae\u0bb2\u0ba8\u0bbf\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0bb5\u0bc1\u0bc8\u0bcd, \u0bc8\u0bcb\u0ba3\u0bb5\u0bcb\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0ba4\u0bae\u0bb5\u0baf\u0bcb\u0ba9 \u0b86\u0ba4\u0bb0\u0bae\u0bb5 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bb5\u0bc1\u0bc8\u0bcd, \u0b95\u0bb2\u0bcb\u0ba8\u0bbf\u0ba4\u0bbf \u0ba4\u0bc1\u0bb2\u0bcb\u0ba9\u0bcd \u0b9a\u0bc6\u0b9f\u0bcd\u0b9f\u0bbf \u0b86\u0bb0\u0bc6\u0bcd\u0bc6\u0bbf \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0bc6\u0bbf\u0bc8 \u0bcd \u0bc1 \u0b99\u0bcd\u0b95\u0bc8\u0bbf \u0bcd \u0bc1\u0bc8\u0bcd \u0bcb\u0bb0\u0bcb\u0b9f\u0bcd\u0b9f \u0bcd \u0b9f\u0bcd\u0b9f\u0ba4\u0bc1. \u0bb5\u0ba3\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bc8\u0bbf\u0baf \u0b85\u0bb8\u0bcd\u0bb8\u0b9c\u0bbf \u0bb5\u0bb4\u0bbf\u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bb2\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf \u0bcd \u0bae\u0b9f\u0baf\u0bbf\u0bb2\u0bcd, \u0b93\u0b95\u0bcd\u0bb8\u0bcd\u0b83\u0baa \u0bcb\u0bcb\u0bcd\u0b9f\u0bc1 \u0b9a\u0bc6\u0bb8\u0bcd\u0b9f\u0bcb\u0bcd \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bc8\u0bcd \u0b9a\u0bc6\u0baf\u0bb2\u0bcd \u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bc8\u0bcd \u0b87\u0ba8\u0bcd\u0ba4 \u0bc6\u0bae\u0bc2\u0b95 \u0baa\u0bc6\u0bae\u0bb5, \u0ba8\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0ba9\u0bcd \u0b8e\u0ba4\u0bbf\u0bcb\u0bcd\u0b95\u0bcb\u0bb2 \u0ba4\u0bae\u0bb2\u0bae\u0bc1\u0bae\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0b95\u0bb2\u0bcd\u0bb5\u0bbf \u0b89\u0bcb\u0bbf\u0bae\u0bc8\u0b95\u0bae\u0bc8 \u0bcb\u0ba4\u0bc1\u0b95\u0bcb\u0b95\u0bcd\u0b95\u0bc1\u0bc8\u0bcd \u0bb5\u0bbf\u0ba4\u0bc8\u0bcb\u0b95\u0bc1\u0bc8\u0bcd. \u0baa\u0bc8\u0bb2\u0bcd \u0bc8\u0bcb\u0b95\u0bcb\u0ba3\u0ba4\u0bcd\u0ba4\u0bbf\u0bc8\u0bcd\u0b95\u0bc1 \u0bcd \u0b9a \u0bcb\u0bb1\u0bc1 \u0bcd \u0bcb\u0ba9 \u0b86\u0bb3\u0bc1\u0ba8\u0bcb\u0bcd \u0b9a\u0b95\u0bcc\u0bb0\u0bb5 \u0bc6\u0ba9\u0bc0\u0bb8\u0bcd \u0baf\u0bc2\u0bc6 \u0bcd, \u0baa\u0bc8\u0bb2\u0bcd \u0bc8\u0bcb\u0b95\u0bcb\u0ba3 \u0b95\u0bb2\u0bcd\u0bb5\u0bbf\u0bc6\u0bcd \u0b9a\u0bc6\u0baf\u0bb2\u0bcb\u0bc8\u0bcb\u0bcd \u0bb5\u0ba9\u0ba9\u0bcd \u0b9a \u0baa\u0bb0\u0bb0\u0bcb \u0b85\u0bb5\u0bcb\u0bcd\u0b95\u0bc8\u0bcd, \u0bc6\u0bbf\u0baa\u0bb0\u0bb7\u0bcd\u0b9f \u0bcd \u0bbf\u0bb0\u0ba4\u0bbf \u0bcd \u0b9a \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd\u0bc8\u0bcb \u0b85\u0ba4\u0bbf \u0bcb\u0bcd \u0ba8\u0bbf\u0bb0\u0bc1\u0bb5\u0bcb\u0b95\u0bc8\u0bcd \u0bc6\u0b9e\u0bcd\u0bc6\u0bc0\u0bb5 \u0ba4\u0bcb\u0bcd\u0bc8\u0bb0\u0ba4\u0bcd\u0ba9, \u0bbf\u0bcb\u0bbf\u0ba4\u0bbf \u0bcd \u0b9a \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd\u0bc8\u0bcb \u0b85\u0ba4\u0bbf \u0bcb\u0bcd \u0b9a \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0ba4\u0bae\u0bb2\u0bae\u0bc8\u0baf\u0b95\u0bc8\u0bcd \u0ba8\u0bcb\u0bb2\u0b95 \u0bc6\u0bbf\u0bb2\u0bcd\u0bb5\u0bcb \u0b89\u0b9f\u0bcd \u0b9f \u0bb2\u0bcb\u0bcd \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1\u0b9a\u0b95\u0bcb\u0ba3\u0bcd\u0b9f\u0ba9\u0bcb\u0bcd. \u0b9a \u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0b8a\u0b9f\u0b95 \u0bcd \u0bbf\u0bcb\u0bbf\u0bb5\u0bc1",
    "fonts": [
      "IskoolaPota-Bold",
      "Kavivanar-Regular"
    ],
    "sizes": [
      12.0,
      14.039999961853027
    ]
  }
]