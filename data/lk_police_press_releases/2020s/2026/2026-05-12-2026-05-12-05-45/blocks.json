    ]
  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      269.8,
      504.54,
      310.68
    ],
    "text": "On 11 May 2026, officers attached to the Galle Police Station carried out two coordinated raids in the Galwadugoda and Sri Sumedha Mawatha areas within the Galle Police Division.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      325.24,
      507.26,
      352.32
    ],
    "text": "During the operations, 110 Indian nationals residing in two lodging establishments were arrested on suspicion of offences under the Computer Crimes Act.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      366.88,
      347.11,
      380.16
    ],
    "text": "The suspects are between 19 and 35 years of age.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      394.6,
      518.0,
      421.7
    ],
    "text": "Authorities also took into custody 58 computers and 79 mobile phones found in their possession.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
