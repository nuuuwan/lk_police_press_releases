    "text": "\u0dcf\u0daf\u0dd4\u0d9a\u0dca\u0d9a \u0dba \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf\u0baf\u0bbf\u0ba9\u0bcd\u0bb1\u0bbf \u0bae\u0bca\u0b9f\u0bcd\u0b9f\u0bc1 \u0b87\u0bb2\u0bb1\u0b9a\u0bcd\u0b9a\u0bbf\u0b95\u0bcd \u0b95\u0bc2\u0b9f\u0bae\u0bcd \u0bc7\u0b9f\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd 3 \u0b9a\u0bc7\u0bcd\u0ba8\u0ba4\u0b95\u0bc7\u0baa\u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0bb2\u0b95\u0ba4\u0bc1 -\u0ba8\u0bb9\u0bca\u0bae\u0bca\u0b95\u0bae \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbf\u0baf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0bb2\u0bc8\u0baa\u0bcd \u0baa\u0bc8\u0bbf\u0baf\u0b95\u0bae\u0bcd. 2026.03.26 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0baa\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0b85\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bb5\u0ba4\u0bcd\u0ba4 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0ba8\u0bb9\u0bca\u0bae\u0bca\u0b95\u0bae \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd\u0baa\u0bc1\u0bb2\u0ba9\u0bca\u0baf\u0bcd\u0bb5\u0bc1 \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1 \u0b85\u0ba4\u0bbf\u0b95\u0bca\u0bca\u0bbf\u0b95\u0bb3\u0bcd \u0bc7\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0ba8\u0b9a\u0bca\u0ba4\u0bb2\u0ba9\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf\u0baf\u0bbf\u0ba9\u0bcd\u0bb1\u0bbf \u0bae\u0bca\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bcd \u0baa\u0b95\u0bca\u0bb2\u0bb2\u0b9a\u0bcd\u0b9a\u0bca\u0bb2\u0bb2 \u0bc7\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf \u0bb5\u0bc7\u0bcd\u0ba4\u0ba4\u0bb1\u0bcd\u0b95\u0bc1\u0bae\u0bcd, \u0bae\u0bbf\u0bb0\u0bc1\u0b95\u0b99\u0bcd\u0b95\u0bb2\u0bb3 \u0baa\u0b95\u0bca\u0b9f\u0bc1\u0bb2\u0bae\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0ba4\u0bb1\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bca\u0b95 \u0bae\u0bc2\u0bb5\u0bca\u0bcd \u0bb2\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0baa\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0bc7\u0bbf\u0bb2\u0bb2\u0baf\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b92\u0baa\u0bcd\u0baa\u0bb2\u0b9f\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bca\u0bcd. \u0b9a\u0bc7\u0bcd\u0ba8\u0ba4\u0b95\u0bc7\u0baa\u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0baf\u0ba4\u0bc1 33, 34 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd 42 \u0b86\u0b95\u0bc1\u0bae\u0bcd; \u0baa\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0ba4\u0bb9\u0bbf\u0ba8\u0baf\u0bca\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bb5\u0b9a\u0bbf\u0baa\u0bcd\u0baa\u0bb5\u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0b86\u0bb5\u0bca\u0bcd. \u0baa\u0b95\u0bca\u0bb2\u0bb2 \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0b95\u0bcd \u0baa\u0b95\u0bca\u0bc8\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b87\u0bb0\u0bc8\u0bcd\u0b9f\u0bc1 \u0bae\u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bcd, \u0baa\u0baf\u0ba9\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0baa\u0b95\u0bca\u0b9f\u0bc1\u0bb5\u0bca\u0bb3\u0bcd, \u0b87\u0bb0\u0bc8\u0bcd\u0b9f\u0bc1 \u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bca\u0b9f\u0bc1\u0b95\u0bb2\u0bb3 \u0b95\u0b9f\u0ba4\u0bcd\u0ba4 \u0baa\u0baf\u0ba9\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0bb2\u0bca\u0bca\u0bbf \u0bb5\u0bca\u0b95\u0ba9\u0bae\u0bcd \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0bb2\u0b95\u0baa\u0bcd\u0baa\u0bb1\u0bcd\u0bb1\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0baa\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0ba8\u0baa\u0bca\u0bb2\u0bc0\u0b9a\u0bca\u0bca\u0bcd \u0ba8\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0bb2\u0bc8\u0b95\u0bb2\u0bb3 \u0ba8\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0bc8\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd.",
