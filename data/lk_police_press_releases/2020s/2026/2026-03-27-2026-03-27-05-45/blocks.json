    "text": "\u0db8\u0dbb\u0dab\u0d9a\u0dbb\u0dd4 \u0dad\u0db8 \u0db4\u0dd2\u0dba\u0dcf \u0dc3\u0db8\u0d9f \u0db1\u0dd2\u0dc0\u0dba\u0dc3\u0dca \u0db8\u0dad\u0dca \u0dd0\u0db1\u0dca \u0dcf\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0d87\u0dad\u0dd2 \u0dc0\u0dd6 \u0d86\u0dbb\u0dc0\u0dd4\u0dbd\u0d9a\u0dca \u0db8\u0dad \u0db4\u0dd2\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dba \u0dcf\u0dbb\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0dc4\u0dbb\u0daf\u0dd3 \u0dba\u0db8\u0db8 \u0d9d\u0dcf\u0dad\u0db1\u0dba \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0daf\u0dd0\u0db1\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0d87\u0dad. \u0db8\u0dd8\u0dad \u0dc1\u0dbb\u0dd3\u0dbb\u0dba \u0db8\u0dba\u0dc4\u0dca\u0dc3\u0dca\u0dbb\u0dcf\u0dad\u0dca \u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dca\u200d\u0dab\u0dba\u0dba\u0db1\u0dca \u0dc3\u0dd4 \u0dc1\u0dca\u0da0\u0dcf\u0dad\u0dca \u0db8\u0dbb\u0dab \u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dca\u200d\u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d86\u0dab\u0db8\u0da9\u0dd4\u0dc0 \u0dba\u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0dbb\u0dd0\u0dba\u0dd9\u0db1 \u0dba\u0dcf\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba\u0dd2. \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 63 \u0d9a\u0dca \u0dc0\u0db1 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0dba\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db8\u0dc4\u0d9a\u0dd4\u0db9\u0dd4\u0d9a\u0dca\u0d9a\u0da9\u0dc0\u0dbd \u0dba \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0bae\u0ba9\u0bbf\u0ba4\u0b95\u0bcd \u0baa\u0b95\u0bca\u0bb2\u0bb2 \u2013 \u0bae\u0bb9\u0b95\u0bc1\u0bae\u0bcd\u0baa\u0bc1\u0b95\u0bcd\u0b95\u0b9f\u0bb5\u0bb2 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1. 2026.03.26 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0b87\u0bb0\u0bb5\u0bc1 \u0ba8\u0bc7\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bae\u0bb9\u0b95\u0bc1\u0bae\u0bcd\u0baa\u0bc1\u0b95\u0bcd\u0b95\u0b9f\u0bb5\u0bb2 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0baa\u0b9a\u0bca\u0baa\u0bb9\u0bca\u0ba9\u0bcd\u0b95\u0bb2\u0bcd\u0bae \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0b9f\u0bae\u0bcd\u0baa\u0baa\u0bb1\u0bcd\u0bb1 \u0bae\u0ba9\u0bbf\u0ba4\u0b95\u0bcd \u0baa\u0b95\u0bca\u0bb2\u0bb2 \u0b9a\u0bae\u0bcd\u0baa\u0bb5\u0bae\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0baa\u0bca\u0b95 \u0bae\u0bb9\u0b95\u0bc1\u0bae\u0bcd\u0baa\u0bc1\u0b95\u0bcd\u0b95\u0b9f\u0bb5\u0bb2 \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0bc7\u0bbf\u0bb2\u0bb2\u0baf\u0bae\u0bcd \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0bb2\u0bc8\u0b95\u0bb2\u0bb3 \u0b86\u0bb0\u0bae\u0bcd\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0b87\u0bb1\u0bc7\u0bcd\u0ba4\u0bb5\u0bca\u0bcd \u0bb5\u0baf\u0ba4\u0bc1 26 \u0b86\u0b95\u0bc1\u0bae\u0bcd; \u0baa\u0b9a\u0bca\u0baa\u0bb9\u0bca\u0ba9\u0bcd\u0b95\u0bb2\u0bcd\u0bae \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0b9a\u0bbf\u0ba4\u0bcd\u0ba4\u0bb5\u0bca\u0bcd \u0b86\u0bb5\u0bca\u0bca\u0bcd. \u0b87\u0bb1\u0bc7\u0bcd\u0ba4\u0bb5\u0bca\u0bcd \u0ba4\u0ba9\u0ba4\u0bc1 \u0ba4\u0bc7\u0bcd\u0bb2\u0ba4\u0baf\u0bc1\u0b9f\u0ba9\u0bcd \u0bb5\u0bc0\u0b9f\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd \u0bae\u0ba4\u0bc1\u0baa\u0bca\u0ba9\u0bae\u0bcd \u0b85\u0bb0\u0bc1\u0bc7\u0bcd\u0ba4\u0bbf\u0b95\u0bcd \u0baa\u0b95\u0bca\u0bc8\u0bcd\u0b9f\u0bbf\u0bb0\u0bc1\u0bc7\u0bcd\u0ba4\u0ba8\u0baa\u0bca\u0ba4\u0bc1 \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0ba4\u0b95\u0bb0\u0bca\u0bb1\u0bc1 \u0b95\u0bca\u0bb0\u0bc8\u0bae\u0bca\u0b95, \u0ba4\u0bc7\u0bcd\u0bb2\u0ba4 \u0baa\u0b95\u0bca\u0b9f\u0bc1\u0bb5\u0bca\u0bb3\u0bca\u0bb2\u0bcd \u0ba4\u0bca\u0b95\u0bcd\u0b95\u0bbf \u0b87\u0b95\u0bcd\u0baa\u0b95\u0bca\u0bb2\u0bb2 \u0baa\u0b9a\u0baf\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bca\u0b95 \u0b86\u0bb0\u0bae\u0bcd\u0baa \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0ba4\u0bca\u0bbf\u0baf\u0bb5\u0bc7\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0bae\u0bb0\u0bc8\u0bae\u0bb2\u0b9f\u0bc7\u0bcd\u0ba4\u0bb5\u0bca\u0bbf\u0ba9\u0bcd \u0b89\u0b9f\u0bb2\u0bcd \u0bc7\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1 \u0bb5\u0bbf\u0b9a\u0bca\u0bb0\u0bb2\u0bc8\u0b95\u0bcd\u0b95\u0bc1\u0baa\u0bcd \u0baa\u0bbf\u0ba9\u0bcd \u0b89\u0b9f\u0bb1\u0bcd\u0b95\u0bc2\u0bb1\u0bc1 \u0baa\u0bca\u0bbf\u0ba8\u0b9a\u0bca\u0ba4\u0bb2\u0ba9\u0b95\u0bcd\u0b95\u0bca\u0b95 \u0b86\u0ba9\u0bae\u0b9f\u0bc1\u0bb5 \u0bb2\u0bb5\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9a\u0bca\u0bb2\u0bb2\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0ba9\u0bc1\u0baa\u0bcd\u0baa\u0baa\u0bcd\u0baa\u0b9f \u0b89\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
