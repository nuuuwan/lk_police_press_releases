    "text": "\u0db0\u0dcf\u0dc0\u0db1\u0dba\u0da7 \u0db1\u0dd4\u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4 \u0dc0\u0dcf\u0dc4\u0db1 \u0db4\u0dbb\u0dd2\u0d9a\u0dca\u0dc2\u0dcf \u0d9a\u0dd2\u0dbb\u0dd2\u0db8\u0dda \u0dc0\u0dd2\u0db8 \u0dda\u0dc2 \u0db8\u0dd9\u0db8\u0dc4\u0dba\u0dd4\u0dd9\u0d9a\u0dca - \u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0db8\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dda \u0dc0\u0dc3\u0dd9. 2026.02.25 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda \u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0db8\u0ddc\u0dbb\u0dca\u0d9c\u0db4\u0dda \u0dc4\u0d9c\u0dca\u0d9c\u0dbd \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0dc4\u0ddc \u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0d8b\u0da9\u0dd4\u0db4\u0dd4\u0dc3\u0dca\u0dc3\u0dd0\u0dbd\u0dca\u0dbd\u0ddc\u0dc0 \u0db8\u0ddc\u0dbb\u0dca\u0d9c\u0db4\u0dda \u0db4\u0db6\u0ddc\u0dbb\u0dbd\u0db1\u0dca\u0daf \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0db4\u0dda \u0db1\u0dd2\u0dc5\u0db0\u0ddc\u0dbb\u0dd2\u0db1\u0dca \u0dc4\u0ddc \u0db4\u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae \u0db4\u0dca\u200d\u0dbb\u0dc0\u0ddc\u0dc4\u0db1 \u0db4\u0daf \u0ddc\u0dbb\u0dca\u0dad\u0db4\u0dda\u0db1\u0dca\u0dd4\u0db4\u0dda \u0db1\u0dd2\u0dc5\u0db0\u0ddc\u0dbb\u0dd2\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0ddc\u0dba\u0db8\u0d9a\u0dca \u0d91\u0d9a\u0dca\u0dc0 \u0dc0\u0ddc\u0dc4\u0db1 \u0dbb\u0dd2\u0d9a\u0dca\u0dc2\u0ddc \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0dda \u0dc0\u0dd2\u0db4\u0dc1\u0dca\u0dc2 \u0db4\u0db8\u0db4\u0dc4\u0dba\u0dd4\u0db8\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb \u0d87\u0dad. \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0db0\u0ddc\u0dc0\u0db1\u0dba\u0da7 \u0db1\u0dd4\u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4, \u0daf\u0dd4\u0dbb\u0dca\u0dc0\u0dbd \u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4, \u0d85\u0db0\u0dd2\u0d9a \u0d9a\u0dc5\u0dd4\u0daf\u0dd4\u0db8 \u0dc3\u0dc4\u0dd2\u0dad \u0db8\u0d9c\u0dd3 \u0db6\u0dc3\u0dca\u0dbb\u0dae 18\u0d9a\u0dca, \u0db4\u0dbd\u0ddc\u0dbb\u0dd2 21 \u0d9a\u0dca, \u0dda\u0dc0\u0dd2\u0dad\u0dca\u0dad\u0dc0 \u0d9a\u0ddc\u0dbb\u0dca \u0dbb\u0dae 08\u0d9a\u0dca \u0dc4\u0ddc \u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dbb\u0ddd\u0daf \u0dbb\u0dae 02\u0d9a\u0dca \u0db4\u0dbd\u0dc3 \u0dc0\u0ddc\u0dc4\u0db1 49\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0ddc \u0dad\u0dc4\u0db1\u0dda \u0db1\u0dd2\u0db4\u0dba\u0ddd\u0d9c \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca\u0dad \u0d9a\u0dbb \u0d87\u0dad. \u0db4\u0db8\u0db8 \u0dc0\u0ddc\u0dc4\u0db1\u0dc0\u0dbd \u0dbb\u0dd2\u0dba\u0dd0\u0daf\u0dd4\u0dbb\u0db1\u0dca\u0db4\u0d9c\u0dca \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0dd4 \u0db6\u0dbd \u0dad\u0dca\u200d\u0dbb \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db7\u0ddc\u0dbb\u0dba\u0da7 \u0db4\u0d9c\u0db1 \u0dad\u0ddc\u0dc0\u0d9a\u0ddc\u0dbd\u0dd2\u0d9a \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0dd4 \u0db6\u0dbd \u0dad\u0dca\u200d\u0dbb \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca\u0dad \u0d9a\u0dd2\u0dbb\u0dd2\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb 2026.03.27 \u0dc0\u0db1 \u0daf\u0dd2\u0db1\u0da7 \u0db4 \u0dbb \u0dc0\u0ddc\u0dc4\u0db1 \u0db0\u0ddc\u0dc0\u0db1\u0dba\u0da7 \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4 \u0dad\u0dad\u0dca\u0dad\u0dad\u0dca\u0dad\u0dc0\u0dba\u0da7 \u0dad\u0dca\u0dad \u0d9a\u0dbb \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0dad\u0dca\u0dad \u0d9a\u0dd2\u0dbb\u0dd2\u0db8\u0da7 \u0daf\u0dd0\u0db1\u0dd4\u0dda \u0daf\u0dd3 \u0d87\u0dad.",
