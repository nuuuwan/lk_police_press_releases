    "text": "\u0b87\u0ba4\u0bbf\u0bb2\u0bcd \u0b87\u0baf\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bbf\u0ba9\u0bcd\u0ba9\u0bca\u0ba9, \u0baa\u0bc7\u0bca\u0bae\u0bca\u0bbf\u0baa\u0bcd\u0baa\u0bc1 \u0b95\u0bc1\u0bb3\u0bb1\u0bb5\u0bca\u0ba9, \u0b85\u0ba4\u0bbf\u0b95 \u0baa\u0bc1\u0bb3\u0b95 \u0baa\u0bb5\u0bc8\u0bbf\u0baf\u0bc0\u0b9f\u0bc1 \u0baa\u0b95\u0bca\u0bc8\u0bcd\u0b9f \u0bae\u0bbf\u0ba9\u0bbf \u0bb0\u0baa\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 18, \u0bb2\u0bca\u0bca\u0bbf 21, \u0b87\u0bc7\u0b9f\u0bcd\u0bb3\u0b9f \u0b95\u0bca\u0bca\u0bcd 8 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bc1 \u0bcd \u0b95\u0bcd\u0b95\u0bc7 \u0bb5\u0bc8\u0bcd\u0b9f\u0bbf \u0b95\u0bc8\u0bcd 2 \u0b8e\u0ba9 \u0baa\u0bae\u0bca\u0ba4\u0bcd\u0ba4\u0bae\u0bcd 49 \u0bb5\u0bca\u0b95\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0ba4\u0bb3\u0b9f \u0b89\u0ba4\u0bcd\u0ba4\u0bc7\u0bb5\u0bc1\u0b95\u0bc8\u0bcd \u0bb5\u0bbf\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bc8\u0bcd\u0bc8\u0ba9\u0bca\u0bcd.",
