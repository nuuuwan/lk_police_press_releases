    "text": "\u0b9a\u0bae\u0bb1\u0bcd\u0baa\u0b9f\u0bbf \u0b85\u0ba4\u0bbf\u0b95\u0bb0\u0bb0\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0baa\u0bc1\u0ba4\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bae\u0bcd \u0b87\u0ba4\u0ba9\u0bc1\u0b9f\u0ba9\u0bcd \u0b87\u0ba4\u0ba3\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0baa\u0baa\u0bb0\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0bb1\u0bbf\u0ba8\u0bcd\u0ba4\u0bc1\u0baa\u0b95\u0bb0\u0bb3\u0bcd\u0bb3\u0bc1\u0bae\u0bcd \u0bb5\u0ba4\u0b95\u0baf\u0bbf\u0bb2\u0bcd, \u0b87\u0ba8\u0bcd\u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bc1 \u0baa\u0ba4\u0bb0\u0b9f\u0bb0\u0bcd\u0baa\u0bb0\u0ba9 \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0baa\u0bcd\u0ba4\u0baa \u0ba4\u0b99\u0bcd\u0b95\u0bb3\u0ba4\u0bc1 \u0b8a\u0b9f\u0b95 \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bae\u0bcd \u0bb5\u0bb0\u0baf\u0bbf\u0bb2\u0bb0\u0b95 \u0baa\u0bbf\u0bb0\u0b9a\u0bc1\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bb0\u0bb1\u0bc1 \u0b85\u0ba9\u0bcd\u0baa\u0bc1\u0b9f\u0ba9\u0bcd \u0b9a\u0b95\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bcd\u0baa\u0b95\u0bb0\u0bb3\u0bcd\u0b95\u0bbf\u0b9a\u0bb1\u0bb0\u0bae\u0bcd.",
