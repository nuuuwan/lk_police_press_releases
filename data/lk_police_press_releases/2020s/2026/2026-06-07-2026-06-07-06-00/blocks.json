  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      127.09,
      523.67,
      167.97
    ],
    "text": "Investigations have been launched at the Horana Police Station following a report that a person was fatally stabbed with a sharp-edged weapon in the Aramakanda area of the Horana Police Division during the early hours of 07.06.2026.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      182.53,
      416.35,
      195.81
    ],
    "text": "The deceased is a 49-year-old resident of Aramakanda, Horana.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      210.37,
      518.71,
      237.45
    ],
    "text": "Preliminary investigations have revealed that the victim was allegedly stabbed by his wife during a domestic dispute at their residence.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      251.92,
      517.59,
      279.0
    ],
    "text": "The body remains under police custody at the scene for a Magistrate\u2019s inquest, while Horana Police continue further investigations.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
