    ],
    "text": "\u0b9a\u0ba8\u0bcd\u0ba4\u0ba4\u0b95\u0ba8\u0baa\u0bbe\u0bcd 2026.07.13 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0b85\u0bb5\u0bbf\u0b9a\u0bbe\u0bb5\u0b95\u0bb3 \u0ba4\u0b95\u0bcc\u0bb0\u0bb5 \u0ba8\u0bc0\u0ba4\u0bb5\u0bbe\u0ba9\u0bcd \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0b95\u0bb2\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0b95\u0ba4\u0ba4\u0bcd \u0ba4\u0ba4\u0bbe\u0b9f\u0bbe\u0bcd\u0ba8\u0bcd\u0ba4, 2026.07.24 \u0bb5\u0b95\u0bb0 \u0bb5\u0bbf\u0bb3\u0b95\u0bcd\u0b95\u0bae\u0bb1\u0bbf\u0baf\u0bb2\u0bbf\u0bb2\u0bcd \u0b95\u0bb5\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bbe\u0bb1\u0bc1 \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4.",
    "fonts": [
