    "text": "\u0ba4\u0bae\u0bb1\u0bcd\u0ba4\u0b95\u0bbe\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb5\u0bbf\u0b9a\u0bbe\u0bb0\u0b95\u0ba3\u0b95\u0bb3\u0bbf\u0bb2\u0bcd, \u0b95\u0bc1\u0bb1\u0bbf\u0ba4\u0bcd\u0ba4 \u0b9a\u0ba8\u0bcd\u0ba4\u0ba4\u0b95\u0ba8\u0baa\u0bbe\u0bcd \u0ba4\u0bb5\u0bb3\u0bbf\u0ba8\u0bbe\u0b9f\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0ba4\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3 \u0ba4\u0baa\u0bbe\u0b95\u0ba4\u0baa\u0bcd\u0ba4\u0baa\u0bbe\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd\u0b95\u0bbe\u0bb0\u0bbe\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b92\u0bb4\u0bc1\u0b99\u0bcd\u0b95\u0b95\u0bae\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0b9a\u0bcd \u0ba4\u0b9a\u0baf\u0bb2\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0ba8\u0baa\u0bbe\u0bcd\u0b95\u0bb3\u0bc1\u0b9f\u0ba9\u0bcd \u0ba4\u0ba8\u0bb0\u0bc1\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba4\u0ba4\u0bbe\u0b9f\u0bbe\u0bcd\u0baa\u0bc1\u0b95\u0b95\u0bb3\u0baa\u0bcd \u0ba4\u0baa\u0ba3\u0bbf \u0bb5\u0ba8\u0bcd\u0ba4\u0bb5\u0bbe\u0bcd \u0b8e\u0ba9 \u0ba4\u0ba4\u0bbe\u0bbf\u0baf\u0bb5\u0ba8\u0bcd\u0ba4\u0bb3\u0bcd\u0bb3\u0ba4.",
