    ]
  },
  {
    "page_number": 1,
    "bbox": [
      72.02,
      458.05,
      525.78,
      564.87
    ],
    "text": "\u0b85\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bae\u0bb2\u0bcb\u0b95, \u0b89\u0ba3\u0bb5\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0bcb\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bae\u0baf\u0b95\u0bcd\u0b95 \u0bae\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba4\u0b95\u0bcb\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1 \u0bae\u0baf\u0b95\u0bcd\u0b95\u0bae\u0bb3\u0b9f\u0baf\u0b9a\u0bcd \u0ba4\u0b9a\u0baf\u0bcd\u0ba4\u0bc1, \u0ba4\u0baa\u0ba3\u0bcd\u0b95\u0bb3\u0bb3 \u0ba4\u0bc1\u0ba9\u0bcd\u0baa\u0bc1\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf \u0ba4\u0b9a\u0bcb\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bb3\u0bb3 \u0ba4\u0bbf\u0bb0\u0bc1\u0b9f\u0bc1\u0bae\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bb5\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0bae\u0bcd \u0b87\u0b9f\u0bae\u0bcd\u0ba4\u0baa\u0bb1\u0bcd\u0bb1\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9. \u0bae\u0bae\u0bb2\u0bc1\u0bae\u0bcd, \u0ba4\u0bbf\u0bb0\u0bc1\u0bae\u0ba3\u0bae\u0bcd \u0ba4\u0b9a\u0baf\u0bcd\u0bb5\u0ba4\u0bcb\u0b95 \u0bb5\u0bcb\u0b95\u0bcd\u0b95\u0bc1\u0bb1\u0bc1\u0ba4\u0bbf \u0b85\u0bb3\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba8\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0bb3\u0b95 \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf, \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0bcb\u0bcd \u0baa\u0ba3\u0bae\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba4\u0b9a\u0bcb\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bb3\u0bb3\u0baa\u0bcd \u0ba4\u0baa\u0bb1\u0bcd\u0bb1\u0bc1\u0b95\u0bcd \u0ba4\u0b95\u0bcb\u0ba3\u0bcd\u0b9f\u0bc1 \u0b87\u0bb1\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0ba4\u0b95\u0bcb\u0bb3\u0bb2 \u0bae\u0baa\u0bcb\u0ba9\u0bcd\u0bb1 \u0ba4\u0bc1\u0baf\u0bb0\u0bae\u0bcb\u0ba9 \u0b9a\u0bae\u0bcd\u0baa\u0bb5\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bc1\u0bae\u0bcd \u0bae\u0bc1\u0b9f\u0bbf\u0bb5\u0bb3\u0b9f\u0ba8\u0bcd\u0ba4 \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bc1\u0b95\u0bb3\u0bcd \u0b95\u0bcb\u0ba3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9.",
