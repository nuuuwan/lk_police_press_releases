    "text": "\u0bae\u0bae\u0bcb\u0b9a\u0b9f\u0bbf \u0b95\u0bcb\u0ba4\u0bb2\u0bcb\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b85\u0bb1\u0bbf\u0bae\u0bc1\u0b95\u0bae\u0bb1\u0bcd\u0bb1 \u0ba8\u0b9f\u0bcd\u0baa\u0bc1\u0bb1\u0bb5\u0bc1\u0b95\u0bb3\u0bbf\u0b9f\u0bae\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bcb\u0ba4\u0bc1\u0b95\u0bcb\u0baa\u0bcd\u0baa\u0bc1 \u0ba4\u0ba4\u0bcb\u0b9f\u0bcb\u0bcd\u0baa\u0bcb\u0ba9 \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0baa\u0bcd\u0baa\u0bc1",
