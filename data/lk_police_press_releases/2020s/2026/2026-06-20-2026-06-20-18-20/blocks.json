    "text": "\u0b87\u0ba8\u0bcd\u0ba4 \u0bb5\u0bb3\u0b95 \u0bae\u0bae\u0bcb\u0b9a\u0b9f\u0bbf\u0b95\u0bb3\u0bcd \u0ba4\u0ba4\u0bcb\u0b9f\u0bcb\u0bcd\u0baa\u0bcb\u0b95 \u0ba4\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0bae\u0bcb \u0b85\u0ba4\u0bbf\u0baa\u0bcb\u0bbf\u0ba9\u0bcd \u0b95\u0bb5\u0ba9\u0bae\u0bcd \u0b88\u0bcb\u0bcd\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0ba8\u0bcb\u0b9f\u0bc1 \u0bae\u0bc1\u0bb4\u0bc1\u0bb5\u0ba4\u0bc1\u0bae\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 \u0b85\u0bb3\u0ba9\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0bb3\u0bb2\u0baf\u0b99\u0bcd\u0b95\u0bb3\u0bcd, \u0ba4\u0baa\u0bcb\u0ba4\u0bc1\u0baa\u0bcd \u0baa\u0bcb\u0ba4\u0bc1\u0b95\u0bcb\u0baa\u0bcd\u0baa\u0bc1 \u0b95\u0bc1\u0bb4\u0bc1\u0b95\u0bcd\u0b95\u0bb3\u0bcd, \u0baa\u0bc1\u0bb2\u0ba9\u0bcb\u0baf\u0bcd\u0bb5\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a\u0bbf\u0bb5\u0bbf\u0bb2\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bcb\u0bcb\u0bbf\u0b95\u0bb3\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0ba4\u0b95\u0bb5\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0b9a\u0b95\u0bcb\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1, \u0ba4\u0baa\u0bcb\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bcb\u0ba4\u0bc1\u0b95\u0bcb\u0baa\u0bcd\u0bb3\u0baa \u0b89\u0bb1\u0bc1\u0ba4\u0bbf \u0ba4\u0b9a\u0baf\u0bcd\u0baf \u0bae\u0ba4\u0bb3\u0bb5\u0baf\u0bcb\u0ba9 \u0ba8\u0b9f\u0bb5\u0b9f\u0bbf\u0b95\u0bcd\u0bb3\u0b95\u0b95\u0bb3\u0bcd \u0bae\u0bae\u0bb1\u0bcd\u0ba4\u0b95\u0bcb\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9.",
