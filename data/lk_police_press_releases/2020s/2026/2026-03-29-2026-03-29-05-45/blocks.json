    "text": "\u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad. \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd2\u0db1\u0dca \u0db6\u0dbb\u0db4\u0dad\u0dbd \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0dd0\u0db6\u0dd6 \u0dba\u0dad\u0dd4\u0dbb\u0dd4\u0db4\u0dd0\u0daf\u0dd2 \u0dbb\u0dd4 \u0dc4\u0dcf \u0db4\u0dc3\u0dd4\u0db4\u0dd0\u0daf\u0dd2 \u0dbb\u0dd4 \u0d9a\u0dd4\u0da0\u0dca\u0da0\u0d9a\u0dda\u0dbd\u0dd2 \u0d9a\u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d87\u0dad\u0dd4\u0dbd\u0dad\u0dca\u0daf\u0dca\u200d \u0d9a\u0dd2\u0dbb\u0dd3\u0d9a\u0db8\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d9a\u0daf\u0d9a\u0daf\u0db1\u0dcf\u0db8 \u0db8\u0dd2\u0dba\u0d9a\u0d9c\u0dcf\u0dc3\u0dca \u0d87\u0dad. \u0db8\u0dbb\u0dab \u0dbb\u0dd4\u0dd9\u0db1\u0dca \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 65 \u0dc4\u0ddc 75 \u0dba\u0dd9 \u0dd9\u0dba\u0dc3\u0dca\u0dd9\u0dbd \u0dc3\u0dd4\u0dd9\u0dd9 \u0dad\u0dd2\u0dbb\u0dd2\u0dba\u0ddc\u0dba \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda \u0daf\u0d82\u0da0\u0dd2 \u0dbb\u0dd4\u0dd9\u0db1\u0dca \u0db4\u0dda. \u0d9a\u0dd4\u0da0\u0dca\u0da0\u0d9a\u0dda\u0dbd\u0dd2 \u0d9a\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2.",
