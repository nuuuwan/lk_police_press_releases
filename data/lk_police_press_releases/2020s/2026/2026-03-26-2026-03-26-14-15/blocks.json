    "text": "\u0daf \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0ddc\u0db0\u0dba \u0daf\u0d9a\u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0dba. \u0b95\u0bc1\u0bb7\u0bcd \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bc1\u0b9f\u0ba9\u0bcd \u0b87\u0bb0\u0bc1 \u0b9a\u0ba8\u0bcd\u0baa\u0bc8\u0b95 \u0ba8\u0baa\u0bcb\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 - \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bcd \u0baa\u0ba3\u0bbf\u0baf\u0b95\u0bae\u0bcd \u0bb5\u0bbf\u0bae\u0bcb\u0ba9 \u0ba8\u0bbf\u0ba4\u0bb2\u0baf\u0baa\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bc1. 2026.03.26 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0b95\u0bcb\u0ba4\u0bb2, \u0b95\u0b9f\u0bcd\u0b9f\u0bc1\u0ba8\u0bcb\u0baf\u0b95\u0bcd\u0b95, \u0baa\u0ba3\u0bcd\u0b9f\u0bcb\u0bb0\u0ba8\u0bcb\u0baf\u0b95\u0bcd\u0b95 \u0b9a\u0bcb\u0bcd\u0bb5\u0baa\u0bc8\u0b9a \u0bb5\u0bbf\u0bae\u0bcb\u0ba9 \u0ba8\u0bbf\u0ba4\u0bb2\u0baf\u0bc8\u0bcd\u0bc8\u0bbf\u0ba9\u0bcd \u0bb5\u0bb0\u0bc1\u0ba4\u0b95 \u0bae\u0bc1\u0ba4\u0ba9\u0baf\u0bc8\u0bcd\u0bc8\u0bbf\u0bb2\u0bcd, \u0bb5\u0bbf\u0bae\u0bcb\u0ba9 \u0ba8\u0bbf\u0ba4\u0bb2\u0baf \u0b9a\u0bc1\u0b99\u0bcd\u0b95\u0baa\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bcd \u0b95\u0bbf\u0ba4\u0b9f\u0bc8\u0bcd\u0bc8 \u0bc8\u0b95\u0bb5\u0bb2\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0b9f\u0baf\u0bbf\u0bb2\u0bcd, \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bcd \u0bc8\u0b9f\u0bc1\u0baa\u0bcd\u0baa\u0bc1 \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bc1 \u0bb5\u0bbf\u0bae\u0bcb\u0ba9 \u0ba8\u0bbf\u0ba4\u0bb2\u0baf\u0baa\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bc1\u0b9f\u0ba9\u0bcd \u0b87\u0ba4\u0ba3\u0ba8\u0bcd\u0ba4\u0bc1 5 \u0b95\u0bbf\u0baa\u0bb2\u0bcb\u0b95\u0bbf\u0bb0\u0bcb\u0bae\u0bcd 206 \u0b95\u0bbf\u0bb0\u0bcb\u0bae\u0bcd \u0b95\u0bc1\u0bb7\u0bcd \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bc1\u0b9f\u0ba9\u0bcd \u0b92\u0bb0\u0bc1 \u0b9a\u0ba8\u0bcd\u0baa\u0bc8\u0b95 \u0ba8\u0baa\u0ba4\u0bb0\u0b95\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0bc8\u0ba4\u0bc1.",
