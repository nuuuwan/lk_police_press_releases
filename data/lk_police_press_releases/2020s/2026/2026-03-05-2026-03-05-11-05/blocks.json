  {
    "page_number": 1,
    "bbox": [
      72.02,
      108.61,
      551.02,
      190.89
    ],
    "text": "The National Operation \u201cRatam Ekata\u201d has been implemented since 30.10.2025 with the objective of completely suppressing drug trafficking in the country through a comprehensive and multifaceted strategy. This approach includes disrupting the supply of illegal drugs across the island, reducing the demand for narcotics, expanding law enforcement operations, rehabilitating drug addicts, implementing preventive programs aimed at deterring drug abuse, and strengthening community involvement in the fight against drugs.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
