    "text": "\u0d9c\u0dd2\u0dbd\u0db1\u0dca\u0dbb\u0dae 1990 , \u0dc5\u0d9f\u0db8 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0dc3\u0dbd\u0dca\u0dc0\u0dd0\u0dc3\u0dd2\u0dba \u0d9a\u0dd4\u0dba\u0dda \u0dc3\u0dc4 \u0dc0\u0dd4\u0dba\u0dbd\u0dca \u0dc0\u0dc0\u0dd9\u0dba\u0dc0\u0dbb \u0dcf\u0dba\u0dda \u0d85\u0d82\u0d9a \u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dcf\u0dbd \u0d85\u0d9a\u0dd4\u0dbb\u0dd2\u0db1\u0dca \u0dbd\u0dd2 \u0dcf \u0dc4\u0dc3\u0dd4\u0dba\u0dc0\u0db1\u0dca \u0dd9\u0dbb\u0dca\u0dc1\u0dca\u200d\u0db1 \u0dc0\u0db1 \u0dc3\u0dda\u0dae\u0dcf\u0db1 \u0d9a \u0db4\u0dca\u200d\u0dbb\u0dd9\u0dbb\u0dca\u0dc1\u0dca\u200d\u0db1 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8",
