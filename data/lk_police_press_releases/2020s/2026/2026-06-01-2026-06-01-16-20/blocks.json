    "text": "\u0dba\u0dd9\u0db8\u0dcf\u0db4\u0dd2 \u0db1\u0dca \u0dc3\u0dc4 \u0dc0\u0dd0\u0da9\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0db1\u0dca \u0dc4\u0dd4\u0dba\u0dd9\u0d9a\u0dbd\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d85\u0dc0\u0db8 \u0d9a\u0dbb \u0d94\u0dc0\u0dd4\u0db1\u0dca\u0dba\u0dda \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 \u0dc3\u0dd4\u0da7 \u0dc3\u0db8\u0dca\u0dd9\u0db1\u0dca\u0db0\u0dc0 \u0db1\u0dd2\u0dbb\u0db1\u0dca\u0dad\u0dbb\u0dba \u0db1\u0dca \u0d85\u0dc0\u0db0\u0dcf\u0db1\u0dba \u0db1\u0dca \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dd2\u0db8\u0dad\u0dca \u0dc0\u0dd3 \u0db8\u0dca \u0d85 \u0dbb\u0dcf\u0db0 \u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0da7 \u0d87\u0dad\u0dd2 \u0d85\u0dc0\u0dc3\u0dda\u0dae\u0dcf \u0d9a\u0dbd\u0dca\u0dba\u0dda\u0dbd\u0dcf \u0d87\u0dad\u0dd2\u0dc0 \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0dd9\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db6\u0dd4\u0daf\u0dca\u0dd2\u0db8\u0dad\u0dca \u0dc0\u0db1 \u0dba\u0dbd\u0dc3 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dba \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2 \u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1\u0dd4 \u0dbd\u0dd0\u0dba\u0dda.",
