  {
    "page_number": 1,
    "bbox": [
      72.02,
      304.03,
      525.9,
      763.52
    ],
    "text": "\u0dba\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dda \u0db8\u0dcf\u0db0\u0dba \u0dba\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba. \u0ba4\u0ba9\u0bbf\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbe\u0bb4\u0bc1\u0bc8\u0bcd \u0bae\u0bc1\u0ba4\u0bbf\u0baf\u0baf\u0bbe\u0bbe\u0bcd\u0b95\u0bb3\u0bcd \u0bc8\u0bb1\u0bcd\u0bb1\u0bc1\u0bc8\u0bcd \u0bb5\u0baf\u0baf\u0bbe\u0ba4\u0bbf\u0baa \u0baa\u0baa\u0bb1\u0bcd\u0baf\u0bb1\u0bbe\u0bbe\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1 \u0baa\u0ba4\u0bbe\u0b9f\u0bbe\u0bcd\u0baa\u0bbe\u0ba9 \u0bb5\u0bbf\u0bb4\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0ba3\u0bbe\u0bcd\u0bb5\u0bc1. \u0ba4\u0ba9\u0bbf\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbe\u0bb4\u0bc1\u0bc8\u0bcd \u0bae\u0bc1\u0ba4\u0bbf\u0baf\u0baf\u0bbe\u0bbe\u0bcd\u0b95\u0bb3\u0bcd \u0bc8\u0bb1\u0bcd\u0bb1\u0bc1\u0bc8\u0bcd \u0bb5\u0baf\u0baf\u0bbe\u0ba4\u0bbf\u0baa \u0baa\u0baa\u0bb1\u0bcd\u0baf\u0bb1\u0bbe\u0bbe\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0bae\u0baa \u0b89\u0bb1\u0bc1\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bc1, \u0baf\u0baa\u0bbe\u0ba4\u0bbf\u0baf \u0b95\u0bb5\u0ba9\u0bc8\u0bcd \u0baa\u0baa\u0bb1\u0bbe\u0ba4\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bbe\u0bb2\u0bc1\u0bc8\u0bcd, \u0ba4\u0bb1\u0bcd\u0baf\u0baa\u0bbe\u0bae\u0ba4\u0baf \u0b9a\u0bc2\u0bb4\u0bb2\u0bbf\u0bb2\u0bcd \u0bc8\u0bbf\u0b95\u0bb5\u0bc1\u0bc8\u0bcd \u0b89\u0ba3\u0bbe\u0bcd\u0bb5\u0bc1\u0baa\u0bc2\u0bbe\u0bcd\u0bb5\u0bc8\u0bbe\u0ba9\u0baf\u0ba4\u0bbe\u0b9f\u0bc1 \u0b85\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bbe\u0bb5\u0b9a\u0bbf\u0baf\u0bc8\u0bbe\u0ba9 \u0baa\u0baa\u0bbe\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbe\u0b95 \u0b87\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bbe\u0b95 \u0b87\u0bb2\u0b99\u0bcd\u0bae\u0b95\u0baa\u0bcd \u0baa\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bbe\u0bbe\u0bcd \u0b9a\u0bc1\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bbe\u0bcd. \u0baa\u0bbf\u0bb3\u0bcd\u0bae\u0bb3\u0b95\u0bb3\u0bcd \u0baa\u0ba4\u0bbe\u0bb4\u0bbf\u0bb2\u0bcd\u0ba8\u0bbf\u0bc8\u0bbf\u0ba4\u0bcd\u0ba4\u0bc8\u0bcd \u0baa\u0bb5\u0bb3\u0bbf\u0baf\u0bbf\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0baa\u0bb5\u0bb3\u0bbf\u0ba8\u0bbe\u0b9f\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0b9a\u0bb2\u0bcd\u0bb5\u0ba4\u0bc1, \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0baf\u0bb5\u0bb1\u0bc1 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0b95\u0bc1\u0b9f\u0bbf\u0baf\u0baf\u0bb1\u0bc1\u0bb5\u0ba4\u0bc1 \u0baf\u0baa\u0bbe\u0ba9\u0bcd\u0bb1 \u0b95\u0bbe\u0bb0\u0ba3\u0b99\u0bcd\u0b95\u0bb3\u0bbe\u0bb2\u0bcd, \u0baa\u0bb2 \u0bae\u0bc1\u0ba4\u0bbf\u0baf\u0baf\u0bbe\u0bbe\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0ba9\u0bbf\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbe\u0bb4 \u0baf\u0bb5\u0ba3\u0bcd\u0b9f\u0bbf\u0baf \u0ba8\u0bbf\u0bae\u0bb2 \u0b89\u0bb0\u0bc1\u0bb5\u0bbe\u0b95\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0b87\u0ba4\u0ba9\u0bcd \u0bb5\u0bbf\u0bae\u0bb3\u0bb5\u0bbe\u0b95 \u0b85\u0bb5\u0bbe\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bb2\u0bcd\u0baf\u0bb5\u0bb1\u0bc1 \u0b86\u0baa\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b89\u0bb3\u0bcd\u0bb3\u0bbe\u0b95\u0bc1\u0bc8\u0bcd \u0b9a\u0bc8\u0bcd\u0baa\u0bb5\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0ba3\u0bcd\u0bae\u0bc8\u0b95\u0bcd \u0b95\u0bbe\u0bb2\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0baa\u0ba4\u0bbf\u0bb5\u0bbe\u0b95\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9. \u0ba4\u0ba9\u0bbf\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bc0\u0b9f\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bb5\u0b9a\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bc8\u0bcd \u0b87\u0bc8\u0bcd\u0bae\u0bc1\u0ba4\u0bbf\u0baf\u0baf\u0bbe\u0bbe\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbe\u0bb3\u0bbf\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b8e\u0bb3\u0bbf\u0baf \u0b87\u0bb2\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bbe\u0b95 \u0bc8\u0bbe\u0bb1\u0b95\u0bcd\u0b95\u0bc2\u0b9f\u0bbf\u0baf \u0ba8\u0bbf\u0bae\u0bb2\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bbe\u0bb2\u0bcd, \u0b85\u0bb5\u0bbe\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0bae\u0baa \u0b89\u0bb1\u0bc1\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0b95 \u0baf\u0bc8\u0bb1\u0bcd\u0baa\u0b95\u0bbe\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f \u0baf\u0bb5\u0ba3\u0bcd\u0b9f\u0bbf\u0baf \u0ba8\u0b9f\u0bb5\u0b9f\u0bbf\u0b95\u0bcd\u0bae\u0b95\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb1\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0baa\u0bbe\u0ba4\u0bc1\u0bc8\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bc2\u0b9f\u0bc1\u0ba4\u0bb2\u0bcd \u0b85\u0bb5\u0ba4\u0bbe\u0ba9\u0bc8\u0bcd \u0baa\u0b9a\u0bb2\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bc8\u0bbe\u0bb1\u0bc1 \u0b87\u0bb2\u0b99\u0bcd\u0bae\u0b95\u0baa\u0bcd \u0baa\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bbe\u0bbe\u0bcd \u0baf\u0b95\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bcd\u0baa\u0b95\u0bbe\u0bb3\u0bcd\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bbe\u0bcd. \u0b95\u0bc1\u0bb1\u0bbf\u0baa\u0bcd\u0baa\u0bbe\u0b95, \u0baf\u0baa\u0bbe\u0bae\u0ba4\u0baa\u0bcd\u0baa\u0baa\u0bbe\u0bb0\u0bc1\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0b9f\u0bbf\u0bae\u0bc8\u0baf\u0bbe\u0ba9 \u0b9a\u0bbf\u0bb2\u0bbe\u0bcd \u0baa\u0ba3\u0bc8\u0bcd \u0bc8\u0bb1\u0bcd\u0bb1\u0bc1\u0bc8\u0bcd \u0ba4\u0b99\u0bcd\u0b95 \u0ba8\u0bae\u0b95\u0b95\u0bae\u0bb3 \u0b85\u0baa\u0b95\u0bbe\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bc8\u0bcd \u0baf\u0ba8\u0bbe\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd \u0b87\u0ba4\u0bcd\u0ba4\u0bae\u0b95\u0baf \u0ba4\u0ba9\u0bbf\u0bae\u0bc8 \u0bb5\u0bc0\u0b9f\u0bc1\u0b95\u0bae\u0bb3 \u0b87\u0bb2\u0b95\u0bcd\u0b95\u0bbe\u0b95\u0b95\u0bcd \u0baa\u0b95\u0bbe\u0bb3\u0bcd\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bbe\u0bcd. \u0ba4\u0b99\u0bcd\u0b95\u0bb3\u0ba4\u0bc1 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1 \u0baf\u0ba8\u0bbe\u0b95\u0bcd\u0b95\u0b99\u0bcd\u0b95\u0bae\u0bb3 \u0ba8\u0bbf\u0bae\u0bb1\u0baf\u0bb5\u0bb1\u0bcd\u0bb1\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0b95 \u0b9a\u0bbf\u0bb2 \u0b9a\u0ba8\u0bcd\u0ba4\u0bbe\u0bcd\u0baa\u0bcd\u0baa\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0baa\u0b95\u0bbe\u0bae\u0bb2\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bc1\u0bc8\u0bcd \u0b9a\u0bc8\u0bcd\u0baa\u0bb5\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0bc8\u0bcd \u0b85\u0ba3\u0bcd\u0bae\u0bc8\u0b95\u0bcd \u0b95\u0bbe\u0bb2\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0baa\u0ba4\u0bbf\u0bb5\u0bbe\u0b95\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3\u0bae\u0ba4 \u0b87\u0bb2\u0b99\u0bcd\u0bae\u0b95\u0baa\u0bcd \u0baa\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bbe\u0bbe\u0bcd \u0b85\u0bb5\u0ba4\u0bbe\u0ba9\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bbe\u0bcd.",
    "fonts": [
      "IskoolaPota-Bold",
      "Kavivanar-Regular"
    ],
    "sizes": [
      12.0,
      14.039999961853027
    ]
  },
  {
    "page_number": 2,
    "bbox": [
