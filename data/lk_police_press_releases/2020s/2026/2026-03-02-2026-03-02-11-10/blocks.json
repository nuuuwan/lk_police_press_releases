  {
    "page_number": 2,
    "bbox": [
      90.02,
      549.25,
      525.93,
      620.82
    ],
    "text": "\u0b87\u0ba4\u0bcd\u0ba4\u0bb2\u0b95\u0bc7 \u0baa\u0bbe\u0b9f\u0b9a\u0bbe\u0bb2\u0bc8\u0b95\u0bcd \u0b95\u0bbf\u0bbe\u0bbf\u0b95\u0bcd\u0b95\u0b95\u0b9f\u0bcd \u0baf\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bbf\u0bc8\u0bcd \u0b95\u0bc8\u0ba8\u0bcd\u0ba4\u0bc1 \u0b95\u0b95\u0bbe\u0bb3\u0bcd\u0baf\u0bc6\u0bbe\u0bbe\u0bcd, \u0baa\u0bc8\u0b95\u0bcd\u0b95\u0bc6\u0bc8\u0b95\u0bcd\u0b95 \u0bc6\u0bbf\u0ba4\u0bbf\u0b95\u0bb2\u0bb3 \u0bae\u0bc0\u0bb1\u0bbf \u0b95\u0baa\u0bbe\u0ba4\u0bc1\u0b9a\u0bcd\u0b95\u0b9a\u0bbe\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baf\u0b9a\u0ba4\u0bae\u0bcd \u0bc6\u0bbf\u0bb2\u0bb3\u0bc6\u0bbf\u0ba4\u0bcd\u0ba4\u0bc8\u0bcd \u0b85\u0bc8\u0bcd\u0bc8\u0ba4\u0bc1 \u0b9a\u0bae\u0bbe\u0ba4\u0bbe\u0ba9\u0ba4\u0bcd\u0bb2\u0ba4 \u0b9a\u0bc0\u0bbe\u0bcd\u0b95\u0bc1\u0bb2\u0bc8\u0ba4\u0bcd\u0ba4\u0bc8\u0bcd \u0baf\u0baa\u0bbe\u0ba9\u0bcd\u0bb1 \u0b95\u0b9a\u0bc7\u0bc8\u0bcd\u0b95\u0bb3\u0bbf\u0bc8\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bcd\u0b9f\u0bbe\u0bc8\u0bcd, \u0b85\u0b9a\u0bcd \u0b9a\u0ba8\u0bcd\u0ba4\u0bbe\u0bcd\u0baa\u0bcd\u0baa\u0ba4\u0bcd\u0ba4\u0bbf\u0bc8\u0bcd \u0b87\u0bc8\u0b99\u0bcd\u0bb2\u0b95 \u0b95\u0baa\u0bbe\u0bc8\u0bbf\u0bb8\u0bcd \u0b95\u0b9f\u0bc1\u0bb2\u0bae\u0bc7\u0bbe\u0b95 \u0b9a\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0bb2\u0ba4 \u0b85\u0bae\u0bc8\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bae\u0bcd.",
    "fonts": [
      "Kavivanar-Regular"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      634.6,
      525.93,
      723.54
    ],
    "text": "\u0b87\u0ba4\u0bb1\u0bcd\u0b95\u0bb2\u0bae\u0bc7, \u0baa\u0bbe\u0b9f\u0b9a\u0bbe\u0bb2\u0bc8\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0b9f\u0baf\u0bc7\u0bc7\u0bbe\u0ba9 \u0b95\u0bbf\u0bbe\u0bbf\u0b95\u0bcd\u0b95\u0b95\u0b9f\u0bcd \u0baf\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b95\u0ba4\u0bbe\u0b9f\u0bbe\u0bcd\u0baa\u0bc1\u0bb2\u0b9f\u0bc7 \u0b95\u0b9a\u0bc7\u0bc8\u0bcd\u0baa\u0bbe\u0b9f\u0bc1\u0b95\u0bb3\u0bbf\u0bc8\u0bcd \u0b85\u0bb2\u0ba9\u0bc6\u0bb0\u0bc1\u0bae\u0bcd \u0b95\u0baa\u0bbe\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bc1\u0b9f\u0ba9\u0bc1\u0bae\u0bcd, \u0b92\u0bb4\u0bc1\u0b99\u0bcd\u0b95\u0bc1\u0b9f\u0ba9\u0bcd \u0b95\u0b9a\u0bc7\u0bc8\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bbe\u0bb1\u0bc1 \u0b85\u0bb1\u0bbf\u0bc6\u0bc1\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bc6\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd \u0bae\u0bbe\u0ba3\u0bc6\u0bbe\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0bb2\u0ba9\u0bc6\u0bb0\u0bc1\u0bae\u0bcd \u0b89\u0ba3\u0bbe\u0bcd\u0bc6\u0bc1\u0baa\u0bc2\u0bbe\u0bcd\u0bc6\u0bae\u0bbe\u0b95 \u0b95\u0bc8\u0ba8\u0bcd\u0ba4\u0bc1\u0b95\u0b95\u0bbe\u0ba3\u0bcd\u0b9f\u0bc1, \u0bc6\u0bbf\u0bb2\u0bb3\u0bc7\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0b8e\u0ba9\u0bc1\u0bae\u0bcd \u0b86\u0ba9\u0ba8\u0bcd\u0ba4\u0ba4\u0bcd\u0bb2\u0ba4 \u0b85\u0ba9\u0bc1\u0baa\u0bc6\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0bc1 \u0b85\u0bc6\u0b9a\u0bbf\u0bc7\u0bae\u0bcd \u0b8e\u0ba9\u0bcd\u0bb1\u0bc1 \u0b87\u0bc8\u0b99\u0bcd\u0bb2\u0b95 \u0b95\u0baa\u0bbe\u0bc8\u0bbf\u0b9a\u0bbe\u0bb0\u0bbe\u0bc8\u0bcd \u0b87\u0ba4\u0ba9\u0bcd\u0baf\u0baa\u0bbe\u0ba4\u0bc1 \u0b85\u0bb1\u0bbf\u0bc6\u0bc1\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba4\u0bc1.",
