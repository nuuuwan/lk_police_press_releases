  {
    "page_number": 2,
    "bbox": [
      158.06,
      769.79,
      440.26,
      783.07
    ],
    "text": "Media Advisory on Inter-School Cricket Tournaments",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      45.47,
      525.22,
      100.17
    ],
    "text": "School cricket tournaments are annual events held between selected schools, where students participate in their school uniforms or colors. Alumni, parents, and other supporters often attend these events. During such activities, maintaining discipline and decorum is essential, as the behavior of participants reflects on the reputation and honor of their respective schools.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      114.73,
      481.66,
      128.01
    ],
    "text": "The Sri Lanka Police urges students and parents to observe the following guidelines:",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      142.45,
      233.45,
      155.73
    ],
    "text": "For Students and Participants:",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      90.02,
      170.29,
      524.74,
      376.8
    ],
    "text": "\u2022 Conduct yourselves in public in a manner that upholds the honor of your school. \u2022 Avoid shouting, obstructing roads, or causing inconvenience to the public or customers. \u2022 Refrain from engaging in conflicts with students from other schools. \u2022 Exercise caution while driving vehicles such as lorries or trucks, and avoid reckless driving. \u2022 Driving without a valid license or under the influence of alcohol is strictly prohibited; the police will enforce the law rigorously. \u2022 Follow all instructions provided by police officers during motorcades or truck parades. \u2022 Bringing alcohol or illegal drugs into stadiums where competitions are held is strictly forbidden. \u2022 The use of cigarettes or any prohibited substances will be subject to strict legal action. \u2022 Avoid conflicts, insulting remarks, or spreading hateful messages against opposing schools on social media.",
    "fonts": [
      "ArialMT",
      "SymbolMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      9.960000038146973,
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      391.24,
      220.13,
      404.52
    ],
    "text": "For Parents and Guardians:",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      90.02,
      419.1,
      484.14,
      473.78
    ],
    "text": "\u2022 Monitor the events and locations your children attend. \u2022 Ensure that children return home safely and on time. \u2022 Exercise caution when providing vehicles for activities such as motorcades or parades.",
    "fonts": [
      "ArialMT",
      "SymbolMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      9.960000038146973,
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      488.34,
      506.74,
      515.42
    ],
    "text": "The Sri Lanka Police will take strict legal action against any unlawful behavior, property damage, or misconduct by students, alumni, or parents during school cricket tournaments.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      529.86,
      507.37,
      556.94
    ],
    "text": "The police emphasize the importance of responsible conduct to ensure that all participants can safely enjoy the excitement of inter-school cricket competitions.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      571.53,
      186.41,
      584.81
    ],
    "text": "Police Media Division",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  }
