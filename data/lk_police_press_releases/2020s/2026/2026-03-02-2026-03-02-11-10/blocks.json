    "text": "\u0b95\u0baa\u0bbe\u0bc8\u0bbf\u0bb8\u0bcd \u0b8a\u0b9f\u0b95\u0baa\u0bcd \u0baa\u0bbf\u0bbe\u0bbf\u0bc6\u0bc1",
    "fonts": [
      "Kavivanar-Regular"
