    "text": "\u0b87\u0ba8\u0bcd\u0ba4 \u0baa\u0baa\u0bb0\u0ba3\u0bbf, \u0b95\u0b99\u0bcd\u0b95\u0bbe\u0bb0\u0bbe\u0bae \u0baa\u0bc1\u0bb0\u0bbe\u0ba4\u0ba9 \u0bb5\u0bbf\u0b95\u0bbe\u0b9f\u0bb0\u0baf\u0bbf\u0bb2\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bc1\u0bb1\u0baa\u0bcd\u0baa\u0bc8\u0bcd\u0b9f\u0bc1, \u0b8a\u0bb0\u0bb5\u0ba4\u0bcd\u0ba4 \u0b95\u0b99\u0bcd\u0b95\u0bbe\u0bb0\u0bbe\u0bae \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf \u0bb5\u0bb4\u0bbf\u0baf\u0bbe\u0b95 \u0b95\u0bbe\u0bb2\u0bbf \u0bb5\u0bc0\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0baf\u0ba3\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1, \u0bb9\u0bbf\u0baa\u0bb0\u0bb5\u0ba4\u0bcd\u0ba4 \u0baa\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0bcd \u0b9a\u0bbf\u0b9f\u0bb2 \u0b85\u0bb0\u0bc1\u0baa\u0b95 \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bbf\u0bb0\u0ba4\u0bbe\u0ba9 \u0bb5\u0bc0\u0ba4\u0bbf \u0bb5\u0bb4\u0bbf\u0baf\u0bbe\u0b95 \u0b85\u0bae\u0bcd\u0baa\u0bb2\u0bbe\u0b99\u0bcd\u0b95\u0b95\u0bbe\u0b9f\u0bc8 \u0bb5\u0bc8\u0bcd\u0bc8\u0b9a\u0bcd\u0b9a\u0ba8\u0bcd\u0ba4\u0bbf \u0bb5\u0b9f\u0bb0 \u0b95\u0b9a\u0ba9\u0bcd\u0bb1\u0bc1, \u0b85\u0b99\u0bcd\u0b95\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bae\u0bc0\u0ba3\u0bcd\u0b9f\u0bc1\u0bae\u0bcd \u0b95\u0bbe\u0bb2\u0bbf \u0bb5\u0bc0\u0ba4\u0bbf\u0baf\u0bc2\u0bc8\u0bbe\u0b95 \u0b8a\u0bb0\u0bb5\u0ba4\u0bcd\u0ba4 \u0b95\u0b99\u0bcd\u0b95\u0bbe\u0bb0\u0bbe\u0bae \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0bb5\u0b9f\u0bb0 \u0bb5\u0ba8\u0bcd\u0ba4\u0bc1, \u0b85\u0b99\u0bcd\u0b95\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba4\u0bbf\u0bb0\u0bc1\u0bae\u0bcd\u0baa\u0bbf \u0b8a\u0bb0\u0bb5\u0ba4\u0bcd\u0ba4 \u0b95\u0b99\u0bcd\u0b95\u0bbe\u0bb0\u0bbe\u0bae \u0baa\u0bc1\u0bb0\u0bbe\u0ba4\u0ba9 \u0bb5\u0bbf\u0b95\u0bbe\u0b9f\u0bb0\u0b95\u0bcd\u0b95\u0bc1 \u0b95\u0b9a\u0bb2\u0bcd\u0bb2\u0bc1\u0bae\u0bcd.",
