    "text": "\u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0dc5\u0db8\u0dba\u0ddc \u0dc0\u0dc3\u0dbd\u0dca\u0dbd\u0dda \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0ddc\u0dc0\u0dda \u0db1\u0dd2\u0dc0\u0dc3 \u0dd2\u0da7\u0dd4 \u0dc3 \u0d85\u0db1\u0ddc\u0dbb\u0d9a\u0dca\u0dd2\u0dad\u0dc0 \u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dc0\u0dd9\u0ddc \u0dc5\u0dd2\u0db3\u0da7 \u0dc0\u0dd0\u0da7\u0dd3 \u0dc0\u0db8\u0db8 \u0d85\u0db1\u0dad\u0dd4\u0dbb \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0dc0\u0dda\u0daf\u0dd3 \u0d85\u0db1\u0ddc\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0d87\u0dad. \u0dc0 \u0ddc\u0dbd\u0dca\u0dd2\u0dad\u0dd2\u0dd9\u0db8 \u0dc0 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. 04. \u0d85\u0dba\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0dbb\u0dd9\u0dba \u0dc3\u0db8\u0d9f \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dd9\u0da7 - \u0db4\u0daf\u0ddc\u0da9\u0db1\u0db4\u0d9c\u0ddc\u0da9 \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0dba. 2026.03.08 \u0daf\u0dd2\u0db1 \u0d85\u0dc5\u0dd4\u0dba\u0dda \u0d9a\u0ddc\u0dbd\u0dc0\u0dda \u0dc0\u0daf\u0ddc\u0da9\u0db1\u0dca\u0dc0\u0dd9\u0ddc\u0da9 \u0dc0 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0dc0\u0dda \u0dc4\u0dbb\u0dca\u0db8\u0db1\u0dca\u0dc0\u0dad\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dda\u0dc1\u0dc0\u0dda\u0daf\u0dd3 \u0dc0\u0daf\u0ddc\u0da9\u0db1\u0dca\u0dc0\u0dd9\u0ddc\u0da9 \u0dc0 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0dc0\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0ddc\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0d