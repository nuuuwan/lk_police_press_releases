    "text": "\u0b87\u0b9a\u0bcd \u0ba3\u0b9a\u0baf\u0bcd \u0bbf\u0b9f\u0baf \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0b9f\u0baf\u0bbe\u0b95\u0b95\u0bcd \u0ba3\u0b95\u0bbe \u0bcd\u0b9f\u0bc1, \u201c\u0b87\u0b9f\u0b9a \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba3\u0baa\u0bbe\u0bb4\u0bc1\u0ba4\u0bc1\u0b9a\u0baa\u0bbe\u0b95\u0bcd\u0b95\u0bc1 \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0baa\u0bbe\u0b9f\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bbe\u0b9f\u0bc1\u0bb5 \u0bb1\u0bcd\u0b95\u0bc1 \u0ba3\u0baa\u0bbe\u0bb2\u0bbf\u0b9a\u0bbe\u0bbe\u0bcd \u0b85\u0ba9\u0bc1\u0bae \u0bbf \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bb5\u0bbf\u0bb2\u0bcd\u0b9f\u0bb2\u201d \u0b8e\u0ba9\u0bcd\u0bb1 \u0bb5\u0bb1\u0bbe\u0ba9 \u0b95\u0bb5\u0bb2\u0bcd \u0b9a\u0bbf\u0bb2 \u0b9a\u0bae\u0bc2\u0b95 \u0b8a\u0b9f\u0b95\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0baa\u0bb0\u0baa\u0bcd\u0baa\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0bb5\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0b85\u0bb5\u0bcd\u0bb5\u0bbe\u0bb1\u0bbe\u0ba9 \u0b95\u0bb5\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0b89 \u0bcd\u0b9f\u0bae\u0baf\u0bb2\u0bcd\u0bb2 \u0b8e\u0ba9\u0bcd\u0baa\u0b9f \u0b87\u0bb2\u0b99\u0bcd\u0b9f\u0b95 \u0ba3\u0baa\u0bbe\u0bb2\u0bbf\u0bb8\u0bcd \u0bb5\u0bb2\u0bbf\u0baf\u0bc1\u0bb1\u0bc1 \u0bcd\u0ba4\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1.",
