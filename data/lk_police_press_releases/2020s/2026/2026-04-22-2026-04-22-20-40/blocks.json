    "text": "\u0b86\u0b95\u0bc8\u0baf\u0bca\u0bb2\u0bcd, \u0b87\u0ba4\u0bcd\u0ba4\u0b95\u0bc8\u0baf \u0baa \u0bca\u0baf\u0bcd\u0baf\u0bca\u0ba9 \u0ba4\u0bc8\u0bb5\u0bb2\u0bcd\u0bc8\u0b95\u0bc8 \u0ba8\u0bae\u0bcd \u0b9a\u0bb5\u0ba3\u0bcd\u0b9f\u0bca\u0bae\u0bcd \u0b8e\u0ba9\u0bcd\u0bb1\u0bc1\u0bae\u0bcd, \u0bb5\u0bca\u0bcd\u0ba4\u0bcd\u0ba4\u0bae\u0bca\u0ba9\u0bbf \u0b85\u0bb1\u0bbf\u0bb5\u0bbf \u0bcd \u0bbf\u0bb2\u0bcd \u0b95\u0bc1\u0bb1\u0bbf \u0bcd \u0bbf\u0b9f \u0bcd \u0b9f\u0bcd\u0b9f\u0bc1\u0bc8\u0bcd\u0bc8 \u0b85\u0b9f\u0bbf \u0bcd \u0b95\u0b9f \u0ba4\u0b95\u0bc1\u0ba4\u0bbf\u0bc8\u0b95\u0bc8 \u0baa\u0bc2\u0bca\u0bcd\u0ba4\u0bcd\u0ba4\u0bbf \u0baa\u0b9a\u0baf\u0bcd\u0ba4\u0bb5\u0bca\u0bcd\u0bc8\u0bc8\u0bcd \u0bae\u0b9f\u0bcd\u0b9f\u0bc1\u0b9a\u0bae \u0bb5\u0bbf\u0ba3\u0bcd\u0ba3 \u0bcd \u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0b9a\u0ba8\u0bca\u0bcd\u0bae\u0bc1\u0bc8\u0ba4\u0bcd \u0b9a\u0ba4\u0bca\u0bcd\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bb5\u0bb0\u0bc1\u0bae\u0bca\u0bb1\u0bc1 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b9a \u0bca\u0bb2\u0bc0\u0b9a\u0bca\u0bca\u0bcd \u0bb5\u0bbf\u0ba3\u0bcd\u0ba3 \u0bcd \u0ba4\u0bca\u0bb0\u0bca\u0bcd\u0bc8\u0bb3\u0bc1\u0bc8\u0bcd\u0b95\u0bc1 \u0b85\u0bb1\u0bbf\u0bb5\u0bc1\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bc8\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bca\u0bcd.",
