    "text": "\u0b87\u0bae\u0bcd \u0bae\u0bc1\u0bb1\u0bc8 \u0bcd \u0bca\u0b9f\u0bcd\u0b9f\u0bc1\u0b9a\u0bcd \u0b9a\u0b9a\u0bb1\u0bc8\u0baf\u0bbf\u0ba9\u0bc2\u0b9f\u0bca\u0b95 \u0baa \u0bca\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1, \u0b89\u0bb3\u0bcd\u0ba8\u0bca\u0b9f\u0bcd\u0b9f\u0bc1 \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0baa\u0bc8\u0bb3\u0bbf\u0ba8\u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba4\u0bbf\u0b9f\u0bcd\u0b9f\u0bae\u0bbf\u0b9f \u0bcd \u0b9f\u0bcd\u0b9f \u0b95\u0bc1\u0bc8\u0bcd\u0bc8\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bc8\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a \u0bca\u0bb1\u0ba4 \u0bcd\u0baa \u0bca\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd \u0bc1 \u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3 \u0ba8 \u0bca\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd \u0bca\u0b95 \u0ba4\u0b95\u0bc8\u0bb2\u0bcd\u0b95\u0bb1\u0bb3 \u0bc8\u0bb4\u0b99\u0bcd\u0b95 \u0bae\u0bc1\u0b9f\u0bbf\u0bc8\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0b95\u0bc1\u0bc8\u0bcd\u0bc8\u0b99\u0bcd\u0b95\u0bb3\u0bcd, \u0b9a\u0bbf\u0bc8\u0bbf\u0baf \u0bae\u0bc1\u0bb1\u0bc8 \u0bcd \u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bcd, \u0b9a \u0bca\u0b95\u0bcd\u0b95\u0bc1\u0bc8\u0bb0\u0ba4\u0bcd\u0ba4\u0bc1 \u0b95\u0bc1\u0bc8\u0bcd\u0bc8\u0b99\u0bcd\u0b95\u0bb3\u0bcd, \u0baa \u0bca\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b9a\u0bbf\u0bb0\u0bae\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bb3\u0bcd\u0bb3\u0bca\u0b95\u0bc1\u0ba4\u0bb2\u0bcd \u0bae\u0bc8\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b8a\u0bb4\u0bb2\u0bcd \u0b95\u0bc1\u0bc8\u0bbf\u0ba4\u0bcd\u0ba4 \u0ba4\u0b95\u0bc8\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd \u0bca\u0b95\u0bc8\u0bc1\u0bae\u0bcd \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd\u0bae\u0bca \u0b85\u0ba4\u0bbf \u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b9a\u0ba8\u0bb0\u0b9f\u0bbf\u0baf\u0bca\u0b95 \u0ba4\u0b95\u0bc8\u0bb2\u0bcd\u0b95\u0bb1\u0bb3 \u0bc8\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bc8\u0ba4\u0bc8\u0bcd\u0b95\u0bc1 \u0b8f\u0bc8\u0bcd \u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bcd \u0baa\u0b9a\u0baf\u0bcd\u0ba4\u0bc1 \u0ba4\u0bb0 \u0bcd \u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0b87\u0ba4\u0ba8\u0bc2\u0b9f\u0bca\u0b95 \u0baa \u0bc8 \u0bcd \u0b9f\u0bc1\u0bae\u0bcd \u0bae\u0bc1\u0bb1\u0bc8 \u0bcd \u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd \u0bca\u0b95 \u0b8e\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0bcd \u0b9f\u0bc1\u0bae\u0bcd \u0bae\u0bc1\u0bb1\u0bc8 \u0bcd \u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd \u0bca\u0b95\u0bc8\u0bc1\u0bae\u0bcd \u0b85\u0ba4\u0bc8\u0bcd\u0b95\u0bc1 \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd \u0bc1\u0bb1\u0b9f\u0baf \u0bc8\u0bbf\u0b9a\u0bca\u0bb0\u0bb1\u0ba3\u0b95\u0bb3\u0bcd \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd \u0bca\u0b95\u0bc8\u0bc1\u0bae\u0bcd \u0bbf\u0bca\u0bbf\u0bc8\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bcd \u0baa \u0bca\u0bb1\u0bc1 \u0bcd \u0bca\u0ba9 \u0b85\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9f\u0bcd\u0b9a\u0b95\u0bca\u0bcd \u0b8a\u0b9f\u0bca\u0b95 \u0b95\u0bc1\u0bc8\u0bbf\u0ba4\u0bcd\u0ba4 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0bb1\u0bb2\u0baf\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bc8\u0bbf\u0bc8\u0bbf\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd \u0bc8\u0bbf\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0bcd \u0b9f\u0bcd\u0b9f\u0bc1 \u0bc8\u0bbf\u0bb1\u0bb0\u0bc8\u0bca\u0b95 \u0b85\u0ba4\u0bc1 \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd \u0bca\u0b95 \u0bc8\u0bbf\u0b9a\u0bca\u0bb0\u0bb1\u0ba3 \u0b89\u0ba4\u0bcd\u0ba4\u0bbf\u0b9a\u0baf\u0bca\u0b95\u0ba4\u0bcd\u0ba4\u0bca\u0bcd\u0b95\u0bb1\u0bb3 \u0b85\u0ba9 \u0bcd \u0bc1\u0bc8\u0ba4\u0bc8\u0bcd\u0b95\u0bc1 \u0ba8\u0b9f\u0bc8\u0b9f\u0bbf\u0b95\u0bcd\u0bb1\u0b95 \u0b8e\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0bcd \u0b9f\u0bc1\u0bae\u0bcd. \u0bae\u0bc1\u0ba9\u0bcd\u0bb1\u0bc8\u0b95\u0bcd\u0b95 \u0bcd \u0b9f\u0bc1\u0bae\u0bcd \u0bae\u0bc1\u0bb1\u0bc8 \u0bcd \u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b89\u0bca\u0bbf\u0baf \u0ba8\u0bc0\u0ba4\u0bbf \u0b95\u0bbf\u0bb1\u0b9f\u0b95\u0bcd\u0b95\u0bc8\u0bbf\u0bb2\u0bcd\u0bb1\u0bb2\u0baa\u0baf\u0ba9\u0bbf\u0bb2\u0bcd \u0bae\u0bc0\u0ba3\u0bcd\u0b9f\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0ba8\u0bbf\u0bb1\u0bb2 \u0b8a\u0b9f\u0bca\u0b95 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd\u0bae\u0bca \u0b85\u0ba4\u0bbf \u0bca\u0bcd \u0b85\u0bc8\u0bca\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0ba4\u0bca\u0bbf\u0bc8\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bc8\u0bca\u0baf\u0bcd \u0bcd \u0bc1 \u0b87\u0ba4\u0ba9\u0bcd\u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0bc8\u0bb4\u0b99\u0bcd\u0b95 \u0bcd \u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
