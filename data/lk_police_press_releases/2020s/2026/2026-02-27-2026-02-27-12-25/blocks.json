    "text": "\u0b87\u0bb2\u0b99\u0bcd\u0bb1\u0b95 \u0baa \u0bca\u0bb2\u0bbf\u0b9a\u0bca\u0bb2\u0bcd \u0b85\u0bc8\u0bbf\u0bae\u0bc1\u0b95 \u0bcd \u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0bcd \u0b9f\u0bcd\u0b9f\u0bc1 \u0ba4\u0bc8\u0bcd\u0b9a \u0bca\u0ba4\u0bc1 \u0ba8\u0bb1\u0b9f\u0bae\u0bc1\u0bb1\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 \u201c\u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd\u0bae\u0bca \u0b85\u0ba4\u0bbf \u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b95\u0bc2\u0bb1\u0bc1\u0b99\u0bcd\u0b95\u0bb3\u0bcd\u201d (Tell IGP) \u0ba4\u0bbf\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bca\u0bb2\u0bcd \u0baa \u0bca\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b89\u0b9f\u0ba8\u0b9f\u0bbf\u0baf\u0bca\u0b95 \u0b92\u0bb0\u0bc1 \u0b9a\u0bae\u0bcd \u0bc8\u0bae\u0bcd \u0ba8\u0bbf\u0b95\u0bb4\u0bc1\u0bae\u0bcd \u0b9a \u0bca\u0ba4\u0bc1 \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0bae\u0bc1\u0bb1\u0bc8 \u0bcd \u0bca\u0b9f\u0bc1 \u0b92\u0ba9\u0bcd\u0bb1\u0bc8 \u0baa \u0bca\u0bb2\u0bbf\u0bb8\u0bcd\u0bae\u0bca \u0b85\u0ba4\u0bbf \u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0ba8\u0bbf\u0bb1\u0bb2 \u0b8a\u0b9f\u0bca\u0b95 \u0bae\u0bc1\u0ba9\u0bcd\u0bb1\u0bc8 \u0bcd \u0ba4\u0bc8\u0bcd\u0b95\u0bca\u0ba9 \u0b9a\u0ba8\u0bcd\u0ba4\u0bca\u0bcd \u0bcd \u0bae\u0bcd \u0bc8\u0bb4\u0b99\u0bcd\u0b95 \u0bcd \u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd 2026 \u0b86\u0bae\u0bcd \u0b86\u0ba3\u0bcd\u0b9f\u0bc1 \u0b87\u0ba4\u0bcd \u0ba4\u0bbf\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0bb1\u0ba4 \u0b9a\u0bae\u0bae\u0bcd \u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf \u0baa\u0ba4\u0bca\u0b9f\u0bca\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1\u0bae\u0bcd \u0baa\u0b9a\u0baf\u0bb2\u0bcd \u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0bcd \u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0b87\u0b9a\u0bcd \u0b9a\u0b9a\u0bb1\u0bc8\u0baf\u0bbf\u0ba9\u0bc2\u0b9f\u0bca\u0b95, \u0b89\u0bb3\u0bcd\u0ba8\u0bca\u0b9f\u0bc1 \u0bae\u0bc8\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0bc8\u0bb3\u0bbf\u0ba8\u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bc8\u0bca\u0bb4\u0bc1\u0bae\u0bcd \u0b85\u0bb1\u0ba3\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba8 \u0bca\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b9a\u0bbf\u0b99\u0bcd\u0b95\u0bb3\u0bae\u0bcd \u0bae\u0bc8\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba4\u0bae\u0bbf\u0bb4\u0bcd \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0b86\u0b99\u0bcd\u0b95\u0bbf\u0bb2 \u0baa\u0bae\u0bca\u0bb4\u0bbf\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0bb1\u0bc8 \u0bcd \u0bca\u0b9f\u0bc1\u0b95\u0bb3\u0bcd \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0bb2\u0bca\u0bae\u0bcd. \u0b85\u0bae\u0bcd \u0bae\u0bc1\u0bb1\u0bc8 \u0bcd \u0bca\u0b9f\u0bcd\u0bb1\u0b9f \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0ba8\u0bbf\u0bb1\u0bb2\u0baf\u0bbf\u0ba9\u0bc2\u0b9f\u0bca\u0b95 \u0ba4\u0bbf\u0bc8\u0bbf\u0b9f\u0bc1\u0bc8\u0ba4\u0bc8\u0bcd\u0b95\u0bca\u0ba9 \u0b9a\u0ba4\u0bb1\u0bc8\u0baf\u0bca\u0ba9 \u0bc8\u0b9a\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0bc8\u0bb4\u0b99\u0bcd\u0b95 \u0bcd \u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
    "fonts": [
