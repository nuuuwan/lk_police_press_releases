  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      160.93,
      514.21,
      243.21
    ],
    "text": "On the night of 07.04.2026, officers of the Northern Provincial Crime Division conducted a raid in the Vishwamadhu area within the Pudukudiyiruppu Police Division based on a tip-off and arrested a suspect in possession of 205 grams of crystal methamphetamine (\u201cice\u201d) and 170 grams of heroin, along with another individual who was aiding and abetting drug trafficking. Both suspects were handed over to the Pudukudiyiruppu Police Station.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      257.8,
      443.38,
      271.08
    ],
    "text": "The suspects are residents of the Vishwamadhu area, aged 22 and 32.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
