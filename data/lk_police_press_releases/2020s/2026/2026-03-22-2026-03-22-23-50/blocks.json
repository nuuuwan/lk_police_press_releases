    "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4 \u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbd \u0db6\u0dc0\u0da7 \u0dc4\u0dd0\u0d9f\u0db4\u0dc0\u0db1 \u0db4\u0dbd\u0dc3 \u0dc3\u0db8\u0dcf\u0da2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d94\u0dc3\u0dda\u0db4\u0dc3\u0dda \u0dc3\u0d82\u0dc3\u0dbb\u0dab\u0dba \u0dc0\u0db1 \u0dbd \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dca\u200d\u0dc0 \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0dd0\u0dc4\u0dd0\u0daf\u0dd2\u0dbd\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8.",
