  },
  {
    "page_number": 1,
    "bbox": [
      72.02,
      170.11,
      543.03,
      253.22
    ],
    "text": "2026.06.30 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1, \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0b95 \u0b95\u0b9f\u0bb1\u0bcd\u0baa\u0b95\u0b9f\u0ba4\u0bcd \u0ba4\u0bb3\u0baa\u0ba4\u0bbf \u0b85\u0b9f\u0bcd\u0bae\u0bbf\u0bb0\u0bb2\u0bcd \u0b95\u0bb0\u0b9e\u0bcd\u0b9a\u0ba9 \u0baa\u0bb0\u0ba9\u0baa\u0b95\u0bb0\u0b9f \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0baa\u0bb0\u0bb2\u0bbf\u0bb8\u0bcd \u0ba4\u0b95\u0bb2\u0b95\u0bae\u0baf\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bb5\u0bbf\u0b9c\u0baf\u0bae\u0bcd \u0baa\u0b9a\u0baf\u0bcd\u0ba4\u0bc1, \u0baa\u0baa\u0bb0\u0bb2\u0bbf\u0bb8\u0bcd\u0bae\u0bb0 \u0b85\u0ba4\u0bbf\u0baa\u0bb0\u0bcd \u0b9a\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bb0\u0ba3\u0bbf \u0baa\u0bbf\u0bb0\u0bbf\u0baf\u0ba8\u0bcd\u0ba4 \u0bb5\u0bc0\u0bb0\u0b9a\u0bc2\u0bb0\u0bbf\u0baf \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b9f\u0ba9\u0bcd \u0b9a\u0bc1\u0bae\u0bc1\u0b95\u0bae\u0bb0\u0ba9 \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1\u0b95\u0bb0\u0baf\u0bb0\u0b9f\u0bb2\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bcd\u0b9f\u0bb0\u0bb0\u0bcd.",
    "fonts": [
