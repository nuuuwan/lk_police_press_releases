    "text": "\u0d85\u0daf\u0dca\u0db8\u0dd2\u0dbb\u0dcf\u0dbd\u0dca \u0db1\u0dd2\u0dbd\u0dba\u0da7 \u0d8b\u0dc3\u0dc3\u0dca \u0dc0\u0dd3\u0db8\u0dca \u0dbd\u0daf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0db4\u0dad\u0dd2 \u0db4\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0db4\u0dda \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dc0. 2026.06.30 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0db4\u0dad\u0dd2 \u0d85\u0daf\u0dca\u0db8\u0dd2\u0dbb\u0dcf\u0dbd\u0dca \u0d9a\u0dcf\u0dcf\u0d82\u0da0\u0db1 \u0db6\u0dcf\u0db1\u0d9c \u0dcf\u0da9 \u0db8\u0dc4\u0dad\u0dcf \u0d9c\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dd0\u0dd2\u0dab \u0d9c\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca\u0db4\u0dad\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0da5 \u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0db1\u0dca\u0dad \u0dc0\u0dd3\u0dbb\u0dc3\u0dd6\u0dbb\u0dd2\u0dba \u0db8\u0dc4\u0dad\u0dcf \u0dc3\u0db8\u0d9f \u0dc3\u0dd4\u0dc4\u0daf \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf\u0dc0\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0db1 \u0dbd\u0daf\u0dd2. \u0d92 \u0db8\u0dc4\u0dad\u0dcf 2026.06.30 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dc0\u0dba\u0dd2\u0dc3\u0dca \u0d85\u0daf\u0dca\u0db8\u0dd2\u0dbb\u0dcf\u0dbd\u0dca \u0db1\u0dd2\u0dbd\u0d9c\u0dda \u0dc3\u0dd2\u0da7 \u0d85\u0daf\u0dca\u0db8\u0dd2\u0dbb\u0dcf\u0dbd\u0dca \u0db1\u0dd2\u0dbd\u0dba\u0da7 \u0d8b\u0dc3\u0dc3\u0dca \u0dc0\u0dd3\u0db8\u0dca \u0dbd\u0daf \u0d85\u0dad\u0dbb, \u0d9c\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0dad\u0dd4\u0db8\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d91\u0dad\u0dd4\u0db8\u0dcf\u0dc4\u0da7 \u0dc3\u0dd4\u0db7\u0dcf\u0dc3\u0dd2\u0dcf\u0d82\u0dc1\u0db1 \u0db4\u0dc5 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd2. \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0db4\u0dad\u0dd2 \u0dc0\u0dc1\u0d9c\u0dba\u0db1\u0dca \u0d89\u0da7\u0dd4\u0d9a\u0dc5 \u0d9c\u0dc3\u0dca\u0dc0\u0dba \u0dc4\u0dcf \u0dbb\u0dcf\u0da2\u0d9a\u0dcf\u0dbb\u0dd2 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dcf \u0d9c\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9c\u0d9a\u0d9c\u0dbb\u0dc4\u0dd2 \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd6 \u0dc3\u0dc4\u0d9c\u0dba\u0ddd\u0d9c\u0dd3\u0dad\u0dcf\u0dc0\u0dba \u0d9c\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0dad\u0dd4\u0db8\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85 \u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0d85\u0dad\u0dbb \u0d91\u0db8 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0da7 \u0d9c\u0da2\u0dd9\u0dc2\u0dca\u0da8 \u0d9c\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca\u0dc0 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0db1 \u0dbd\u0daf\u0dd2. \u0d9c\u0db8\u0db8 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0d9c\u0dda\u0daf\u0dd3 \u0d9c\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0dad\u0dd4\u0db8\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0daf\u0dca\u0db8\u0dd2\u0dbb\u0dcf\u0dbd\u0dca \u0d9a\u0dcf\u0dcf\u0d82\u0da0\u0db1 \u0db6\u0dcf\u0db1\u0d9c \u0dcf\u0da9 \u0db8\u0dc4\u0dad\u0dcf \u0d9c\u0dc0\u0dad \u0dc3\u0db8\u0dbb\u0dd4 \u0dc3\u0dd2\u0dc4\u0dd2\u0dc0\u0da7\u0db1\u0dba\u0d9a\u0dca\u0dc0\u0daf \u0db4\u0dd2\u0dc5\u0dd2 \u0dd0\u0db1\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd2. \u0db4\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dba \u0db4\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba.",
    "fonts": [
