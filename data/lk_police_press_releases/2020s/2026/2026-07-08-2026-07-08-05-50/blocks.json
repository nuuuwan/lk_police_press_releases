    "bbox": [
      107.42,
      749.99,
      355.15,
      763.27
    ],
    "text": "The suspect is a 61-year-old resident of Moratuwa.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      777.71,
      436.06,
      790.99
    ],
    "text": "Further investigations are being conducted by the Moratuwa Police.",
    "fonts": [
