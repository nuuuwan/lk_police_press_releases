    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      32.03,
      353.11,
      45.31
    ],
    "text": "The suspect is a 41-year-old resident of Kotugoda.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      59.75,
      523.9,
      86.85
    ],
    "text": "Subsequent investigations led officers to recover 16 rounds of 9mm live ammunition, 18 rounds of T-56 ammunition, and a motorcycle concealed at the suspect's residence.",
    "fonts": [
