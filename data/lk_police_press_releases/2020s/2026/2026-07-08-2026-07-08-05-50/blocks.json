    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.42,
      666.93,
      520.93,
      735.41
    ],
    "text": "On the evening of 07.07.2026, officers attached to the Walana Central Anti-Corruption Unit conducted a raid in the Koralawella area within the Moratuwa Police Division following a tip-off and arrested a suspect in possession of 75 litres of illicit liquor. The suspect was subsequently handed over to the Moratuwa Police Station for further legal action.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
