    "text": "\u0b85\u0ba8\u0bcd\u0ba4 \u0b9a\u0ba8\u0bcd\u0ba4\u0bcb\u0bcd \u0bcd \u0ba4\u0bcd\u0ba4\u0bbf\u0bc8\u0bcd \u0ba4 \u0bcb\u0bc8\u0bbf\u0bb8\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bcb\u0bcb\u0bbf\u0b95\u0bc8\u0bcd \u0b85\u0ba8\u0bcd\u0ba4 \u0bae\u0bc1\u0baf\u0bb1\u0bcd\u0b9a\u0bbf\u0ba9\u0baf \u0ba4\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba8\u0bbf\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0ba4\u0bc1\u0b9f\u0bc8\u0bcd, \u0b85\u0b99\u0bcd\u0b95\u0bc1 \u0ba4\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0b95\u0bc1\u0bb4\u0bc1\u0bb5\u0bbf\u0bc8\u0ba9\u0bb0 \u0b85\u0ba8\u0bcd\u0ba4 \u0b87\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0bc8\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0b85\u0b95\u0bb1\u0bcd\u0bb1 \u0ba8\u0b9f\u0bb5\u0b9f\u0bbf\u0b95\u0bcd\u0ba9\u0b95 \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bc8\u0bcd\u0bc8\u0bc8\u0bcb\u0bcd.",
