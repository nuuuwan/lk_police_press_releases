    "text": "\u0d8b\u0dad\u0dca\u0dc3\u0dc0 \u0dc3\u0db8\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0d9c\u0dad \u0dc0\u0d82\u0da0\u0dcf\u0dc0\u0db1\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dc0 \u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0",
