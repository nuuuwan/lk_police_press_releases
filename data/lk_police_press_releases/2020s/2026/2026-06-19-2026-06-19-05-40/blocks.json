    "text": "\u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0ddc\u0db0\u0dca\u200d\u0dba \u0db4 \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0dba \u0db4\u0dd9\u0dad \u0dd9\u0ddc\u0dbb\u0dca\u0dad\u0ddc \u0dc0\u0dd6 \u0dd9\u0dd0\u0daf\u0d9c\u0dad\u0dca \u0db4\u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4. \u0baa\u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0b8a\u0b9f\u0b95\u0baa\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0b85\u0bb1\u0bbf\u0b95\u0bcd\u0b95\u0b95\u0baf\u0bbf\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bae\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0ba4\u0b95\u0bb5\u0bb2\u0bcd\u0b95\u0bb3\u0bcd 01. \u0db4\u0dd4\u0dbb\u0ddc\u0dd9\u0dc3\u0dca\u0dad\u0dd4 \u0db4\u0dc3\u0dc0\u0dd3\u0db4\u0dda \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dd2\u0db1\u0dca \u0dd0\u0dab\u0dd3\u0dda \u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0dd0 \u0dbb\u0dd4\u0dd9\u0db1\u0dca 07 \u0db4\u0daf\u0db4\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dd9\u0da7 - \u0daf\u0db9\u0d9c\u0dbd\u0dca\u0dbd \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0dd9\u0dba. 2026.06.18 \u0daf\u0dd2\u0db1 \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0daf\u0db9\u0d9c\u0dbd\u0dca\u0dbd \u0db4\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda \u0d9c\u0dbd\u0dca\u0db4\u0db4\u0ddc\u0dbd\u0dca\u0dbd\u0db1\u0dca\u0daf \u0dbb\u0d9a\u0dca\u0dc2\u0dd2\u0dad \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0daf\u0db9\u0d9c\u0dbd\u0dca\u0dbd \u0db4\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0db4\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0ddc\u0dba\u0db8\u0d9a\u0dca\u0dc2 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da7\u0dbd\u0dd3\u0db8\u0d9a\u0dca\u0dc2 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb \u0db4\u0dd4\u0dbb\u0ddc\u0dc0\u0dc3\u0dca\u0dd4 \u0db4\u0dc3\u0dc0\u0dd3\u0db4\u0dda \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dd2\u0db1\u0dca \u0d9a\u0dd0\u0dab\u0dd3\u0dda \u0d9a\u0dbb\u0db8\