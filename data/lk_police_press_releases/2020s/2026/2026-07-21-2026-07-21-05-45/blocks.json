    ]
  },
  {
    "page_number": 3,
    "bbox": [
      107.42,
      454.96,
      497.97,
      486.58
    ],
    "text": "The motorcyclist sustained critical injuries and was pronounced dead upon admission to the Anamaduwa Hospital.",
    "fonts": [
