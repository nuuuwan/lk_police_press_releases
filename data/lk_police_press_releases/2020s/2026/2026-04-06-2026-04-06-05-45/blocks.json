    "bbox": [
      107.42,
      380.2,
      526.15,
      421.1
    ],
    "text": "The motive for the murder has not yet been established. Two suspects have been arrested in connection with the incident, and further investigations are being conducted by the Panamura Police.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
