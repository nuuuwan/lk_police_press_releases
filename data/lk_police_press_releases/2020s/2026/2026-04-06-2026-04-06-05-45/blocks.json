    ]
  },
  {
    "page_number": 1,
    "bbox": [
      107.42,
      324.88,
      526.28,
      365.76
    ],
    "text": "Preliminary investigations have revealed that the victim sustained severe injuries after being assaulted with hands, feet, and sharp weapons by two individuals present at the location on the night of 05.04.2026.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
