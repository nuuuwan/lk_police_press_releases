    "bbox": [
      107.42,
      297.04,
      455.14,
      310.32
    ],
    "text": "The deceased is a 46-year-old resident of the Weathura, Panamura area.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
