    "bbox": [
      107.42,
      244.82,
      525.57,
      340.88
    ],
    "text": "On the evening of 24.05.2026, a team of officers attached to the Kochchikade Police Station carried out a raid in the Madampitiya Road area based on intelligence received and arrested a suspect in possession of 588 grams and 570 milligrams of ice, 595 grams and 430 milligrams of hashish, 234 pills, and 286 stamps. The suspect and the seized items were subsequently handed over to the Madampitiya Police Station.",
    "fonts": [
      "TimesNewRomanPS-ItalicMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      14.039999961853027
    ]
  },
