    ]
  },
  {
    "page_number": 5,
    "bbox": [
      107.42,
      87.37,
      538.78,
      128.25
    ],
    "text": "During the operation, officers arrested a suspect found in possession of 375 litres (500 bottles) of illicit liquor. The suspect and the seized liquor were subsequently handed over to the Ragama Police Station.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
