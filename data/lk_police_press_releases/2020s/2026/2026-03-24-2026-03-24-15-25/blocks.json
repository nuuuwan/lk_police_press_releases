    ],
    "text": "\u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0bc8\u0bcd\u0bc8\u0bb2\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0baa\u0ba3\u0bcd \u0b92\u0bb0\u0bc1\u0bb5\u0bb0\u0bcb\u0bb2\u0bcd \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa\u0bb0\u0bcb\u0bc8\u0bae\u0bcb\u0b95 \u0b9a\u0bae\u0bcd\u0baa\u0bcb\u0bc8\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0ba3\u0bc8\u0bcd\u0bc8\u0bbf\u0bb2\u0bcd \u0bb5\u0bcb\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb0\u0bc2\u0baa\u0bcb\u0baf\u0bcd 03 \u0baa\u0b95\u0bcb\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b85\u0bc8\u0bbf\u0b95 \u0baa\u0baa\u0bb1\u0bc1\u0bae\u0bc8\u0bbf\u0baf\u0bcb\u0ba9 \u0baa\u0b9a\u0bcb\u0bc8\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bc1\u0b9f\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9 \u2013 \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa\u0bb0\u0bcb\u0bc8 \u0baa\u0b9a\u0bcb\u0bc8\u0bcd\u0ba4\u0bc1\u0b95\u0bb3\u0bcd \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0ba3\u0baa\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bc1. \u0baa\u0b95\u0bcb\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 14 \u0baa\u0b95\u0bc1\u0bc8\u0bbf\u0ba4\u0baf\u0b9a\u0bcd \u0baa\u0b9a\u0bcb\u0bcd\u0ba8\u0bcd\u0bc8 \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0bc8\u0bcd\u0bc8\u0bb2\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0baa\u0ba3\u0bcd \u0b92\u0bb0\u0bc1\u0bb5\u0bcb\u0bcd, \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0bc8\u0bcd\u0bc8\u0bb2\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0baa\u0b9a\u0bcb\u0bc8\u0bcd\u0ba4\u0bc1\u0b95\u0bb3\u0bcd \u0baa\u0baa\u0bb1\u0bcd\u0bb1\u0bc1\u0bb3\u0bcd\u0bb3\u0bc8\u0bcb\u0b95 \u0b95\u0bbf\u0ba4\u0b9f\u0bc8\u0bcd\u0bc8 \u0bae\u0bc1\u0ba4\u0bb1\u0baa\u0bcd\u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0b9f\u0baf\u0bbf\u0bb2\u0bcd, \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa\u0bb0\u0bcb\u0bc8 \u0baa\u0b9a\u0bcb\u0bc8\u0bcd\u0ba4\u0bc1\u0b95\u0bb3\u0bcd \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0ba3\u0baa\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bbf\u0ba9\u0bcb\u0bb2\u0bcd \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0ba3\u0b95\u0bb3\u0bcd \u0b86\u0bb0\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0baa\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bcb\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9. \u0b87\u0baa\u0bcd\u0baa\u0baa\u0ba3\u0bcd\u0ba3\u0bcb\u0bb2\u0bcd \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa\u0bb0\u0bcb\u0bc8\u0bae\u0bcb\u0b95 \u0b9a\u0bae\u0bcd\u0baa\u0bcb\u0bc8\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0ba3\u0bc8\u0bcd\u0bc8\u0bbf\u0bb2\u0bcd \u0baa\u0b95\u0bcb\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 14 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9c\u0bcb-\u0b8f\u0bb2 \u0baa\u0b95\u0bc1\u0bc8\u0bbf\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bb5\u0bcb\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb0\u0bc2\u0baa\u0bcb\u0baf\u0bcd 514 \u0b87\u0bb2\u0b9f\u0bcd\u0b9a\u0bc8\u0bcd\u0bc8\u0bbf\u0bb1\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b85\u0bc8\u0bbf\u0b95 \u0baa\u0baa\u0bb1\u0bc1\u0bae\u0bc8\u0bbf\u0baf\u0bcb\u0ba9 \u0b95\u0bcb\u0ba3\u0bbf, 04 \u0b95\u0ba4\u0b9f\u0b95\u0bb3\u0bcd, \u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bcb\u0b9f\u0bbf \u0bb5\u0bc0\u0b9f\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb0\u0bc2\u0baa\u0bcb\u0baf\u0bcd 59 \u0b87\u0bb2\u0b9f\u0bcd\u0b9a\u0bae\u0bcd \u0baa\u0baa\u0bb1\u0bc1\u0bae\u0bc8\u0bbf\u0baf\u0bcb\u0ba9 06 \u0bb5\u0b99\u0bcd\u0b95\u0bbf \u0b95\u0ba3\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0ba4\u0bb5 \u0baa\u0ba3\u0bae\u0bcd \u0ba4\u0bc1\u0bc2\u0baf\u0bc8\u0bcb\u0b95\u0bcd\u0b95\u0bb2\u0bc1\u0b95\u0bcd\u0baa\u0b95\u0bc8\u0bbf\u0bb0\u0bcb\u0ba9 \u0b9a\u0b9f\u0bcd\u0b9f\u0bc8\u0bcd\u0bc8\u0bbf\u0ba9\u0bcd \u0b95\u0bc0\u0bb4\u0bcd, \u0ba8\u0bc0\u0bcb\u0bcd\u0baa\u0b95\u0bcb\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0b95\u0bcb\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 \u0baa\u0b95\u0bcc\u0bb0\u0bb5 \u0baa\u0bae\u0bb2\u0bcd \u0ba8\u0bc0\u0bc8\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcb\u0bb2\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b89\u0bc8\u0bcd\u0bc8\u0bb0\u0bb5\u0bbf\u0ba9\u0bcd \u0baa\u0baa\u0bcb\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0b9f\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1, \u0b85\u0ba8\u0bcd\u0bc8 \u0b89\u0bc8\u0bcd\u0bc8\u0bb0\u0bb5\u0bc1 \u0ba8\u0bc0\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0b85\u0bae\u0bb2\u0bcd\u0baa\u0b9f\u0bc1\u0bc8\u0bcd\u0bc8\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0baa\u0bae\u0bb2\u0bc1\u0bae\u0bcd \u0baa\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bcb\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0ba3\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0baa\u0bcb\u0ba4\u0bc1, \u0baa\u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0baa\u0bcb\u0bb0\u0bc1\u0bb3\u0bcd \u0b95\u0b9f\u0bc8\u0bcd\u0bc8\u0bb2\u0bcb\u0bb2\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bcb\u0bc8\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc8\u0bcb\u0b95 \u0baa\u0bc8\u0bcb\u0bbf\u0baf\u0bb5\u0ba8\u0bcd\u0bc8 \u0baa\u0bb5\u0ba9\u0bcd\u0ba9\u0bb5\u0bc8\u0bcd\u0bc8, \u0baa\u0bb5\u0bb2\u0bcd\u0bb2\u0bae\u0bcd\u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf \u0baa\u0b95\u0bc1\u0bc8\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0ba4\u0bae\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3 \u0bb0\u0bc2\u0baa\u0bcb\u0baf\u0bcd 300 \u0b87\u0bb2\u0b9f\u0bcd\u0b9a\u0bae\u0bcd \u0baa\u0baa\u0bb1\u0bc1\u0bae\u0bc8\u0bbf\u0baf\u0bcb\u0ba9 \u0b86\u0b9f\u0bae\u0bcd\u0baa\u0bb0\u0bae\u0bcb\u0ba9 \u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bcb\u0b9f\u0bbf \u0bb5\u0bc0\u0b9f\u0bc1, 2026.03.20 \u0bae\u0bc1\u0bc8\u0bb2\u0bcd 07 \u0ba8\u0bcb\u0b9f\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bcb\u0bb2\u0bc8\u0bcd\u0bc8\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0b9f\u0b95\u0bcd\u0b95 \u0b89\u0bc8\u0bcd\u0bc8\u0bb0\u0bb5\u0bc1 \u0baa\u0bbf\u0bb1\u0baa\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa\u0bb0\u0bcb\u0bc8 \u0baa\u0b9a\u0bcb\u0bc8\u0bcd\u0ba4\u0bc1\u0b95\u0bb3\u0bcd \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0ba3\u0baa\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bbf\u0ba9\u0bcb\u0bb2\u0bcd \u0baa\u0bae\u0bb2\u0bc8\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bcb\u0bb0\u0ba4\u0ba3\u0b95\u0bb3\u0bcd \u0baa\u0bc8\u0bcb\u0b9f\u0bcb\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bcb\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9. \u0baa\u0baa\u0bcb\u0bb2\u0bbf\u0bb8\u0bcd \u0b8a\u0b9f\u0b95\u0baa\u0bcd \u0baa\u0bbf\u0bcb\u0bbf\u0bb5\u0bc1",
    "fonts": [
      "IskoolaPota-Bold",
      "Kavivanar-Regular"
    ],
