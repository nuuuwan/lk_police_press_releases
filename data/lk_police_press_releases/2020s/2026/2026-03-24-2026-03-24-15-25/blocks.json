    "text": "\u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d9a\u0dbb\u0dca\u0dad\u0dd8 / \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0d9a\u0dbb\u0dca\u0dad\u0dd8, \u0d85\u0db0\u0dba\u0d9a\u0dca\u0dc2 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 / \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0d9a\u0dc5\u0db8\u0dab\u0dcf\u0d9a\u0dbb\u0dd4, \u0dc3\u0dd2\u0dba\u0dc5\u0dd4\u0db8 \u0db8\u0dcf\u0db0\u0dba \u0d86\u0dba\u0dad\u0db1. \u0db8\u0dad\u0dca\u0dad\u0dbb\u0dc0\u0dba \u0da2\u0dcf\u0dc0\u0dcf\u0dbb\u0db8\u0dca\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0d9a \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd3\u0dd2 \u0dc0\u0dd2\u0dbb\u0dbb\u0ddd\u0db0\u0dd2 \u0dbb\u0dd9\u0dc3 \u0d8b\u0db4\u0dba\u0dcf \u0d9c\u0dad\u0dca\u0dad \u0db8\u0dd4\u0daf\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dd9\u0daf\u0dd3 \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dd9\u0daf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbb\u0d9a\u0ddd\u0da7\u0dd2 03 \u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0dc0\u0da7\u0dd2\u0db1\u0dcf\u0d9a\u0db8\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca\u0dad \u0dbb\u0dda\u0db4\u0dd9 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf \u0dc0\u0dd2\u0dbb\u0dc4\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 - \u0db1\u0dd3\u0dd2 \u0dc0\u0dd2\u0dbb\u0dbb\u0ddd\u0db0\u0dd2 \u0dc0\u0dad\u0dca\u0dad\u0d9a\u0db8\u0dca \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dbb\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba. \u0d9a \u0ddc\u0dc5\u0db9 14 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dda\u0dc1\u0d9a\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0da2\u0ddc\u0dc0\u0dca\u200d\u0ddc\u0dbb\u0db8\u0dca \u0ddc\u0dbb\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0da2\u0ddc\u0dc0\u0dca\u200d\u0ddc\u0dbb\u0db8\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb \u0d9a\u0dda\u0db4\u0dbd \u0dc4\u0ddc \u0dc0\u0dca\u200d\u0dad\u0dca\u0daf\u0dca\u200d \u0db8\u0dca \u0d8b\u0db4\u0dba\u0ddc\u0d9a\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dca\u200d\u0da7 \u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0d9a\u0dbb\u0ddd\u0db0\u0dd2 \u0dc0\u0dca\u200d\u0dad\u0dca\u0daf\u0dca\u200d \u0db8\u0dca \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d9a \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0dba \u0d9a\u0dc0\u0dca\u200d\u0dad \u0dbd\u0daf \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0d9a\u0dba\u0db1\u0dca \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0dba\u0d9a\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dbb \u0db4\u0dc0\u0dca\u200d\u0dad\u0dca\u0daf\u0dca\u200d\u0dc0\u0dca\u200d\u0ddc\u0d9a\u0dd9\u0db1 \u0dba\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0d9a\u0db8\u0db8 \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0da2\u0ddc\u0dc0\u0dca\u200d\u0ddc\u0dbb\u0db8\u0dca \u0ddc\u0dbb\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0d9a\u0dbb\u0ddd\u0db0\u0dd3 \u0d9a\u0dbd\u0dc3 \u0d8b\u0db4\u0dba\u0ddc\u0dd9\u0db1\u0dca\u0db1\u0ddc \u0dbd\u0daf \u0db8\u0dd4\u0daf\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3\u0d9a\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d9a \u0ddc\u0dc5\u0db9 14 \u0dc3\u0dc4 \u0da2\u0ddc\u0d87\u0dbd \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dda\u0dc1\u0d9a\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 514 \u0da7 \u0d85\u0db0\u0dd2 \u0dc0\u0dca\u200d\u0da7\u0dd2\u0db1\u0ddc \u0db8\u0d9a\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca\u0daf\u0dca\u200d \u0d89\u0da9\u0db8\u0d9a\u0dca, \u0da9 \u0ddc\u0db8\u0dbb 04 \u0d9a\u0dca, \u0d9a\u0dad\u0db8\u0dc4\u0dbd\u0dca \u0db1\u0dd2\u0dc0\u0dca\u200d\u0dc3\u0d9a\u0dca \u0dc3\u0dc4 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 59 \u0dc0\u0dca\u200d\u0da7\u0dd2\u0db1\u0ddc \u0db8\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dd0\u0dd2\u0d82\u0d9a\u0dd4 \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca 06 \u0d9a\u0dca \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc0\u0dd2\u0dc1\u0dd4\u0dda\u0db0\u0dd2 \u0dbb\u0dab\u0dba \u0dc0\u0dca\u200d\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dd3\u0d9a\u0db8\u0dca \u0db4\u0db1\u0dad \u0db4\u0dca\u200d\u0dbb \u0ddc\u0dbb\u0dc0\u0dca\u200d \u0db8\u0dd3\u0dd9\u0db8\u0dd4\u0dc0\u0dca\u200d \u0dc3\u0dc4 \u0d9a \u0ddc\u0dc5\u0db9 \u0dd9\u0dbb\u0dd4 \u0db8\u0dc4\u0ddc\u0db0\u0dd2 \u0dbb\u0dab \u0db8\u0d9f\u0dd2\u0db1\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0ddc\u0dc0\u0dd2\u0dbb\u0dc4\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0d9a\u0db8\u0dca \u0db1\u0dd2\u0d9a\u0dba\u0ddd\u0dd9 \u0daf\u0dd3\u0dbb\u0dca\u0d9d \u0dbb \u0db6\u0dbd\u0ddc\u0dad\u0dca\u0daf\u0dca\u200d\u0db8 \u0dbb \u0d87\u0dad. \u0dc3\u0dd0 \u0ddc\u0dbb\u0dd2\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dc0\u0dca\u200d \u0dc3\u0dd2\u0daf\u0dd4 \u0dc5 \u0dc0\u0dca\u200d\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0d9a\u0dda\u0daf\u0dd3 \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0da2\u0ddc\u0dc0\u0dca\u200d\u0ddc\u0dbb\u0d9a\u0db8\u0db1\u0dca \u0d8b\u0db4\u0dba\u0ddc \u0dd9\u0dad\u0dca\u0daf\u0dca\u200d \u0db6\u0dc0\u0dca\u200d\u0da7 \u0dbb\u0dd4\u0dab\u0dd4 \u0d85\u0db1\u0ddc\u0dc0\u0dca\u200d\u0dbb\u0dab\u0dba \u0dc0\u0dca\u200d\u0db1 \u0d9a\u0dc0\u0dca\u200d\u0db1\u0dca\u0db1\u0dc0\u0dca\u200d\u0dad\u0dca\u0daf\u0dca\u200d\u0dad, \u0dc0\u0dca\u200d\u0dd0\u0dbd\u0dca\u0dbd\u0db8\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dda\u0dc1\u0d9a\u0dda \u0d89\u0da9\u0d9a\u0db8\u0dca \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 300 \u0d9a\u0dca \u0dc0\u0dca\u200d\u0da7\u0dd2\u0db1\u0ddc \u0dc3\u0dd4\u0d9a \u0ddd\u0db4\u0d9a\u0db7\u0ddd\u0d9c\u0dd3 \u0d9a\u0dad\u0db8\u0dc4\u0dbd\u0dca \u0db1\u0dd2\u0dc0\u0dca\u200d\u0dc3 2026.03.20 \u0dc0\u0dca\u200d\u0db1 \u0daf\u0db1 \u0dc3\u0dd2\u0da7 \u0daf\u0db1 07 \u0ddc\u0dbd\u0dba\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0ddc \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0ddc \u0dc0\u0dd2\u0dbb\u0dc4\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0d9a\u0db8\u0dca \u0db1\u0dd2\u0d9a\u0dba\u0ddd\u0dd9 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca\u0daf\u0dca\u200d \u0dbb \u0d87\u0dad. \u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0d9a\u0dbb\u0ddd\u0db0\u0dd2 \u0dc0\u0dca\u200d\u0dad\u0dca\u0daf\u0dca\u200d \u0db8\u0dca \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d9a \u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dca\u200d\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2. \u0dbb\u0db4\u0dcf\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dba \u0dbb\u0d9a\u0dcf\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba.",
