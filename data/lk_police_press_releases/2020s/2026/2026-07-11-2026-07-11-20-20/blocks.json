    "text": "\u0db4\u0dd4\u0dbb\u0dcf\u0dab \u0dad \u0dcf\u0da7\u0d9c\u0db8\u0dd4\u0dc0 \u0dbb\u0dad\u0dca\u0db4\u0dad\u0dca \u0dbb\u0da2\u0db8\u0dc4\u0dcf \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dad\u0dda \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0db8\u0dd2\u0dc4\u0dd2\u0db3\u0dd4 \u0db8\u0dc4\u0dcf \u0dad\u0db4\u0dbb\u0dc4\u0dbb 2026.07.12 \u0daf\u0dd2\u0db1 \u0daf\u0dc4\u0dc0\u0dbd\u0dca\u0db4 0100 \u0dc3\u0dd2\u0da7 \u0d9c\u0dcf\u0dbd\u0dca\u0db4\u0dbd \u0dad\u0d9a\u0dcf\u0dc5\u0db9 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0dc2\u0d9c\u0dad\u0dda \u0dc0\u0dd3\u0dae\u0dd2 \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2 \u0dc0 \u0d87 . \u0dad\u0db4\u0dbb\u0dc4\u0dbb 2026.07.12 \u0daf\u0dd2\u0db1 \u0daf\u0dc4\u0dc0\u0dbd\u0dca\u0db4 0100 \u0da7 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dad\u0dba\u0db1\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb \u0d9c\u0dcf\u0dbd\u0dca\u0db4\u0dbd \u0dad\u0d9a\u0dcf\u0dc5\u0db9 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0dc2\u0d9c\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0d9c\u0dcf\u0dbd\u0dd4 \u0db4\u0dcf\u0dbb \u0d94\u0dc3\u0dca\u0dad\u0dc3\u0dca \u0dc0\u0dd0\u0dbb\u0dd0\u0dbd\u0dca\u0db4\u0dbd\u0dcf\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dbb \u0db1\u0dd0\u0dc0 \u0d91\u0db8 \u0db8\u0dcf\u0dbb\u0dca\u0dc2\u0d9c\u0dad\u0dda\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2 \u0dc0 \u0d87 . \u0dad\u0db4\u0dbb\u0dc4\u0dbb \u0d9c\u0dcf\u0dbd\u0dca\u0db4\u0dbd \u0dad\u0d9a\u0dcf\u0dc5\u0db9 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0dc2\u0d9c\u0dad\u0dda \u0d9c\u0db8\u0db1\u0dca \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d9a\u0dcf\u0dbd\u