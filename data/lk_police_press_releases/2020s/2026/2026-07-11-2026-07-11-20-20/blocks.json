    "page_number": 1,
    "bbox": [
      90.02,
      884.37,
      528.5,
      899.91
    ],
    "text": "\u2022 Vehicles travelling from Colombo towards Galle are advised to turn left at",
    "fonts": [
      "ArialMT",
      "SymbolMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      9.960000038146973,
      14.039999961853027
