    "text": "2026.03.15 \u0daf\u0dd2\u0db1 \u0dc3\u0dc0\u0dc3 \u0db4\u0daf\u0dc4\u0dd2\u0d85\u0dad\u0dca\u0dad\u0d9a\u0dab\u0dca\u0da9\u0dd2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda \u0dc3\u0dbd\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0d9c\u0dd9 \u0dc3\u0daf\u0dd4\u0db1\u0dca\u0db4\u0dd4\u0dbb \u0dd9\u0ddc\u0dbb\u0dca\u0d9c\u0db4\u0dda \u0dc3\u0dbd\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0d9c\u0dd9 \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0db4\u0daf\u0dc4\u0dd2\u0d85\u0dad\u0dca\u0dad\u0d9a\u0dab\u0dca\u0da9\u0dd2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc\u0db1\u0db4\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0ddc\u0dba\u0dd9\u0d9a\u0da7 \u0dbd\u0daf \u0db4\u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0dd9\u0dad \u0dd9\u0ddc\u0dbb\u0dca\u0d9c\u0db6\u0ddc\u0db0\u0d9a \u0db4\u0dba\u0ddc\u0daf\u0ddc \u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dbb\u0ddd\u0daf \u0dbb\u0dae\u0dba\u0d9a\u0dca \u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dca\u200d\u0ddc \u0d9a\u0dd2\u0dbb\u0dd3\u0db4\u0dda\u0daf\u0dd3 \u0db4\u0dd4\u0dbb\u0ddc\u0dc0\u0dd2\u0daf\u0dba\u0ddc\u0dad\u0dca\u0dd9\u0d9a \u0dc0\u0da7\u0dd2\u0db1\u0ddc\u0d9a\u0dd9\u0d9a\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc3\u0dd0\u0d9a \u0d9a\u0dbb\u0db1 \u0db6\u0dd4\u0dda\u0db0 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dd9\u0ddc\u0dc0\u0d9a\u0dca \u0dc4\u0ddc \u0dd9\u0dd0\u0dab\u0dd2\u0d9a\u0dca \u0d9c\u0dbd\u0dca \u0db6\u0dc0\u0da7 \u0dc3\u0dd0\u0d9a \u0d9a\u0dbb\u0db1 \u0db1\u0dd2\u0dbd\u0dca \u0dd0\u0dc4\u0dd0\u0dad\u0dd2 \u0d9c\u0dbd\u0dca 03 \u0d9a\u0dca \u0dc3\u0dd9\u0d9f \u0dc3\u0dd0\u0d9a\u0d9a\u0ddc\u0dbb\u0dd2\u0dba\u0db1\u0dca \u0dad\u0dd2\u0db4\u0daf\u0db4\u0db1\u0d9a\u0dd4 \u0dc4\u0ddc \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0daf\u0db4\u0daf\u0db4\u0db1\u0d9a\u0dd4 \u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dbb\u0ddd\u0daf \u0dbb\u0dae\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0d9a\u0dd0\u0dab\