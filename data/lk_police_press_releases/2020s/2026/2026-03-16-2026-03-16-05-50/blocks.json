    "text": "\u0db4\u0dd9\u0dd9 \u0dd9\u0dbb\u0dab\u0d9a\u0dbb\u0dd4 \u0d8b\u0daf\u0dbb\u0db4\u0dda \u0d87\u0dad\u0dd2 \u0dc0\u0dd6 \u0d86\u0db6\u0ddc\u0db0\u0dba\u0d9a\u0dca \u0db4\u0dc4\u0dca\u0dad\u0dd4\u0db4\u0dc0\u0db1\u0dca \u0db4\u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d9c\u0dad \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7\u0dad\u0dca, 2026.03.14 \u0daf\u0dd2\u0db1 \u0db4\u0dd4\u0dda\u0d9c\u0dbd\u0db4\u0dba\u0d9a\u0dd4\u0db4\u0dda \u0dc4\u0dbb\u0d9a\u0dd1\u0dd9\u0d9a\u0da7 \u0dbd\u0d9a\u0dca\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7\u0dad\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dd2\u0dd9\u0dbb\u0dca\u0dc1\u0db1\u0db4\u0dda\u0daf\u0dd3 \u0d85\u0db1\u0ddc\u0dc0\u0dbb\u0dab\u0dba \u0dd3 \u0d87\u0dad. \u0db4\u0dd9\u0dd9 \u0dd9\u0dbb\u0dab\u0d9a\u0dbb\u0dd4\u0da7 \u0dc4\u0dbb\u0daf\u0dd4\u0db1\u0dca \u0db4\u0dd4\u0dda\u0d9c\u0dbd\u0dba\u0ddc \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0db4\u0d9c\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db4\u0dd9\u0dba \u0dd9\u0db1\u0dd4\u0dc2\u0dca\u200d\u0dba \u0d9d\u0ddc\u0dad\u0db1\u0dba\u0d9a\u0dca\u0daf \u0dba\u0db1\u0dca\u0db1 \u0dc3\u0dda\u0db6\u0db1\u0dca\u0db0\u0db4\u0dba\u0db1\u0dca \u0d85\u0db1\u0ddc\u0dc0\u0dbb\u0dab\u0dba \u0d9a\u0dbb\u0d9c\u0dd0\u0db1\u0dd3\u0dd9 \u0dc3\u0db3\u0dc4\u0ddc \u0dc0\u0dd2\u0dd9\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc0\u0dad\u0dd3. \u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0db4 \u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0dc0\u0dd2\u0dd9\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0dba\u0dd2. 02. \u0db4\u0dc4\u0db4\u0dbb\u0ddc\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddc \u0d85\u0dba\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0dbb\u0dd9\u0dba \u0dc3\u0db8\u0d9f \u0dc3\u0dd0 \u0dbb\u0dd4\u0db4\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0dd2\u0d82\u0d9c\u0dd4\u0dd9\u0da7 - \u0db4 \u0ddc\u0da7\u0db4\u0daf\u0db1\u0dd2\u0dba\u0