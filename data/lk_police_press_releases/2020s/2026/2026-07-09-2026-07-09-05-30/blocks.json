    "text": "\u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8\u0b95\u0bb3\u0bbf\u0bb2\u0bcd, \u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95\u0ba8\u0baa\u0bca\u0bcd \u0baa\u0bc1\u0baa\u0bc1\u0ba4\u0bc1\u0b95\u0bae, \u0b89\u0bb8\u0bcd\u0baa\u0bb5\u0b9f\u0bcd\u0b9f\u0baa\u0b95\u0baf\u0bcd\u0baf\u0bca\u0bb5 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0ba4\u0bae\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3 20 \u0baa\u0baa\u0bca\u0bcd\u0b9a\u0bcd\u0b9a\u0bb8\u0bcd \u0b95\u0bca\u0bc8\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0ba8\u0bbf\u0bca\u0bcd\u0bae\u0bca\u0bc8\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b9a\u0bc1\u0bae\u0bca\u0bca\u0bcd 5 \u0baa\u0b95\u0bca\u0b9f\u0bbf \u0bb0\u0bc2\u0baa\u0bca\u0baf\u0bcd \u0bae\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0bb3\u0bcd\u0bb3 \u0b87\u0bb0\u0bc1\u0bae\u0bca\u0b9f\u0bbf \u0bb5\u0bc0\u0b9f\u0bc1\u0bae\u0bcd, \u0bb5\u0ba4\u0bcd\u0ba4\u0ba4\u0bb3 \u2013 \u0ba8\u0bc1\u0b95\u0baa\u0baa, \u0b95\u0bc1\u0b9e\u0bcd\u0b9c\u0bca\u0bb5\u0ba4\u0bcd\u0ba4\u0ba4 \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 9.5 \u0baa\u0baa\u0bca\u0bcd\u0b9a\u0bcd\u0b9a\u0bb8\u0bcd \u0b95\u0bca\u0bc8\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0ba8\u0bbf\u0bca\u0bcd\u0bae\u0bca\u0bc8\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b9a\u0bc1\u0bae\u0bca\u0bca\u0bcd 70 \u0b87\u0bb2\u0b9f\u0bcd\u0b9a\u0bae\u0bcd \u0bb0\u0bc2\u0baa\u0bca\u0baf\u0bcd \u0bae\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0bb3\u0bcd\u0bb3 \u0bb5\u0bc0\u0b9f\u0bc1\u0bae\u0bcd \u0bb5\u0bca\u0bcd\u0ba4\u0bcd\u0ba4\u0b95\u0b95\u0bcd \u0b95\u0b9f\u0bcd\u0b9f\u0bbf\u0b9f\u0bae\u0bc1\u0bae\u0bcd, \u0baa\u0baa\u0bca\u0ba4\u0ba4\u0baa\u0bcd\u0baa\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bcd \u0bb5\u0bca\u0bcd\u0ba4\u0bcd\u0ba4\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bca\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0bc8\u0ba4\u0bcd\u0ba4\u0bca\u0bb2\u0bcd \u0ba8\u0bbf\u0bca\u0bcd\u0bae\u0bca\u0bc8\u0bbf\u0b95\u0bcd\u