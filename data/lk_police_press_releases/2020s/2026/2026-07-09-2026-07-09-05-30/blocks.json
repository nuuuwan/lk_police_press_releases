    "text": "\u0b9a\u0ba8\u0bcd\u0baa\u0ba4\u0b95\u0ba8\u0baa\u0bca\u0bcd \u0ba4\u0bb1\u0bcd\u0baa\u0baa\u0bca\u0ba4\u0bc1 \u0baa\u0bbf \u0baa\u0ba4\u0b9a\u0ba4\u0bcd\u0ba4\u0ba4 \u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1 \u0ba4\u0baa\u0bcd\u0baa\u0bbf\u0b9a\u0bcd \u0baa\u0b9a\u0ba9\u0bcd\u0bb1\u0bc1\u0bb3\u0bcd\u0bb3 \u0ba8\u0bbf\u0ba4\u0bb2\u0baf\u0bbf\u0bb2\u0bcd, \u0b85\u0bb5\u0ba4 \u0b95\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0b9a\u0baf\u0bcd\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bca\u0ba9 \u0baa\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8\u0b95\u0ba4\u0bb3 \u0b9a\u0b9f\u0bcd\u0b9f\u0bb5\u0bbf\u0baa \u0bca\u0ba4 \u0baa\u0b9a\u0bca\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bb3\u0bcd \u0bb5\u0bbf\u0b9a\u0bca \u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0bca\u0bbf\u0bb5\u0bc1 \u0baa\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bca\u0bc8\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1.",
