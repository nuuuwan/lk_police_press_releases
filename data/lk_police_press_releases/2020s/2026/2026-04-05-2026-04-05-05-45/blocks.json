    "bbox": [
      108.02,
      166.69,
      418.03,
      193.77
    ],
    "text": "Missing child suspected drowned \u2013 Norwood Police Division",
    "fonts": [
      "TimesNewRomanPS-BoldMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      208.33,
      526.0,
      249.24
    ],
    "text": "Investigations have been initiated by the Norwood Police Station following a report received on the evening of 04.04.2026 that a child bathing in the Keselgamuwa Oya at the Norwood Estate within the Norwood Police Division had drowned.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      263.68,
      400.39,
      276.96
    ],
    "text": "The deceased is a 16-year-old resident of the Norwood area.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      291.52,
      509.25,
      318.6
    ],
    "text": "Preliminary investigations indicate that the child went missing while bathing in the Keselgamuwa Oya with several friends.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      333.16,
      519.66,
      360.24
    ],
    "text": "The Police Lifeguard Unit has launched a search operation to trace the missing child. Further investigations are being conducted by the Norwood Police.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
