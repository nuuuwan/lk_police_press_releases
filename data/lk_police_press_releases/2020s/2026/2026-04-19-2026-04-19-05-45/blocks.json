    ],
    "text": "Suspicious death - Polonnaruwa Police Division.",
    "fonts": [
      "TimesNewRomanPS-BoldMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      614.97,
      526.29,
      655.85
    ],
    "text": "On 17.04.2026, the Polonnaruwa Police Station received a complaint that a person had gone missing in the Leuragolla area of the Polonnaruwa Police Division. The bodies of these missing persons were found in the Parakrama Samudra on 18.04.2026.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      670.29,
      488.98,
      683.57
    ],
    "text": "The deceased was a resident of Leuragolla, Polonnaruwa, aged about 60 years.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      698.13,
      526.16,
      739.01
    ],
    "text": "The bodies have been deposited at the Polonnaruwa Hospital morgue for a post-mortem examination. Further investigations are being conducted by the Polonnaruwa Police.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
