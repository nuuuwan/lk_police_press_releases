    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      142.81,
      526.28,
      183.69
    ],
    "text": "On the same day, a suspect was arrested with 97.5 liters (130 bottles) of illegal liquor in the Kehelbaddara area of the Gampaha Police Division and presented him to the Gampaha Police Station.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      198.13,
      526.09,
      225.21
    ],
    "text": "The suspects are residents of the Gonapala Junction and Kehelbaddara areas, aged 26 and 65.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
