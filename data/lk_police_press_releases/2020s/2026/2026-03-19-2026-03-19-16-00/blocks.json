    ],
    "text": "\u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd \u0b9a\u0bc7\u0bae \u0ba8\u0bbf\u0ba4\u0bbf\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bc7\u0bae\u0bcd\u0baa\u0bb3 \u0ba8\u0bbf\u0ba4\u0bbf \u0b9a\u0bae\u0bb0\u0bc7\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0b89\u0b9f\u0ba8\u0bcd\u0ba4\u0ba4\u0baf\u0bb0\u0b95 \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0bc7\u0ba8\u0bcd\u0b9a\u0ba4\u0b95 \u0ba8\u0baa\u0bb0\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u2013 \u0bae\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbf\u0baf\u0bb2\u0bcd \u0bb5\u0bbf\u0bc7\u0bb0\u0bb0\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bc8\u0bbf\u0baf\u0b95\u0bae\u0bcd. \u0b85\u0bb0\u0b9a\u0bc1 \u0b9a\u0bc7\u0ba4\u0bb5\u0baf\u0bbf\u0bb2\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba8\u0bbf\u0ba4\u0bb2\u0baf\u0bb0\u0ba9 \u0b93\u0baf\u0bcd\u0bb5\u0bc2\u0ba4\u0bbf\u0baf\u0bae\u0bcd \u0baa\u0baa\u0bb1\u0bc1\u0bb5\u0ba4\u0bb0\u0b95 \u0b9a\u0baa\u0bb0\u0bb2\u0bbf\u0baf\u0bb0\u0ba9 \u0b86\u0bb5\u0bc8\u0b99\u0bcd\u0b95\u0ba4\u0bb3 \u0bc7\u0bae\u0bb0\u0bcd\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1, \u0bc7\u0bae\u0bcd\u0baa\u0bb3 \u0ba8\u0bbf\u0ba4\u0bbf \u0b9a\u0bae\u0bb0\u0bc7\u0b9f\u0bbf \u0baa\u0bc7\u0baf\u0bcd\u0bb5\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bb0\u0bb3\u0bbf\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0ba8\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0ba4\u0b95\u0ba4\u0baf \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbf\u0baf\u0bb2\u0bcd \u0ba8\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0ba4\u0b95 \u0b9a\u0bae\u0bb0\u0bc7\u0b9f\u0bbf \u0baa\u0bc7\u0baf\u0bcd\u0ba4\u0bc1 \u0ba8\u0bbf\u0ba4\u0bbf\u0b95\u0ba4\u0bb3 \u0b9a\u0bae\u0bb0\u0bc7\u0b9f\u0bbf\u0baf\u0bb0\u0b95 \u0baa\u0baa\u0bb1\u0bcd\u0bb1\u0ba4\u0bae \u0baa\u0ba4\u0bb0\u0b9f\u0bb0\u0bcd\u0baa\u0bb0\u0b95, \u0bae\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbf\u0baf\u0bb2\u0bcd \u0bb5\u0bbf\u0bc7\u0bb0\u0bb0\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bc8\u0bbf\u0baf\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bae\u0bc1\u0ba4\u0bb1\u0baa\u0bcd\u0baa\u0bb0\u0b9f\u0bcd\u0b9f\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0b9f\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0bc7\u0bb0\u0bb0\u0ba4\u0bc8 \u0b86\u0bb0\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0b87\u0ba4\u0ba9\u0bcd\u0baa\u0b9f\u0bbf, \u0b87\u0ba8\u0bcd\u0ba4 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0b89\u0b9f\u0ba8\u0bcd\u0ba4\u0ba4\u0baf\u0bb0\u0b95 \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 06 \u0bc7\u0ba8\u0bcd\u0b9a\u0ba4\u0b95 \u0ba8\u0baa\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b87\u0bb0\u0bc8\u0bcd\u0b9f\u0bc1 \u0baa\u0baa\u0bc8\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0bc7\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1, \u0baa\u0b95\u0bcc\u0bb0\u0bb5 \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0ba4\u0bb2\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0ba4\u0ba9\u0bcd \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0bb0\u0bcd \u0bb5\u0bbf\u0bb3\u0b95\u0bcd\u0b95\u0bae\u0bb1\u0bbf\u0baf\u0bb2\u0bbf\u0bb2\u0bcd \u0ba4\u0bb5\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bb0\u0bb1\u0bc1 \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bbf\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0bb0\u0bb0\u0bcd. \u0b87\u0b95\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bae\u0bcd \u0baa\u0ba4\u0bb0\u0b9f\u0bb0\u0bcd\u0baa\u0bb0\u0b95 \u0b9a\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0bc7\u0bb0\u0bb0\u0ba4\u0bc8\u0b95\u0bb3\u0bcd \u0b9a\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bb0\u0bc8\u0bcd\u0b9f\u0bc1 \u0b87\u0bb5\u0bcd\u0bb5\u0bb0\u0bb1\u0bc1 \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0bc7\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0baa\u0bc8\u0bcd \u0bc7\u0ba8\u0bcd\u0b9a\u0ba4\u0b95\u0ba8\u0baa\u0bb0\u0bbf\u0ba9\u0bcd \u0b95\u0bc8\u0bb5\u0bb0\u0bcd \u0b87\u0b95\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0b89\u0b9f\u0ba8\u0bcd\u0ba4\u0ba4\u0baf\u0bb0\u0b95 \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0ba4\u0bae\u0b95\u0bcd\u0b95\u0bc1 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bae\u0bcd \u0bc7\u0bb0\u0b9f\u0bcd\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 2026.03.18 \u0b86\u0ba8\u0bcd \u0ba4\u0bbf\u0b95\u0ba4\u0bbf \u0bae\u0bb0\u0ba4\u0bb2 \u0b9a\u0bb5\u0ba4\u0bb3\u0baf\u0bbf\u0bb2\u0bcd \u0bae\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbf\u0baf\u0bb2\u0bcd \u0bb5\u0bbf\u0bc7\u0bb0\u0bb0\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bc8\u0bbf\u0baf\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bb0\u0bb2\u0bcd \u0ba4\u0b95\u0ba4\u0bc1 \u0baa\u0bc7\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0bb0\u0bb0\u0bcd. \u0bc7\u0ba8\u0bcd\u0b9a\u0ba4\u0b95\u0b95 \u0ba8\u0baa\u0bb0\u0bcd 32 \u0bb5\u0baf\u0ba4\u0bc1\u0ba4\u0b9f\u0baf\u0bb5\u0bb0\u0bcd \u0baa\u0bae\u0ba4\u0bb5\u0bc7\u0bcd\u0bc7\u0bbf\u0baf \u0baa\u0bbf\u0bb0\u0b9a\u0ba4\u0bc7\u0ba4\u0bcd\u0ba4\u0ba4 \u0b9a\u0bc7\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bb0\u0bcd. \u0bc7\u0ba8\u0bcd\u0b9a\u0ba4\u0b95 \u0ba8\u0baa\u0ba4\u0bb0 2026.03.19 \u0b85\u0ba9\u0bcd\u0bb1\u0bc1 \u0baa\u0bae\u0ba4\u0bb5\u0bc7\u0bcd\u0bc7\u0bbf\u0baf \u0ba8\u0bc0\u0ba4\u0bbf\u0bb5\u0bb0\u0ba9\u0bcd \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0ba4\u0bb2\u0baa\u0bcd \u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3\u0bb0\u0bb0\u0bcd. \u0bae\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbf\u0baf\u0bb2\u0bcd \u0bb5\u0bbf\u0bc7\u0bb0\u0bb0\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bc8\u0bbf\u0baf\u0b95\u0bae\u0bcd \u0b9a\u0bae\u0bb2\u0ba4\u0bbf\u0b95 \u0bb5\u0bbf\u0bc7\u0bb0\u0bb0\u0ba4\u0bc8\u0b95\u0ba4\u0bb3 \u0b9a\u0bae\u0bb1\u0bcd\u0baa\u0b95\u0bb0\u0bc8\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba4\u0bc1. \u0b9a\u0baa\u0bb0\u0bb2\u0bc0\u0bb8\u0bcd \u0b8a\u0b9f\u0b95 \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1",
    "fonts": [
      "IskoolaPota-Bold",
      "Kavivanar-Regular"
    ],
    "sizes": [
      12.0,
      14.039999961853027
    ]
  }
]