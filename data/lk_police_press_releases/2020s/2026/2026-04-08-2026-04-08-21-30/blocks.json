    "text": "\u0dc4\u0dd9\u0dc4 \u0ddc\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0dd9 \u0d85\u0dba\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0dc3\u0db8\u0d9f \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc4\u0dc0\u0dca\u200d\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0daf\u0dca\u200d\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0dca\u200d\u0da7 - \u0db6\u0dc3\u0dca\u0db1\u0ddc\u0dc4\u0dd2 \u0db4\u0dc5\u0ddc\u0dad \u0d8b\u0dad\u0dd4 \u0d85\u0db4 \u0ddc\u0db0 \u0dc4\u0d9a\u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0dba. \u0db4\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0dad\u0dd4\u0db8\u0ddc\u0db4\u0dda \u0d8b\u0db4\u0db4\u0dd9\u0dc3\u0dca \u0db8\u0dad \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0db4\u0dd4\u0dbb\u0ddc \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0ddc\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0ddc \u0db4\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb \u0db4\u0dd9\u0db1 \u0dba\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0d85\u0db4\u0dbb\u0ddc\u0db0 \u0dc4\u0ddc \u0db8\u0dad\u0dca\u0dbb\u0dc0\u0dba \u0db1\u0dd2\u0dc0\u0ddc\u0dbb\u0dab \u0db4\u0db8\u0db4\u0dc4\u0dba\u0dd4\u0db8\u0da7 \u0dc3\u0db8\u0dd9\u0ddc\u0db8\u0dd3\u0dc0 2026.04.08 \u0daf\u0dd2\u0db1 \u0d8b\u0dd9\u0dd1\u0dc3\u0db1 \u0dd9\u0db4\u0dda\u0db8\u0dd4\u0dbd\u0dca\u0dbd \u0db4\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db4\u0dda \u0db4\u0db6\u0ddc\u0dbd\u0dca\u0dbd\u0db1 \u0d8b\u0dad\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0db4\u0dda\u0dc1\u0db4\u0dda\u0daf\u0dd3 \u0db6\u0dc3\u0dca\u0db1\u0ddc\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0ddc\u0dad \u0d8b\u0dad\u0dd4\u0dbb \u0d85\u0db4\u0dbb\u0ddc\u0db0 \u0db4\u0d9a\u0ddc\u0da7\u0dca\u0da8\u0ddc\u0dc3\u0db4\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0ddc\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0dda\u0da9\u0ddc\u0dba\u0db8\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dbd\u0dd9 \u0db4\u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0db8\u0dad \u0dc0\u0dd0\u0d